@inherits LayoutComponentBase
@implements IDisposable
@inject TokenStore Tokens
@inject NavigationManager Nav
@inject IJSRuntime Js

<div class="page">
    <header class="top-bar">
        <a class="brand" href="/">FactoryGame</a>
        <nav class="nav">
            <a href="/">Home</a>
            <a href="/exchange">Börs</a>
            <a href="/pool">Pool</a>
            <a href="/boards">Fabrik</a>
            <a href="/wiki">Wiki</a>
            <a href="/cli">CLI</a>
        </nav>
        <span class="session">@(string.IsNullOrEmpty(Tokens.BearerToken) ? "Ej inloggad" : "Inloggad")</span>
    </header>
    <main class="content">
        @Body
    </main>
    <footer class="app-footer muted">
        <span>Version @AppReleaseVersion.Current</span>
        <button type="button" class="secondary" @onclick="HardReloadClientAsync" disabled="@_reloadBusy" title="Rensa PWA-cache och ladda om så senaste WASM hämtas">
            @(_reloadBusy ? "Uppdaterar…" : "Hämta senaste app")
        </button>
    </footer>
</div>

@code {
    private bool _reloadBusy;

    protected override async Task OnInitializedAsync()
    {
        await Tokens.LoadAsync();
        Tokens.Changed += OnAuthChanged;
    }

    private void OnAuthChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task HardReloadClientAsync()
    {
        if (_reloadBusy)
            return;
        _reloadBusy = true;
        try
        {
            await Js.InvokeVoidAsync("factoryGame.hardReloadClient");
        }
        catch (JSException)
        {
            _reloadBusy = false;
        }
    }

    public void Dispose() => Tokens.Changed -= OnAuthChanged;
}
