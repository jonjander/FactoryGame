@inherits LayoutComponentBase
@implements IDisposable
@inject TokenStore Tokens
@inject WalletState Wallet
@inject NavigationManager Nav
@inject IJSRuntime Js
@inject AppVersionMonitor AppVersion

<div class="page">
    <header class="top-bar">
        <a class="brand" href="/">FactoryGame</a>
        <nav class="nav">
            <a href="/">Home</a>
            <a href="/exchange" title="Trading — buy and sell elements in your pool">Exchange</a>
            <a href="/market" title="Leaderboards, price analysis and ranking per element">Market</a>
            <a href="/pool">Pool</a>
            <a href="/boards">Factory</a>
            <a href="/transactions" title="Economy history — buys, sells and income">Account</a>
            <a href="/wiki">Wiki</a>
            <a href="/cli">CLI</a>
        </nav>
        <span class="session">
            @if (Wallet.Cash is { } cash)
            {
                <span class="wallet" title="Cash">@cash.ToString("0.##")</span>
            }
            @(string.IsNullOrEmpty(Tokens.BearerToken) ? "Not logged in" : "Logged in")
            @if (!string.IsNullOrEmpty(Tokens.BearerToken))
            {
                <button type="button" class="secondary session-action" @onclick="LogoutAsync">Log out</button>
            }
            else
            {
                <a class="session-action" href="/">Log in</a>
            }
        </span>
    </header>
    <main class="content">
        @Body
    </main>
    @if (AppVersion.UpdateAvailable)
    {
        <div class="app-update-banner" role="status">
            <span>New version @AppVersion.ServerVersion available (you are running @AppReleaseVersion.Current).</span>
            <button type="button" @onclick="HardReloadClientAsync" disabled="@_reloadBusy">
                @(_reloadBusy ? "Updating..." : "Update now")
            </button>
        </div>
    }
    <AppVersionFooter />
    <SnackbarHost />
</div>

@code {
    private bool _reloadBusy;

    protected override async Task OnInitializedAsync()
    {
        AppVersion.Changed += OnAppVersionChanged;
        AppVersion.Start();
        await Tokens.LoadAsync();
        Tokens.Changed += OnAuthChanged;
        Wallet.Changed += OnWalletChanged;
        await Wallet.RefreshAsync();
    }

    private void OnAppVersionChanged() => _ = InvokeAsync(StateHasChanged);

    private void OnAuthChanged() => _ = OnAuthChangedAsync();

    private async Task OnAuthChangedAsync()
    {
        await Wallet.RefreshAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void OnWalletChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task LogoutAsync()
    {
        await Tokens.ClearAsync();
        Nav.NavigateTo("/");
    }

    private async Task HardReloadClientAsync()
    {
        if (_reloadBusy)
            return;
        _reloadBusy = true;
        try
        {
            await Js.InvokeVoidAsync("factoryGame.hardReloadClient");
        }
        catch (JSException)
        {
            _reloadBusy = false;
        }
    }

    public void Dispose()
    {
        AppVersion.Changed -= OnAppVersionChanged;
        Tokens.Changed -= OnAuthChanged;
        Wallet.Changed -= OnWalletChanged;
    }
}
