@inherits LayoutComponentBase
@implements IDisposable
@inject TokenStore Tokens
@inject NavigationManager Nav

<div class="page">
    <header class="top-bar">
        <a class="brand" href="/">FactoryGame</a>
        <nav class="nav">
            <a href="/">Home</a>
            <a href="/exchange">Börs</a>
            <a href="/pool">Pool</a>
            <a href="/boards">Fabrik</a>
            <a href="/wiki">Wiki</a>
            <a href="/cli">CLI</a>
        </nav>
        <span class="session">@(string.IsNullOrEmpty(Tokens.BearerToken) ? "Ej inloggad" : "Inloggad")</span>
    </header>
    <main class="content">
        @Body
    </main>
    <footer class="app-footer muted">Version @AppReleaseVersion.Current</footer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Tokens.LoadAsync();
        Tokens.Changed += OnAuthChanged;
    }

    private void OnAuthChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Tokens.Changed -= OnAuthChanged;
}
