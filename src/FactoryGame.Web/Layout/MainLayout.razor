@inherits LayoutComponentBase
@implements IDisposable
@inject TokenStore Tokens
@inject WalletState Wallet
@inject NavigationManager Nav
@inject IJSRuntime Js
@inject AppVersionMonitor AppVersion

<div class="page">
    <header class="top-bar">
        <a class="brand" href="/">FactoryGame</a>
        <nav class="nav">
            <a href="/">Home</a>
            <a href="/exchange" title="Handel — köp och sälj grundämnen i din pool">Börs</a>
            <a href="/market" title="Topplistor, prisanalys och rankning per grundämne">Marknad</a>
            <a href="/pool">Pool</a>
            <a href="/boards">Fabrik</a>
            <a href="/transactions" title="Ekonomihistorik — köp, sälj och inkomster">Konto</a>
            <a href="/wiki">Wiki</a>
            <a href="/cli">CLI</a>
        </nav>
        <span class="session">
            @if (Wallet.Cash is { } cash)
            {
                <span class="wallet" title="Kassa">@cash.ToString("0.##")</span>
            }
            @(string.IsNullOrEmpty(Tokens.BearerToken) ? "Ej inloggad" : "Inloggad")
            @if (!string.IsNullOrEmpty(Tokens.BearerToken))
            {
                <button type="button" class="secondary session-action" @onclick="LogoutAsync">Logga ut</button>
            }
            else
            {
                <a class="session-action" href="/">Logga in</a>
            }
        </span>
    </header>
    <main class="content">
        @Body
    </main>
    @if (AppVersion.UpdateAvailable)
    {
        <div class="app-update-banner" role="status">
            <span>Ny version @AppVersion.ServerVersion finns (du kör @AppReleaseVersion.Current).</span>
            <button type="button" @onclick="HardReloadClientAsync" disabled="@_reloadBusy">
                @(_reloadBusy ? "Uppdaterar…" : "Uppdatera nu")
            </button>
        </div>
    }
    <footer class="app-footer muted">
        <span>Version @AppReleaseVersion.Current</span>
        <button type="button" class="secondary" @onclick="HardReloadClientAsync" disabled="@_reloadBusy" title="Rensa PWA-cache och ladda om så senaste WASM hämtas">
            @(_reloadBusy ? "Uppdaterar…" : "Hämta senaste app")
        </button>
    </footer>
    <SnackbarHost />
</div>

@code {
    private bool _reloadBusy;

    protected override async Task OnInitializedAsync()
    {
        AppVersion.Changed += OnAppVersionChanged;
        AppVersion.Start();
        await Tokens.LoadAsync();
        Tokens.Changed += OnAuthChanged;
        Wallet.Changed += OnWalletChanged;
        await Wallet.RefreshAsync();
    }

    private void OnAppVersionChanged() => _ = InvokeAsync(StateHasChanged);

    private void OnAuthChanged() => _ = OnAuthChangedAsync();

    private async Task OnAuthChangedAsync()
    {
        await Wallet.RefreshAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void OnWalletChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task LogoutAsync()
    {
        await Tokens.ClearAsync();
        Nav.NavigateTo("/");
    }

    private async Task HardReloadClientAsync()
    {
        if (_reloadBusy)
            return;
        _reloadBusy = true;
        try
        {
            await Js.InvokeVoidAsync("factoryGame.hardReloadClient");
        }
        catch (JSException)
        {
            _reloadBusy = false;
        }
    }

    public void Dispose()
    {
        AppVersion.Changed -= OnAppVersionChanged;
        Tokens.Changed -= OnAuthChanged;
        Wallet.Changed -= OnWalletChanged;
    }
}
