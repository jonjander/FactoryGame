    private sealed record OpenOrderStatus(string Badge, string BadgeClass, string Message, string? Suggestion, string CssClass);

    private OpenOrderStatus DescribeOpenOrderStatus(MyOpenOrderDto order, bool isBuy)
    {
        if (_selected is null)
            return new OpenOrderStatus("Open", "badge-wait", "Order is in the order book.", null, "open-order-wait");

        if (isBuy)
        {
            if (_selected.BestAsk is not { } ask)
                return new OpenOrderStatus(
                    "Waiting",
                    "badge-wait",
                    "No seller in the book yet — order fills when someone lists for sale.",
                    "The market auto-fills over time, or raise your limit price.",
                    "open-order-wait");

            if (order.LimitPrice < ask)
                return new OpenOrderStatus(
                    "Price too low",
                    "badge-blocked",
                    $"Your limit {order.LimitPrice:0.##} is below best ask {ask:0.##} — no seller matches yet.",
                    $"Raise to at least {ask:0.##} to buy immediately against the book.",
                    "open-order-blocked");

            return new OpenOrderStatus(
                "Waiting for volume",
                "badge-wait",
                $"Price is sufficient against ask {ask:0.##}, but there is not enough volume right now.",
                "Order stays open until a seller fills the rest.",
                "open-order-wait");
        }

        if (_selected.BestBid is not { } bid)
            return new OpenOrderStatus(
                "Waiting",
                "badge-wait",
                "No buyer in the book yet.",
                null,
                "open-order-wait");

        if (order.LimitPrice > bid)
            return new OpenOrderStatus(
                "Price too high",
                "badge-blocked",
                $"Your limit {order.LimitPrice:0.##} is above best bid {bid:0.##}.",
                $"Lower to {bid:0.##} or below for a faster fill.",
                "open-order-blocked");

        return new OpenOrderStatus(
            "Waiting for volume",
            "badge-wait",
            "Price matches buyers but volume is insufficient.",
            null,
            "open-order-wait");
    }

