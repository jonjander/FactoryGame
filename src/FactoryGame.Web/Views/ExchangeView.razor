    private async Task CancelOrderAsync(MyOpenOrderDto order)
    {
        _actingOrderId = order.Id;
        _orderFeedback = "";
        try
        {
            var res = await Http.PostAsync($"/v1/market/orders/{order.Id}/cancel", null);
            var body = await res.Content.ReadAsStringAsync();
            if (res.IsSuccessStatusCode)
            {
                _orderFeedbackKind = "ok";
                _orderFeedback = "Order cancelled.";
                Snackbar.Show("Order cancelled", SnackbarKind.Success);
                _editingOrderId = null;
                await RefreshAfterOrderAsync();
            }
            else
            {
                _orderFeedbackKind = "error";
                _orderFeedback = ParseApiError(body, (int)res.StatusCode);
                Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            }
        }
        catch (Exception ex)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = ApiConnectionErrors.Format(ex);
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
        }
        finally
        {
            _actingOrderId = null;
        }
    }

    private Task SubmitAmendAsync(MyOpenOrderDto order) => AmendOrderAsync(order, _editingPrice);

    private async Task AmendToAskAsync(MyOpenOrderDto order, decimal ask) => await AmendOrderAsync(order, ask);

    private async Task AmendOrderAsync(MyOpenOrderDto order, decimal newPrice)
    {
        if (newPrice <= 0) return;

        _actingOrderId = order.Id;
        _orderFeedback = "";
        try
        {
            var res = await Http.PostAsJsonAsync(
                $"/v1/market/orders/{order.Id}/amend",
                new AmendOrderRequest(newPrice));
            var body = await res.Content.ReadAsStringAsync();
            if (res.IsSuccessStatusCode)
            {
                var result = JsonSerializer.Deserialize<OrderActionResponse>(body, JsonOpts);
                _editingOrderId = null;
                if (result is { QuantityFilled: > 0, QuantityRemaining: 0 })
                {
                    _orderFeedbackKind = "ok";
                    _orderFeedback = $"Order filled after price change: {result.QuantityFilled} units.";
                    Snackbar.Show("Order filled", SnackbarKind.Success);
                }
                else if (result is { QuantityFilled: > 0 })
                {
                    _orderFeedbackKind = "warn";
                    _orderFeedback = $"Partially filled: {result.QuantityFilled} units. {result.QuantityRemaining} units still open.";
                    Snackbar.Show("Order partially filled", SnackbarKind.Info);
                }
                else
                {
                    _orderFeedbackKind = "warn";
                    _orderFeedback = $"Price updated to {newPrice:0.##} — order still waiting for counterparty.";
                    Snackbar.Show("Price updated", SnackbarKind.Info);
                }
                await RefreshAfterOrderAsync();
            }
            else
            {
                _orderFeedbackKind = "error";
                _orderFeedback = ParseApiError(body, (int)res.StatusCode);
                Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            }
        }
        catch (Exception ex)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = ApiConnectionErrors.Format(ex);
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
        }
        finally
        {
            _actingOrderId = null;
        }
    }

    private string ChartPoints
    {
        get
        {
            if (_history.Count < 2) return "";
            var min = _history.Min(c => c.Close);
            var max = _history.Max(c => c.Close);
            var range = max - min;
            if (range == 0) range = 1;
            var step = (double)(ChartWidth - 4) / (_history.Count - 1);
            var parts = new List<string>();
            for (var i = 0; i < _history.Count; i++)
            {
                var x = 2 + i * step;
                var y = ChartHeight - 2 - (double)((_history[i].Close - min) / range) * (ChartHeight - 4);
                parts.Add($"{x.ToString(Invariant)},{y.ToString(Invariant)}");
            }
            return string.Join(" ", parts);
        }
    }

    private async Task PlaceAsync()
    {
        if (!CanSubmit)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = "Check price and quantity (must be > 0).";
            return;
        }

        if (_side.Equals("sell", StringComparison.OrdinalIgnoreCase) && _selected is { } sel && _qty > sel.PoolQuantity)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = $"You only have {sel.PoolQuantity} units in pool — lower quantity.";
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            return;
        }

        _placing = true;
        _orderFeedback = "";
        _orderDetails = "";
        _error = null;

        try
        {
            try
            {
                await Http.GetAsync($"/v1/market/elements/{_selectedId}/depth?dna={_selectedDna}");
            }
            catch
            {
                // Try placing order anyway — depth may have failed without making matching impossible.
            }

            var res = await Http.PostAsJsonAsync("/v1/market/orders",
                new PlaceOrderRequest(_selectedId, _selectedDna, _side, _price, _qty, $"web-{Guid.NewGuid():N}"));

            var body = await res.Content.ReadAsStringAsync();

            if (res.IsSuccessStatusCode)
            {
                var order = JsonSerializer.Deserialize<PlaceOrderResponse>(body, JsonOpts);
                if (order != null)
                {
                    ApplyOrderResultFeedback(order);
                }
                else
                {
                    _orderFeedbackKind = "ok";
                    _orderFeedback = "Order sent to server.";
                    Snackbar.Show("Order submitted", SnackbarKind.Success);
                }

                try
                {
                    await RefreshAfterOrderAsync();
                }
                catch
                {
                    // Keep order confirmation even if refresh fails.
                }
            }
            else
            {
                _orderFeedbackKind = "error";
                _orderFeedback = ParseApiError(body, (int)res.StatusCode);
                Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            }
        }
        catch (Exception ex)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = ApiConnectionErrors.Format(ex);
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
        }
        finally
        {
            _placing = false;
        }
    }

    private void ApplyOrderResultFeedback(PlaceOrderResponse order)
    {
        var status = order.Status;
        var filled = order.QuantityFilled;
        var remaining = order.QuantityRemaining;
        var original = order.OriginalQuantity > 0 ? order.OriginalQuantity : _qty;
        var sideLabel = _side == "buy" ? "Buy" : "Sell";
        var fillPrice = order.AverageFillPrice?.ToString("0.##") ?? _price.ToString("0.##");

        if (status.Equals("Filled", StringComparison.OrdinalIgnoreCase))
        {
            _orderFeedbackKind = "ok";
            _orderFeedback = $"{sideLabel} filled: {filled} units at avg {fillPrice}.";
            Snackbar.Show("Order filled", SnackbarKind.Success);
            SetLastFill(filled, order.AverageFillPrice ?? _price);
        }
        else if (filled > 0)
        {
            _orderFeedbackKind = "warn";
            _orderFeedback = $"{sideLabel} partially filled: {filled} of {original} units (avg {fillPrice}). {remaining} units still open.";
            Snackbar.Show("Order partially filled", SnackbarKind.Info);
            SetLastFill(filled, order.AverageFillPrice ?? _price);
        }
        else if (status.Equals("Open", StringComparison.OrdinalIgnoreCase))
        {
            _orderFeedbackKind = "warn";
            _orderFeedback = BuildNoFillExplanation(sideLabel, remaining);
            Snackbar.Show("Order open — no match", SnackbarKind.Info);
        }
        else
        {
            _orderFeedbackKind = "warn";
            _orderFeedback = $"{sideLabel} status {status}: {remaining} units remaining.";
            Snackbar.Show("Order registered", SnackbarKind.Info);
        }

        _orderDetails = $"Order id: {order.OrderId:N}";
    }

    private string BuildNoFillExplanation(string sideLabel, long remaining)
    {
        if (_selected is null)
            return $"{sideLabel} is open ({remaining} units) — no counterparty matched your limit price {_price:0.##}.";

        if (_side == "buy")
        {
            var ask = _selected.BestAsk?.ToString("0.##") ?? "—";
            if (_selected.BestAsk is { } best && _price < best)
                return $"{sideLabel} open ({remaining} units): limit {_price:0.##} is below best ask {best:0.##}. Raise price or use Buy at ask.";
            return $"{sideLabel} open ({remaining} units): no fill against sellers in the book right now (best ask {ask}). Order appears under Your open orders.";
        }

        var bid = _selected.BestBid?.ToString("0.##") ?? "—";
        if (_selected.BestBid is { } bestBid && _price > bestBid)
            return $"{sideLabel} open ({remaining} units): limit {_price:0.##} is above best bid {bestBid:0.##}. Lower price or use Sell at bid.";
        return $"{sideLabel} open ({remaining} units): no buyer matched (best bid {bid}).";
    }

    private void SetLastFill(long quantity, decimal price, string? counterparty = null)
    {
        _lastFill = new MarketTradeDto(
            Guid.Empty, _selectedId, _selectedDna, price, quantity, DateTimeOffset.UtcNow,
            null, counterparty, false, false, null, null);
        _lastFillCounterparty = counterparty;
    }

    private async Task RefreshAfterOrderAsync()
    {
        var savedFeedback = _orderFeedback;
        var savedKind = _orderFeedbackKind;
        var savedDetails = _orderDetails;
        var savedFill = _lastFill;
        var savedFillCounterparty = _lastFillCounterparty;

        await RefreshAsync(afterOrder: true);
        await LoadTradesAsync(_selectedId, _selectedDna);
        await Wallet.RefreshAsync();

        if (savedFill is not null && _trades.FirstOrDefault(t =>
                t.Quantity == savedFill.Quantity
                && t.Price == savedFill.Price
                && (DateTimeOffset.UtcNow - t.CreatedAt).TotalMinutes < 5) is { } matched)
        {
            savedFillCounterparty = FormatTradeCounterparty(matched);
        }

        _orderFeedback = savedFeedback;
        _orderFeedbackKind = savedKind;
        _orderDetails = savedDetails;
        _lastFill = savedFill;
        _lastFillCounterparty = savedFillCounterparty;
        if (_lastFill is { } lf && _trades.Any(t =>
                t.Quantity == lf.Quantity
                && t.Price == lf.Price
                && (DateTimeOffset.UtcNow - t.CreatedAt).TotalMinutes < 5))
            _lastFill = null;
        if (_selected is { } sel)
            _orderDetails += $" · Pool now: {sel.PoolQuantity} units.";
        if (Wallet.Cash is { } cash)
            _orderDetails += $" · Cash: {cash:0.##}.";
    }

    private static string ParseApiError(string body, int statusCode)
    {
        if (string.IsNullOrWhiteSpace(body))
            return statusCode switch
            {
                401 => "Not logged in — log in again.",
                409 => "Order could not be placed (e.g. insufficient pool or full pool).",
                400 => "Invalid order.",
                _ => $"Server responded with error ({statusCode})."
            };

        try
        {
            using var doc = JsonDocument.Parse(body);
            if (doc.RootElement.TryGetProperty("error", out var err))
                return err.GetString() ?? body;
        }
        catch
        {
            // ignore
        }

        return body.Length > 200 ? body[..200] + "..." : body;
    }

    private void ApplyTradeQueryFromUri()
    {
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query;
        if (string.IsNullOrEmpty(query))
            return;

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length != 2)
                continue;

            var key = Uri.UnescapeDataString(kv[0]);
            var value = Uri.UnescapeDataString(kv[1]);
            if (key.Equals("elementId", StringComparison.OrdinalIgnoreCase)
                && int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var elementId)
                && elementId > 0)
            {
                _pendingElementId = elementId;
                _selectedId = elementId;
                _side = "buy";
            }
            else if (key.Equals("dna", StringComparison.OrdinalIgnoreCase)
                     && long.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var dna)
                     && dna != 0)
            {
                _pendingDna = dna;
                _selectedDna = dna;
            }
        }
    }

    private bool TryApplyPendingSelection()
    {
        if (_pendingElementId is not int elementId || _pendingDna is not long dna)
            return false;

        var match = _summary.FirstOrDefault(s => s.ElementId == elementId && s.Dna == dna);
        if (match == null)
            return false;

        _selectedId = elementId;
        _selectedDna = dna;
        _side = "buy";
        _selected = match;
        return true;
    }

    private async Task EnsurePendingBuyRowAsync(int elementId, long dna)
    {
        if (_summary.Any(s => s.ElementId == elementId && s.Dna == dna))
            return;

        try
        {
            var elements = await Http.GetFromJsonAsync<List<ElementContentItem>>(
                "/v1/content/elements?locale=en", JsonOpts);
            var element = elements?.FirstOrDefault(e => e.Id == elementId);
            if (element == null)
                return;

            var depth = await Http.GetFromJsonAsync<MarketDepthDto>(
                $"/v1/market/elements/{elementId}/depth?dna={dna}", JsonOpts);

            var phaseKey = element.Decoded.Phase;
            var row = new MarketElementSummaryDto(
                elementId,
                dna,
                depth?.Symbol ?? element.Symbol,
                phaseKey,
                WikiPresentation.PhaseLabel(phaseKey),
                depth?.DisplayName ?? element.Name,
                0,
                depth?.BestAsk ?? depth?.BestBid ?? 10m,
                null,
                depth?.BestBid,
                depth?.BestAsk);

            _summary.Insert(0, row);
            _selectedId = elementId;
            _selectedDna = dna;
            _side = "buy";
            _selected = row;
        }
        catch
        {
            // Keep existing exchange view if prefilling fails.
        }
    }

