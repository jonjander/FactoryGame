        if (_side.Equals("buy", StringComparison.OrdinalIgnoreCase) && sel.BestAsk is { } ask)
            _price = ask;
        else if (_side.Equals("sell", StringComparison.OrdinalIgnoreCase) && sel.BestBid is { } bid)
            _price = bid;
