@using System.Globalization
@using System.Net.Http.Json
@using FactoryGame.Web.Models
@using FactoryGame.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject ViewportLayoutService Viewport
@implements IDisposable

<PageTitle>Wiki</PageTitle>

<div class="wiki-page">
    <header class="panel wiki-hero">
        <div class="wiki-hero-top">
            <div>
                <h2 class="wiki-title">Game wiki</h2>
                <p class="muted wiki-subtitle">Look up machines, base elements, and material DNA before you wire your factory.</p>
            </div>
            <button type="button" class="secondary wiki-refresh" @onclick="LoadAsync" disabled="@_busy">
                @(_busy ? "Loading..." : "Refresh")
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error">@_error</p>
        }
        else if (_wiki is not null)
        {
            <div class="wiki-meta">
                <span>@_wiki.Machines.Count machines</span>
                <span aria-hidden="true">·</span>
                <span>@_wiki.Elements.Count base elements</span>
            </div>
            <p class="wiki-daily-tip">@WikiPresentation.DailyTip(_wiki.Machines)</p>
        }

        <div class="wiki-search-row">
            <input type="search"
                   class="wiki-search"
                   placeholder="Search machine, symbol, name, phase... (try &quot;ash&quot; or &quot;dna&quot;)"
                   @bind="_search"
                   @bind:event="oninput"
                   aria-label="Search wiki" />
            @if (!string.IsNullOrWhiteSpace(_search))
            {
                <button type="button" class="secondary wiki-search-clear" @onclick="ClearSearch">Clear</button>
            }
        </div>

        <nav class="wiki-tabs" aria-label="Wiki sections">
            @foreach (var tab in Tabs)
            {
                <button type="button"
                        class="wiki-tab @(_activeTab == tab.Id ? "wiki-tab-active" : "")"
                        @onclick="() => SelectTab(tab.Id)">
                    @tab.Label
                </button>
            }
        </nav>
    </header>

    @if (_showFallbackCard)
    {
        <section class="panel wiki-fallback-card">
            <h3>Fallback material</h3>
            <p>When a machine does not get the right input (wrong phase, blocking properties, broken rules), output becomes <strong>ash</strong> or <strong>goo</strong> -- worthless junk that shows clearly in logs and factory info.</p>
            <p class="muted">Tip: read the machine requirements here in the wiki before wiring pipes -- or check why a machine is red/blocked on the factory floor.</p>
        </section>
    }

    @if (_showDnaExplainerFlag)
    {
        <section class="panel wiki-dna-explainer">
            <h3>DNA -- the game's chemical fingerprint</h3>
            <p>Each material carries a DNA fingerprint — phase, volatility, boiling and freezing temperament, and chemical family. Machines reshape that fingerprint as material flows through the factory.</p>
            <div class="wiki-dna-legend">
                <span class="wiki-legend-chip wiki-dna-bar-phase">Phase</span>
                <span class="wiki-legend-chip wiki-dna-bar-explosive">Explosive</span>
                <span class="wiki-legend-chip wiki-dna-bar-fire">Fire</span>
                <span class="wiki-legend-chip wiki-dna-bar-toxic">Toxic</span>
                <span class="wiki-legend-chip wiki-dna-bar-boil">Boil</span>
                <span class="wiki-legend-chip wiki-dna-bar-freeze">Freeze</span>
            </div>
        </section>
    }

    @if (_wiki is null && !_busy && string.IsNullOrEmpty(_error))
    {
        <div class="panel"><p class="muted">Loading wiki...</p></div>
    }
    else if (_wiki is not null)
    {
        <div class="wiki-layout @GetWikiLayoutClass()">
            <aside class="wiki-sidebar panel @GetWikiSidebarClass()">
                @if (_activeTab == "overview")
                {
                    <h3 class="wiki-sidebar-title">Quick links</h3>
                    <ul class="wiki-quick-links">
                        <li><button type="button" class="wiki-link-btn" @onclick='() => SelectTab("machines")'>⚙️ All machines</button></li>
                        <li><button type="button" class="wiki-link-btn" @onclick='() => SelectTab("elements")'>🧪 Base elements</button></li>
                        <li><button type="button" class="wiki-link-btn" @onclick="ShowDnaExplainer">🧬 What is DNA?</button></li>
                        <li><a href="/boards">🏭 To the factory</a></li>
                        <li><a href="/pool">🚢 Seaport pool</a></li>
                        <li><a href="/exchange">📈 Exchange</a></li>
                    </ul>

                    @if (_phaseStats.Count > 0)
                    {
                        <h4 class="wiki-sidebar-subtitle">Phase distribution</h4>
                        <div class="wiki-phase-bars">
                            @foreach (var stat in _phaseStats)
                            {
                                <div class="wiki-phase-bar-row">
                                    <span class="@WikiPresentation.PhaseCssClass(stat.Phase)">@WikiPresentation.PhaseLabel(stat.Phase)</span>
                                    <div class="wiki-phase-bar-track">
                                        <div class="wiki-phase-bar-fill wiki-phase-fill-@stat.Phase.ToLowerInvariant()"
                                             style="width: @(stat.Percent)%"></div>
                                    </div>
                                    <span class="muted">@stat.Count</span>
                                </div>
                            }
                        </div>
                    }
                }
                else if (_activeTab == "machines")
                {
                    <div class="wiki-sidebar-head">
                        <h3 class="wiki-sidebar-title">Filter</h3>
                        <div class="wiki-filter-chips">
                            <button type="button" class="wiki-chip @(_machineCategory == "" ? "wiki-chip-active" : "")" @onclick='() => _machineCategory = ""'>All</button>
                            @foreach (var cat in MachineCategories)
                            {
                                <button type="button"
                                        class="wiki-chip @(_machineCategory == cat ? "wiki-chip-active" : "")"
                                        @onclick="() => _machineCategory = cat">
                                    @WikiPresentation.MachineCategoryLabel(cat)
                                </button>
                            }
                        </div>
                        <p class="muted wiki-sidebar-hint">@FilteredMachines.Count() matches</p>
                    </div>
                    <ul class="wiki-sidebar-list wiki-sidebar-scroll">
                        @foreach (var m in FilteredMachines)
                        {
                            <li class="@(_selectedMachine?.Type == m.Type ? "selected" : "")">
                                <button type="button" class="wiki-sidebar-item" @onclick="() => SelectMachine(m)">
                                    <span class="wiki-sidebar-emoji">@WikiPresentation.MachineEmoji(m.Type)</span>
                                    <span>@WikiPresentation.MachineDisplayName(m.Type)</span>
                                </button>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="wiki-sidebar-head">
                        <h3 class="wiki-sidebar-title">Base elements</h3>
                        <div class="wiki-filter-chips">
                            <button type="button" class="wiki-chip @(_elementPhaseFilter == "" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = ""'>All phases</button>
                            <button type="button" class="wiki-chip @(_elementPhaseFilter == "Gas" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = "Gas"'>Gas</button>
                            <button type="button" class="wiki-chip @(_elementPhaseFilter == "Liquid" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = "Liquid"'>Liquid</button>
                            <button type="button" class="wiki-chip @(_elementPhaseFilter == "Solid" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = "Solid"'>Solid</button>
                        </div>
                        <p class="muted wiki-sidebar-hint">@FilteredElements.Count() matches</p>
                    </div>
                    <ul class="wiki-sidebar-list wiki-sidebar-list-elements wiki-sidebar-scroll">
                        @foreach (var item in FilteredElements.Take(120))
                        {
                            var el = GetElementDetail(item.Id);
                            <li class="@(_selectedElementId == item.Id ? "selected" : "")">
                                <button type="button" class="wiki-sidebar-item" @onclick="() => SelectElement(item.Id)">
                                    <span class="fg-element-badge">@item.Symbol</span>
                                    <span class="wiki-sidebar-item-name">@item.DisplayName</span>
                                    @if (el is not null)
                                    {
                                        <span class="fg-phase-badge @WikiPresentation.PhaseCssClass(el.Decoded.Phase) wiki-sidebar-phase">
                                            @WikiPresentation.PhaseLabel(el.Decoded.Phase)
                                        </span>
                                    }
                                </button>
                            </li>
                        }
                    </ul>
                }
            </aside>

            <main class="wiki-main">
                @if (_activeTab == "overview")
                {
                    <section class="panel wiki-overview">
                        <h3>Welcome to the factory reference</h3>
                        <p>Everything here grows from the same rules the simulation runs. Pick a machine or base element on the left -- or jump straight to what you are building with.</p>

                        <div class="wiki-feature-grid">
                            <button type="button" class="wiki-feature-card wiki-feature-heat" @onclick='() => { _machineCategory = "heat"; SelectTab("machines"); }'>
                                <span class="wiki-feature-icon">🔥</span>
                                <strong>Heat and melting</strong>
                                <span class="muted">Boiler, heater, cooler, melter</span>
                            </button>
                            <button type="button" class="wiki-feature-card wiki-feature-sep" @onclick='() => { _machineCategory = "separation"; SelectTab("machines"); }'>
                                <span class="wiki-feature-icon">⚗️</span>
                                <strong>Separation</strong>
                                <span class="muted">Mixer, distillator, sorter</span>
                            </button>
                            <button type="button" class="wiki-feature-card wiki-feature-logistics" @onclick='() => { _machineCategory = "logistics"; SelectTab("machines"); }'>
                                <span class="wiki-feature-icon">🚢</span>
                                <strong>Seaport</strong>
                                <span class="muted">Pool ↔ factory</span>
                            </button>
                            <button type="button" class="wiki-feature-card wiki-feature-elements" @onclick='() => SelectTab("elements")'>
                                <span class="wiki-feature-icon">🧪</span>
                                <strong>Base elements</strong>
                                <span class="muted">@_wiki.Elements.Count with generated names</span>
                            </button>
                        </div>

                        @if (_highlightElement is not null && GetElementDetail(_highlightElement.Id) is { } highlighted)
                        {
                            <div class="wiki-highlight-banner">
                                <p>You arrived from pool analysis -- showing <strong>@highlighted.Name</strong>.</p>
                                <button type="button" class="secondary" @onclick="() => SelectElement(highlighted.Id)">Show details</button>
                            </div>
                        }
                    </section>

                    <section class="wiki-machine-grid">
                        @foreach (var m in _wiki.Machines.Take(6))
                        {
                            <button type="button" class="panel wiki-machine-card" @onclick="() => SelectMachine(m)">
                                <WikiMachineIcon Type="@m.Type" Ports="@m.Ports" />
                                <h4>@WikiPresentation.MachineDisplayName(m.Type)</h4>
                                <p class="muted">@m.Ports in->out · @Truncate(m.Summary, 90)</p>
                            </button>
                        }
                    </section>
                }
                else if (_activeTab == "machines" && _selectedMachine is { } machine)
                {
                    <article class="panel wiki-detail wiki-machine-detail">
                        <div class="wiki-detail-header">
                            <WikiMachineIcon Type="@machine.Type" Ports="@machine.Ports" />
                            <div>
                                <h3>@WikiPresentation.MachineDisplayName(machine.Type)</h3>
                                <p class="muted wiki-detail-meta">
                                    <span class="wiki-type-mono">@machine.Type</span>
                                    · ports @machine.Ports
                                    · @WikiPresentation.MachineCategoryLabel(WikiPresentation.MachineCategory(machine.Type))
                                </p>
                            </div>
                        </div>

                        <div class="wiki-port-diagram" aria-label="Port layout">
                            @{
                                var portSpec = WikiPresentation.ParsePortSpec(machine.Ports);
                            }
                            <div class="wiki-port-column wiki-port-column-in">
                                @foreach (var inName in portSpec.InPorts)
                                {
                                    <span class="wiki-port-node wiki-port-in" title="@inName">@WikiPresentation.PortDisplayLabel(inName)</span>
                                }
                            </div>
                            <span class="wiki-port-pipe"></span>
                            <span class="wiki-port-box">@WikiPresentation.MachineEmoji(machine.Type)</span>
                            <span class="wiki-port-pipe"></span>
                            <div class="wiki-port-column wiki-port-column-out">
                                @foreach (var outName in portSpec.OutPorts)
                                {
                                    <span class="wiki-port-node wiki-port-out" title="@outName">@WikiPresentation.PortDisplayLabel(outName)</span>
                                }
                            </div>
                        </div>

                        <p class="wiki-detail-summary">@WikiPresentation.ExtendedSummary(machine.Type, machine.Summary)</p>

                        <h4 class="wiki-section-label">Tips from the rule engine</h4>
                        <ul class="wiki-tips-list">
                            @foreach (var tip in WikiPresentation.MachineTips(machine.Type))
                            {
                                <li>@tip</li>
                            }
                        </ul>

                        <div class="wiki-detail-actions">
                            <a class="button-link" href="/boards">Build in factory</a>
                            <button type="button" class="secondary" @onclick="ClearMachineSelection">Close</button>
                        </div>
                    </article>
                }
                else if (_activeTab == "machines")
                {
                    <section class="wiki-machine-grid">
                        @foreach (var m in FilteredMachines)
                        {
                            <button type="button" class="panel wiki-machine-card" @onclick="() => SelectMachine(m)">
                                <WikiMachineIcon Type="@m.Type" Ports="@m.Ports" />
                                <h4>@WikiPresentation.MachineDisplayName(m.Type)</h4>
                                <p class="muted">@m.Ports · @Truncate(m.Summary, 72)</p>
                            </button>
                        }
                    </section>
                }
                else if (_activeTab == "elements" && _selectedElementId is int eid && GetElementDetailView(eid) is { } element)
                {
                    <article class="panel wiki-detail wiki-element-detail">
                        <div class="wiki-detail-header wiki-element-detail-header">
                            <WikiElementOrb Element="element" />
                            <div>
                                <h3>@element.Name</h3>
                                <p class="muted wiki-detail-meta">
                                    <span class="fg-element-badge">@element.Symbol</span>
                                    Element @element.Id
                                    · <span class="fg-phase-badge @WikiPresentation.PhaseCssClass(element.Decoded.Phase)">@WikiPresentation.PhaseLabel(element.Decoded.Phase)</span>
                                </p>
                            </div>
                        </div>

                        <p class="wiki-detail-narrative">@ElementPropertyNarrator.Describe(element)</p>

                        <h4 class="wiki-section-label">DNA breakdown</h4>
                        <WikiDnaChart Element="element" />
                        <p class="muted pool-dna-hex">DNA: 0x@element.Dna.ToString("X16")</p>

                        <h4 class="wiki-section-label">Properties</h4>
                        <dl class="pool-props-grid">
                            <dt>Phase</dt><dd>@WikiPresentation.PhaseLabel(element.Decoded.Phase)</dd>
                            <dt>Explosivity</dt><dd>@element.Decoded.Explosivity %</dd>
                            <dt>Flammability</dt><dd>@element.Decoded.Flammability %</dd>
                            <dt>Toxicity</dt><dd>@element.Decoded.Toxicity %</dd>
                            <dt>Boiling point</dt><dd>@element.Decoded.BoilingPoint</dd>
                            <dt>Freeze point</dt><dd>@element.Decoded.FreezePoint</dd>
                            <dt>Family</dt><dd>@element.Decoded.FamilyId</dd>
                        </dl>

                        <WikiElementInputMachines Element="element" OnSelectMachine="SelectMachineByType" />

                        <div class="wiki-detail-actions">
                            <a class="button-link" href="@ExchangeHrefFor(element)">Trade on exchange</a>
                            <a class="button-link secondary-link" href="/pool">View pool</a>
                            <button type="button" class="secondary" @onclick="ClearElementSelection">Close</button>
                        </div>
                    </article>
                }
                else if (_activeTab == "elements")
                {
                    <div class="panel wiki-empty-detail">
                        <p class="muted">Pick a base element from the list -- or search by symbol, name, or phase.</p>
                    </div>
                }
            </main>
        </div>

        @if (ShowMobileDetailSheet && _selectedMachine is { } sheetMachine)
        {
            <div class="wiki-mobile-sheet-backdrop" @onclick="ClearMachineSelection"></div>
            <div class="wiki-mobile-sheet panel wiki-detail wiki-machine-detail">
                <div class="wiki-detail-header">
                    <WikiMachineIcon Type="@sheetMachine.Type" Ports="@sheetMachine.Ports" />
                    <div>
                        <h3>@WikiPresentation.MachineDisplayName(sheetMachine.Type)</h3>
                        <p class="muted wiki-detail-meta">
                            <span class="wiki-type-mono">@sheetMachine.Type</span>
                            · ports @sheetMachine.Ports
                        </p>
                    </div>
                </div>
                <p class="wiki-detail-summary">@WikiPresentation.ExtendedSummary(sheetMachine.Type, sheetMachine.Summary)</p>
                <div class="wiki-detail-actions">
                    <a class="button-link" href="/boards">Build in factory</a>
                    <button type="button" class="secondary" @onclick="ClearMachineSelection">Close</button>
                </div>
            </div>
        }
        else if (ShowMobileDetailSheet && _selectedElementId is int sheetEid && GetElementDetailView(sheetEid) is { } sheetElement)
        {
            <div class="wiki-mobile-sheet-backdrop" @onclick="ClearElementSelection"></div>
            <div class="wiki-mobile-sheet panel wiki-detail wiki-element-detail">
                <div class="wiki-detail-header wiki-element-detail-header">
                    <WikiElementOrb Element="sheetElement" />
                    <div>
                        <h3>@sheetElement.Name</h3>
                        <p class="muted wiki-detail-meta">
                            <span class="fg-element-badge">@sheetElement.Symbol</span>
                            Element @sheetElement.Id
                        </p>
                    </div>
                </div>
                <p class="wiki-detail-narrative">@ElementPropertyNarrator.Describe(sheetElement)</p>
                <WikiDnaChart Element="sheetElement" />
                <WikiElementInputMachines Element="sheetElement" OnSelectMachine="SelectMachineByType" />
                <div class="wiki-detail-actions">
                    <a class="button-link" href="@ExchangeHrefFor(sheetElement)">Trade on exchange</a>
                    <button type="button" class="secondary" @onclick="ClearElementSelection">Close</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private static readonly (string Id, string Label)[] Tabs =
    [
        ("overview", "Overview"),
        ("machines", "Machines"),
        ("elements", "Base elements")
    ];

    private static readonly string[] MachineCategories = ["heat", "phase", "separation", "logistics"];

    private bool _busy;
    private string? _error;
    private WikiContentResponse? _wiki;
    private List<ElementContentItem> _elementDetails = [];
    private WikiElementItem? _highlightElement;

    private string _activeTab = "overview";
    private string _search = "";
    private string _machineCategory = "";
    private string _elementPhaseFilter = "";
    private WikiMachineItem? _selectedMachine;
    private int? _selectedElementId;
    private long? _selectedVariantDna;
    private bool _showDnaExplainer;
    private List<PhaseStat> _phaseStats = [];

    private bool ShowMobileDetailSheet =>
        !Viewport.UseGameShell && (_selectedMachine != null || _selectedElementId != null);

    private string GetWikiLayoutClass()
    {
        var parts = new List<string>();
        if (ShowMobileDetailSheet)
            parts.Add("wiki-layout-detail-open");
        if (_activeTab == "machines" && _selectedMachine == null)
            parts.Add("wiki-layout-machines-browse");
        return string.Join(' ', parts);
    }

    private string GetWikiSidebarClass() =>
        _activeTab is "machines" or "elements" ? "wiki-sidebar-picker" : "";

    protected override async Task OnInitializedAsync()
    {
        Viewport.Changed += OnViewportChanged;
        ApplyQueryRoute();
        await LoadAsync();
    }

    private void OnViewportChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Viewport.Changed -= OnViewportChanged;

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var wikiTask = Http.GetFromJsonAsync<WikiContentResponse>("/v1/content/wiki?locale=en");
            var elementsTask = Http.GetFromJsonAsync<List<ElementContentItem>>("/v1/content/elements?locale=en");
            await Task.WhenAll(wikiTask, elementsTask);

            _wiki = await wikiTask;
            _elementDetails = await elementsTask ?? [];

            if (_wiki == null)
            {
                _error = "Could not load wiki.";
                return;
            }

            BuildPhaseStats();
            ApplyHighlightFromQuery();
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private void BuildPhaseStats()
    {
        if (_elementDetails.Count == 0)
        {
            _phaseStats = [];
            return;
        }

        var total = _elementDetails.Count;
        _phaseStats = _elementDetails
            .GroupBy(e => e.Decoded.Phase)
            .OrderByDescending(g => g.Count())
            .Select(g => new PhaseStat(g.Key, g.Count(), (int)Math.Round(g.Count() * 100.0 / total)))
            .ToList();
    }

    private void ApplyHighlightFromQuery()
    {
        if (_wiki == null)
            return;

        if (TryGetQueryInt("elementId", out var elementId))
        {
            _highlightElement = _wiki.Elements.FirstOrDefault(e => e.Id == elementId);
            long? variantDna = TryGetQueryLong("dna", out var dna) ? dna : null;
            if (_highlightElement != null)
                SelectElement(elementId, updateUrl: false, variantDna: variantDna);
        }

        if (TryGetQueryString("machine", out var machineType))
        {
            var machine = _wiki.Machines.FirstOrDefault(m =>
                m.Type.Equals(machineType, StringComparison.OrdinalIgnoreCase));
            if (machine != null)
                SelectMachine(machine, updateUrl: false);
        }

        if (TryGetQueryString("tab", out var tab) && Tabs.Any(t => t.Id == tab))
            _activeTab = tab;
    }

    private void ApplyQueryRoute()
    {
        if (TryGetQueryString("tab", out var tab) && Tabs.Any(t => t.Id == tab))
            _activeTab = tab;
    }

    private IEnumerable<WikiMachineItem> FilteredMachines
    {
        get
        {
            if (_wiki == null)
                return [];

            IEnumerable<WikiMachineItem> q = _wiki.Machines;
            if (!string.IsNullOrWhiteSpace(_machineCategory))
                q = q.Where(m => WikiPresentation.MachineCategory(m.Type) == _machineCategory);

            if (string.IsNullOrWhiteSpace(_search))
                return q.OrderBy(m => WikiPresentation.MachineDisplayName(m.Type));

            var s = _search.Trim();
            return q.Where(m =>
                    WikiPresentation.MachineDisplayName(m.Type).Contains(s, StringComparison.OrdinalIgnoreCase)
                    || m.Type.Contains(s, StringComparison.OrdinalIgnoreCase)
                    || m.Summary.Contains(s, StringComparison.OrdinalIgnoreCase))
                .OrderBy(m => WikiPresentation.MachineDisplayName(m.Type));
        }
    }

    private IEnumerable<WikiElementItem> FilteredElements
    {
        get
        {
            if (_wiki == null)
                return [];

            IEnumerable<WikiElementItem> q = _wiki.Elements;
            if (!string.IsNullOrWhiteSpace(_elementPhaseFilter))
            {
                q = q.Where(item =>
                {
                    var detail = GetElementDetail(item.Id);
                    return detail != null
                           && detail.Decoded.Phase.Equals(_elementPhaseFilter, StringComparison.OrdinalIgnoreCase);
                });
            }

            if (string.IsNullOrWhiteSpace(_search))
                return q.OrderBy(e => e.DisplayName);

            var s = _search.Trim();
            return q.Where(e =>
            {
                var detail = GetElementDetail(e.Id);
                return e.Symbol.Contains(s, StringComparison.OrdinalIgnoreCase)
                       || e.DisplayName.Contains(s, StringComparison.OrdinalIgnoreCase)
                       || e.Id.ToString() == s
                       || (detail != null && WikiPresentation.PhaseLabel(detail.Decoded.Phase)
                           .Contains(s, StringComparison.OrdinalIgnoreCase));
            }).OrderBy(e => e.DisplayName);
        }
    }

    private bool _showFallbackCard =>
        _search.Contains("ash", StringComparison.OrdinalIgnoreCase)
        || _search.Contains("goo", StringComparison.OrdinalIgnoreCase)
        || _search.Contains("fallback", StringComparison.OrdinalIgnoreCase);

    private bool _showDnaExplainerFlag =>
        _showDnaExplainer
        || _search.Contains("dna", StringComparison.OrdinalIgnoreCase);

    private ElementContentItem? GetElementDetail(int id) =>
        _elementDetails.FirstOrDefault(e => e.Id == id);

    private ElementContentItem? GetElementDetailView(int id)
    {
        var baseElement = GetElementDetail(id);
        return baseElement == null
            ? null
            : ElementContentVariant.WithDna(baseElement, _selectedVariantDna);
    }

    private void SelectTab(string tabId)
    {
        _activeTab = tabId;
        UpdateUrl();
    }

    private void SelectMachine(WikiMachineItem machine, bool updateUrl = true)
    {
        _selectedMachine = machine;
        _activeTab = "machines";
        if (updateUrl)
            UpdateUrl(machine: machine.Type);
    }

    private void SelectMachineByType(string machineType)
    {
        var machine = _wiki?.Machines.FirstOrDefault(m =>
            m.Type.Equals(machineType, StringComparison.OrdinalIgnoreCase));
        if (machine != null)
            SelectMachine(machine);
    }

    private void SelectElement(int elementId, bool updateUrl = true, long? variantDna = null)
    {
        _selectedElementId = elementId;
        _selectedVariantDna = variantDna;
        _activeTab = "elements";
        if (updateUrl)
            UpdateUrl(elementId: elementId);
    }

    private void ClearMachineSelection()
    {
        _selectedMachine = null;
        UpdateUrl();
    }

    private void ClearElementSelection()
    {
        _selectedElementId = null;
        _selectedVariantDna = null;
        UpdateUrl();
    }

    private void ClearSearch() => _search = "";

    private void ShowDnaExplainer()
    {
        _showDnaExplainer = true;
        _search = "dna";
    }

    private void UpdateUrl(string? machine = null, int? elementId = null)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase)
        {
            ["tab"] = _activeTab
        };

        if (_activeTab == "machines" && (_selectedMachine != null || machine != null))
            q["machine"] = machine ?? _selectedMachine?.Type;
        else if (_activeTab == "elements" && (_selectedElementId != null || elementId != null))
        {
            q["elementId"] = (elementId ?? _selectedElementId)?.ToString();
            if (_selectedVariantDna is { } variantDna && variantDna != 0)
                q["dna"] = variantDna.ToString(CultureInfo.InvariantCulture);
        }

        var qs = string.Join("&", q.Where(kv => !string.IsNullOrEmpty(kv.Value)).Select(kv =>
            $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value!)}"));

        Nav.NavigateTo(qs.Length > 0 ? $"/wiki?{qs}" : "/wiki", replace: true);
    }

    private bool TryGetQueryInt(string key, out int value)
    {
        value = 0;
        return TryGetQueryString(key, out var raw) && int.TryParse(raw, out value) && value > 0;
    }

    private bool TryGetQueryLong(string key, out long value)
    {
        value = 0;
        return TryGetQueryString(key, out var raw)
               && long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out value)
               && value != 0;
    }

    private bool TryGetQueryString(string key, out string value)
    {
        value = "";
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query;
        if (string.IsNullOrEmpty(query))
            return false;

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0].Equals(key, StringComparison.OrdinalIgnoreCase))
            {
                value = Uri.UnescapeDataString(kv[1]);
                return true;
            }
        }

        return false;
    }

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..(max - 1)] + "...";

    private static string ExchangeHrefFor(ElementContentItem element) =>
        $"/exchange?elementId={element.Id}&dna={element.Dna}";

    private sealed record PhaseStat(string Phase, int Count, int Percent);
}
