@inject BoardCanvasSession Session
@implements IDisposable

@using System.Text.Json
@using FactoryGame.Contracts.Boards
@using FactoryGame.Contracts.Machines
@using FactoryGame.Contracts.Pool
@using FactoryGame.Contracts.Json
@using FactoryGame.Web.Components
@using FactoryGame.Web.Models
@using FactoryGame.Web.Services

@inject HttpClient Http
@inject OfflineCommandQueue Queue
@inject BrowserStorage Storage
@inject WalletState Wallet
@inject SnackbarService Snackbar
@inject BoardIssueMuteStore IssueMutes

<PageTitle>Factory</PageTitle>

<ConfirmDialog Visible="@Session.ConfirmVisible"
               Message="@Session.ConfirmMessage"
               ConfirmLabel="@Session.ConfirmLabel"
               OnConfirm="Session.OnConfirmDialogYesAsync"
               OnCancel="Session.OnConfirmDialogNoAsync" />

<MachineStoreInfoModal Visible="Session.StoreInfoVisible"
                       Item="Session.StoreInfoItem"
                       OnClose="Session.CloseStoreInfo" />

<div class="panel">
    <h2>Boards</h2>
    <button type="button" class="secondary" @onclick='() => Session.LoadBoardsAsync()' disabled="@Session.Busy">List</button>
    <button type="button" @onclick="Session.CreateBoardAsync" disabled="@Session.Busy">New board</button>
    @if (!string.IsNullOrEmpty(Session.Error))
    {
        <p class="error">@Session.Error</p>
    }
    <ul class="fg-board-tiles">
        @foreach (var b in Session.Boards)
        {
            var selected = Session.Selected == b.Id;
            <li class="fg-board-tile @Session.GetBoardTileCss(b) @(selected ? "fg-board-tile-selected" : "")">
                <button type="button"
                        class="fg-board-tile-main"
                        @onclick="async () => await Session.SelectBoardAsync(b.Id)"
                        aria-pressed="@selected">
                    <span class="fg-board-tile-head">
                        <span class="fg-board-tile-status-dot" title="@Session.GetDisplayStatusHint(b)"></span>
                        <span class="fg-board-tile-name">@b.Name</span>
                        <span class="fg-status-pill @Session.GetBoardStatusPillCss(b)">@Session.GetBoardStatusLabel(b)</span>
                    </span>
                    <span class="fg-board-tile-meta muted">
                        @b.PlanMachineCount machine@(b.PlanMachineCount == 1 ? "" : "s")
                        · @b.PlanConnectionCount pipes
                        · rev @b.RevisionVersion
                        @if (b.SimulationTick > 0)
                        {
                            <span> · tick @b.SimulationTick</span>
                        }
                    </span>
                    @{
                        var displayHint = Session.GetDisplayStatusHint(b);
                    }
                    @if (!string.IsNullOrEmpty(displayHint))
                    {
                        <span class="fg-board-tile-hint">@displayHint</span>
                    }
                </button>
            </li>
        }
    </ul>
</div>

<div class="panel fg-store" id="fg-machine-store">
    <h2>Machine store & inventory</h2>
    <p class="muted">Buy machines into your inventory. Place them on a saved board with any machine id (letters, digits, <code>_</code>, <code>-</code>). Seaport: buy <strong>Seaport connector</strong> and place like any other machine.</p>
    @if (Session.StoreItems.Count == 0 && Session.Connectors.Count == 0)
    {
        <p class="muted">Loading store...</p>
    }
    else
    {
        <div class="fg-table-wrap">
            <table class="fg-table">
                <thead>
                <tr><th>Machine</th><th>Price</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var item in Session.StoreItems)
                {
                    <tr>
                        <td>@item.DisplayName <span class="muted">(@item.Type)</span></td>
                        <td>@item.Price.ToString("0.##")</td>
                        <td>
                            <button type="button" class="secondary" @onclick="() => Session.ShowStoreInfo(item)">Info</button>
                            <button type="button" class="secondary" @onclick="async () => await Session.PurchaseAsync(item.Type)" disabled="@Session.Busy">Buy</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <h3>Your machine inventory</h3>
        @if (Session.Inventory.Count == 0)
        {
            <p class="muted">No purchased machines in inventory.</p>
        }
        else
        {
            <ul>
                @foreach (var row in Session.Inventory)
                {
                    <li><span class="fg-id-short" title="@row.Id">@DisplayIds.ShortGuid(row.Id)</span> — @row.MachineType</li>
                }
            </ul>
        }
    }
</div>

@if (Session.Selected != null)
{
    <div class="panel fg-board">
        <div class="fg-board-title-row">
            @if (Session.RenamingBoard)
            {
                <div class="fg-board-rename-row">
                    <label for="fg-board-rename">Name</label>
                    <input id="fg-board-rename" @bind="Session.RenameDraft" maxlength="120" />
                    <button type="button" @onclick="Session.SaveRenameAsync" disabled="@Session.Busy">Save name</button>
                    <button type="button" class="secondary" @onclick="Session.CancelRename" disabled="@Session.Busy">Cancel</button>
                </div>
            }
            else
            {
                <h3>
                    @Session.GetSelectedBoardName()
                    <span class="fg-id-short muted" title="@Session.Selected.Value.ToString()">@DisplayIds.ShortGuid(Session.Selected.Value)</span>
                </h3>
                <button type="button" class="secondary" @onclick="Session.BeginRename" disabled="@Session.Busy">Rename</button>
                <button type="button"
                        class="danger-outline"
                        @onclick="async () => await Session.DeleteBoardAsync(Session.Selected!.Value)"
                        disabled="@(Session.Busy || Session.IsSelectedBoardRunning())">Delete</button>
            }
        </div>

        <div class="fg-toolbar">
            <button type="button" class="secondary" @onclick="Session.ReloadPlanUiAsync" disabled="@Session.Busy">Reload plan from server</button>
            <button type="button" class="secondary" @onclick="Session.RefreshBoardInfoAsync" disabled="@Session.Busy">Refresh info</button>
        </div>

        @if (Session.BoardInfo != null)
        {
            <div class="fg-board-mode-banner @Session.GetBoardModeCss()">
                @if (Session.IsSelectedBoardRunning())
                {
                    <span class="fg-status-pill fg-status-running">Running</span>
                    <span class="muted">Editing locked until you stop</span>
                }
                else
                {
                    <span class="fg-status-pill fg-status-stopped">Stopped</span>
                    <span class="muted">Edit plan, save and start simulation</span>
                }
            </div>
            <BoardInfoPanel Info="Session.BoardInfo"
                            VisibleIssues="Session.GetVisibleBoardIssues()"
                            MutedIssueKeys="Session.MutedIssueKeys"
                            OnToggleIssueMute="Session.ToggleIssueMuteAsync" />
        }

        @if (Session.TryDeserializePlan(out var canvasPlan))
        {
            <div class="panel fg-sub fg-factory-view">
                <h4>Factory (visual)</h4>
                <FactoryCanvas @key="Session.Selected"
                               Plan="canvasPlan"
                               ElementCatalog="Session.Elements"
                               ReadOnly="@Session.IsSelectedBoardRunning()"
                               IsFactoryRunning="@Session.IsSelectedBoardRunning()"
                               UnitsPerSecond="@Session.GetEstimatedUnitsPerSecond()"
                               MachineMeta="Session.MachineMeta"
                               LatestKeyframe="Session.LatestKeyframe"
                               SeaportPortFlows="@(Session.BoardInfo?.SeaportPorts ?? Array.Empty<SeaportPortFlowDto>())"
                               MachinePortFlows="@(Session.BoardInfo?.MachinePortFlows ?? Array.Empty<MachinePortFlowDto>())"
                               MachineProgress="@(Session.BoardInfo?.MachineProgress ?? Array.Empty<MachineRuntimeProgressDto>())"
                               BoardIssues="@Session.GetVisibleBoardIssues()"
                               SelectedMachineId="@Session.SettingsMachineId"
                               SelectedMachineIdChanged="Session.OnCanvasMachineSelectedAsync"
                               PlanChanged="Session.OnCanvasPlanChangedAsync"
                               ConnectionAdded="Session.OnCanvasConnectionAddedAsync"
                               ConnectionRemoved="Session.OnCanvasConnectionRemovedAsync"
                               MachineRemoved="Session.OnCanvasMachineRemovedAsync"
                               LayoutCommitted="Session.OnCanvasLayoutCommittedAsync" />
            </div>
        }

        @if (Session.GetPlanMachines().Count > 0)
        {
            <div class="panel fg-sub">
                <h4>Machine settings</h4>
                <p class="muted">Click a machine on the canvas or pick from the list. Fixed steps only (dropdown). Save the plan after changes.</p>
                <label for="fg-settings-machine-pick">Machine</label>
                <select id="fg-settings-machine-pick"
                        class="fg-select fg-settings-machine-pick"
                        disabled="@(Session.Busy || Session.IsSelectedBoardRunning())"
                        @bind="Session.SettingsMachineId">
                    <option value="">— Select —</option>
                    @foreach (var m in Session.GetPlanMachines())
                    {
                        <option value="@m.Id">@m.Id (@m.Type)</option>
                    }
                </select>
            </div>
            <MachineSettingsPanel Machine="@Session.GetSettingsMachine()"
                                  Disabled="@(Session.Busy || Session.IsSelectedBoardRunning())"
                                  Elements="Session.Elements"
                                  OwnedPoolElementIds="Session.OwnedPoolElementIds"
                                  PoolVariants="Session.OwnedPoolVariants"
                                  PlanMachines="@Session.GetPlanMachines()"
                                  PlanConnections="@Session.GetPlanConnections()"
                                  MachineMeta="Session.MachineMeta"
                                  MachineChanged="Session.OnMachineSettingsChangedAsync" />
        }

        <div class="panel fg-sub">
            <PlaceMachinePanel />
        </div>

        <div class="panel fg-sub">
            <h4>Connect pipes</h4>
            <p class="muted">All ports can be selected. If a port is already connected you must confirm before the old connection is replaced.</p>
            <div class="fg-pipe-grid">
                <div>
                    <label>From machine</label>
                    <select class="fg-select" @bind="Session.PipeFromId" @bind:after="Session.OnPipeEndpointChanged">
                        <option value="">— Select —</option>
                        @foreach (var m in Session.GetPlanMachines())
                        {
                            <option value="@m.Id">@m.Id (@m.Type)</option>
                        }
                    </select>
                </div>
                <div>
                    <label>From output</label>
                    <select class="fg-select" @bind="Session.PipeFromPort" @bind:after="Session.OnPipeEndpointChanged">
                        <option value="">— Select —</option>
                        @foreach (var p in Session.GetOutputPortChoices(Session.PipeFromId))
                        {
                            <option value="@p.Name">@p.Label</option>
                        }
                    </select>
                </div>
                <div>
                    <label>To machine</label>
                    <select class="fg-select" @bind="Session.PipeToId" @bind:after="Session.OnPipeEndpointChanged">
                        <option value="">— Select —</option>
                        @foreach (var m in Session.GetPlanMachines())
                        {
                            <option value="@m.Id">@m.Id (@m.Type)</option>
                        }
                    </select>
                </div>
                <div>
                    <label>To input</label>
                    <select class="fg-select" @bind="Session.PipeToPort" @bind:after="Session.OnPipeEndpointChanged">
                        <option value="">— Select —</option>
                        @foreach (var p in Session.GetInputPortChoices(Session.PipeToId))
                        {
                            <option value="@p.Name">@p.Label</option>
                        }
                    </select>
                </div>
                <div class="fg-pipe-actions">
                    <button type="button" class="secondary" @onclick="Session.AddPipeToPlanAsync" disabled="@Session.Busy">Add pipe</button>
                </div>
            </div>
            @{
                var planConnections = Session.GetPlanConnections();
            }
            @if (planConnections.Count > 0)
            {
                <ul class="fg-connection-list">
                    @for (var ci = 0; ci < planConnections.Count; ci++)
                    {
                        var conn = planConnections[ci];
                        var connIndex = ci;
                        <li>
                            <span class="fg-connection-label">@conn.FromId.@conn.FromPort -> @conn.ToId.@conn.ToPort</span>
                            <button type="button"
                                    class="secondary"
                                    disabled="@(Session.Busy || Session.IsSelectedBoardRunning())"
                                    @onclick="@(async () => await Session.RemoveConnectionAtAsync(connIndex))">
                                Remove
                            </button>
                        </li>
                    }
                </ul>
            }
        </div>

        <h4>Plan (JSON)</h4>
        <textarea class="fg-json" rows="14" @bind="Session.PlanJson" @bind:event="oninput"></textarea>
        <div class="fg-toolbar fg-sim-controls">
            <button type="button" @onclick="Session.SavePlanAsync" disabled="@(Session.Busy || Session.IsSelectedBoardRunning())">Save</button>
            <button type="button"
                    class="@(Session.IsSelectedBoardRunning() ? "secondary fg-btn-disabled-visual" : "")"
                    @onclick="Session.StartAsync"
                    disabled="@(Session.Busy || Session.IsSelectedBoardRunning())"
                    title="@(Session.IsSelectedBoardRunning() ? "Factory is already running" : "Start simulation")">
                Start
            </button>
            <button type="button"
                    class="@(!Session.IsSelectedBoardRunning() ? "secondary fg-btn-disabled-visual" : "")"
                    @onclick="Session.StopAsync"
                    disabled="@(Session.Busy || !Session.IsSelectedBoardRunning())"
                    title="@(!Session.IsSelectedBoardRunning() ? "Factory is already stopped" : "Stop simulation")">
                Stop
            </button>
            <button type="button" class="secondary" @onclick="Session.SnapshotAsync" disabled="@Session.Busy">Snapshot</button>
        </div>
        @if (!string.IsNullOrEmpty(Session.SaveHint))
        {
            <p class="muted">@Session.SaveHint</p>
        }
        <pre class="fg-snapshot">@Session.Snapshot</pre>
    </div>
}


@code {
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsInitialized)
            await Session.InitializeAsync();
        Session.Changed += OnSessionChanged;
    }

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Session.Changed -= OnSessionChanged;
}
