@page "/transactions"
@using System.Globalization
@using System.Net.Http.Json
@using FactoryGame.Contracts.Player
@inject HttpClient Http
@inject TokenStore Tokens

<PageTitle>Transaktioner</PageTitle>

@if (string.IsNullOrEmpty(Tokens.BearerToken))
{
    <div class="panel">
        <h2>Konto</h2>
        <p class="muted">Du måste <a href="/">logga in som gäst</a> för att se transaktioner.</p>
    </div>
}
else
{
    <div class="panel">
        <div class="pool-toolbar">
            <h2>Konto</h2>
            <button type="button" class="secondary pool-refresh-btn" @onclick="LoadAsync" disabled="@_busy">Uppdatera</button>
        </div>

        <div class="tx-filters">
            <label class="tx-filter-field">
                <span class="muted">Datum från</span>
                <input type="date" @bind="_dateFrom" @bind:format="yyyy-MM-dd" />
            </label>
            <label class="tx-filter-field">
                <span class="muted">Datum till</span>
                <input type="date" @bind="_dateTo" @bind:format="yyyy-MM-dd" />
            </label>
            <button type="button" class="secondary" @onclick="ApplyFiltersAsync" disabled="@_busy">Filtrera</button>
            <button type="button" class="secondary" @onclick="ClearFiltersAsync" disabled="@_busy">Rensa filter</button>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error">@_error</p>
        }
        @if (_busy)
        {
            <p class="muted">Laddar…</p>
        }
        else if (_page?.Items.Count == 0)
        {
            <p class="muted">Inga transaktioner för valt filter.</p>
        }
        else if (_page is not null)
        {
            <div class="pool-table-wrap">
                <table class="pool-holdings-table">
                    <thead>
                        <tr>
                            <th>Tid</th>
                            <th>Typ</th>
                            <th class="pool-col-num">Belopp</th>
                            <th>Detalj</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in _page.Items)
                        {
                            <tr>
                                <td class="muted" style="white-space:nowrap">@FormatTime(tx.CreatedAt)</td>
                                <td>@FormatType(tx.Type)</td>
                                <td class="pool-col-num @(tx.CashDelta >= 0 ? "tx-positive" : "tx-negative")">
                                    <strong>@(tx.CashDelta >= 0 ? "+" : "")@tx.CashDelta.ToString("0.##")</strong>
                                </td>
                                <td class="muted">@tx.Metadata</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="tx-pager">
                <button type="button" class="secondary" disabled="@(_busy || _pageNumber <= 1)" @onclick="() => GoToPageAsync(_pageNumber - 1)">Föregående</button>
                <span class="muted">
                    Sida @_pageNumber av @TotalPages · @_page.TotalCount transaktion(er)
                </span>
                <button type="button" class="secondary" disabled="@(_busy || _pageNumber >= TotalPages)" @onclick="() => GoToPageAsync(_pageNumber + 1)">Nästa</button>
            </div>
        }
    </div>
}

@code {
    private const int PageSize = 25;

    private bool _busy;
    private string? _error;
    private PlayerTransactionsPageDto? _page;
    private int _pageNumber = 1;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private int TotalPages =>
        _page == null || _page.TotalCount == 0
            ? 1
            : (int)Math.Ceiling(_page.TotalCount / (double)PageSize);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _dateFrom = null;
        _dateTo = null;
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        _pageNumber = Math.Max(1, page);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(Tokens.BearerToken))
            return;

        _busy = true;
        _error = null;
        try
        {
            var url = BuildUrl();
            var res = await Http.GetAsync(url);
            if (!res.IsSuccessStatusCode)
            {
                _error = res.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Kunde inte läsa transaktioner (är du inloggad?)"
                    : "Kunde inte läsa transaktioner.";
                return;
            }

            _page = await res.Content.ReadFromJsonAsync<PlayerTransactionsPageDto>();
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private string BuildUrl()
    {
        var q = new List<string>
        {
            $"page={_pageNumber}",
            $"pageSize={PageSize}"
        };

        if (_dateFrom is { } from)
            q.Add($"from={Uri.EscapeDataString(new DateTimeOffset(from.Date, TimeSpan.Zero).ToString("o", CultureInfo.InvariantCulture))}");
        if (_dateTo is { } to)
            q.Add($"to={Uri.EscapeDataString(new DateTimeOffset(to.Date.AddDays(1).AddTicks(-1), TimeSpan.Zero).ToString("o", CultureInfo.InvariantCulture))}");

        return $"/v1/me/transactions?{string.Join("&", q)}";
    }

    private static string FormatTime(DateTimeOffset dt) =>
        dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string FormatType(string type) => type switch
    {
        "MachinePurchase" => "Maskinköp",
        "BoardStartAudit" => "Fabriksstart",
        "MachinePlacement" => "Maskinplacering",
        "BaseIncome" => "Basinkomst",
        "MarketBuy" => "Börsköp",
        "MarketSell" => "Börssälj",
        "MarketTrade" => "Börssälj",
        _ => type
    };
}
