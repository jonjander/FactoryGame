@page "/pool"
@using System.Net.Http.Json
@using FactoryGame.Contracts.Pool
@using FactoryGame.Web.Models
@inject HttpClient Http
@inject TokenStore Tokens

<PageTitle>Pool</PageTitle>

<ElementDeepAnalysisModal Visible="_analysisVisible"
                          Element="_analysisElement"
                          OnClose="CloseAnalysisAsync" />

@if (string.IsNullOrEmpty(Tokens.BearerToken))
{
    <div class="panel pool-page">
        <div class="pool-toolbar">
            <h2 class="pool-title">Seaport-pool</h2>
        </div>
        <p class="muted pool-empty">Du måste <a href="/">logga in som gäst</a> för att se poolen.</p>
    </div>
}
else if (_overview is null && !_busy)
{
    <div class="panel pool-page">
        <div class="pool-toolbar">
            <h2 class="pool-title">Seaport-pool</h2>
            <button type="button" class="secondary pool-refresh-btn" @onclick="LoadAsync" disabled="@_busy">Uppdatera</button>
        </div>
        <p class="muted pool-empty">Kunde inte läsa poolen.</p>
        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error pool-error">@_error</p>
        }
    </div>
}
else if (GetGroups().Count == 0 && !_busy)
{
    <div class="panel pool-page">
        <div class="pool-toolbar">
            <h2 class="pool-title">Seaport-pool</h2>
            <button type="button" class="secondary pool-refresh-btn" @onclick="LoadAsync" disabled="@_busy">Uppdatera</button>
        </div>
        <p class="muted pool-empty">Inget material i poolen. Öppna sidan igen efter inloggning om du nyss skapade konto — startpaket läggs i poolen automatiskt.</p>
    </div>
}
else if (_overview is not null)
{
    <div class="panel pool-page">
        <div class="pool-toolbar">
            <h2 class="pool-title">Seaport-pool</h2>
            <span class="pool-stat muted">Volym <strong>@_overview.UsedVolume</strong>/@_overview.MaxVolume</span>
            <span class="pool-stat pool-stat-total">Värde <strong>@_overview.TotalEstimatedValue.ToString("0.##")</strong></span>
            <button type="button" class="secondary pool-refresh-btn" @onclick="LoadAsync" disabled="@_busy">Uppdatera</button>
        </div>
        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error pool-error">@_error</p>
        }
        <div class="pool-table-wrap">
            <table class="pool-holdings-table">
                <thead>
                    <tr>
                        <th>Ämne</th>
                        <th>Variant</th>
                        <th class="pool-col-num">Antal</th>
                        <th class="pool-col-num">Pris/enh</th>
                        <th class="pool-col-num">Radvärde</th>
                        <th class="pool-col-rank">Rank</th>
                        <th class="pool-col-action"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in GetFlatRows())
                    {
                        <tr>
                            <td class="pool-element-cell">
                                <span class="fg-element-badge">@row.Symbol</span>
                                <span class="pool-element-name">@row.DisplayName</span>
                            </td>
                            <td>
                                <span class="fg-phase-badge fg-phase-@row.Phase.ToLowerInvariant()">@row.PhaseLabel</span>
                            </td>
                            <td class="pool-col-num"><strong>@row.Quantity</strong></td>
                            <td class="pool-col-num">@row.LastPrice.ToString("0.##")</td>
                            <td class="pool-col-num"><strong>@row.LineValue.ToString("0.##")</strong></td>
                            <td class="pool-col-rank">#@row.PriceRank <span class="muted">/@row.CatalogSize</span></td>
                            <td class="pool-col-action">
                                <button type="button" class="secondary pool-info-btn" @onclick="() => OpenAnalysisAsync(row.ElementId)">Info</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (GetGroups().Any(g => g.Variants.Count > 1))
        {
            <p class="muted pool-variant-hint">
                Samma grundämne kan ha flera rader (olika DNA/fas). Processat material — t.ex. kristalliserat fast E03 — hamnar som egen variant, inte i startvätskans rad.
            </p>
        }
    </div>
}

@code {
    private bool _busy;
    private string? _error;
    private PoolOverviewDto? _overview;
    private List<ElementContentItem> _elements = [];
    private bool _analysisVisible;
    private ElementContentItem? _analysisElement;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private IEnumerable<PoolFlatRow> GetFlatRows()
    {
        return GetGroups()
            .OrderBy(g => g.DisplayName)
            .SelectMany(g => g.Variants
                .OrderBy(v => v.Phase, StringComparer.Ordinal)
                .Select(v => new PoolFlatRow(g.Symbol, g.DisplayName, v)));
    }

    private sealed record PoolFlatRow(string Symbol, string DisplayName, PoolVariantStackDto Variant)
    {
        public int ElementId => Variant.ElementId;
        public string Phase => Variant.Phase;
        public string PhaseLabel => Variant.PhaseLabel;
        public long Quantity => Variant.Quantity;
        public decimal LastPrice => Variant.LastPrice;
        public decimal LineValue => Variant.LineValue;
        public int PriceRank => Variant.PriceRank;
        public int CatalogSize => Variant.CatalogSize;
    }

    private IReadOnlyList<PoolElementGroupDto> GetGroups()
    {
        if (_overview == null)
            return Array.Empty<PoolElementGroupDto>();
        if (_overview.Groups.Count > 0)
            return _overview.Groups.Where(g => g.TotalQuantity > 0).ToList();
        return _overview.Stacks
            .Where(s => s.Quantity > 0)
            .GroupBy(s => s.ElementId)
            .Select(g =>
            {
                var first = g.First();
                return new PoolElementGroupDto(
                    g.Key,
                    first.Symbol,
                    first.DisplayName,
                    g.Sum(x => x.Quantity),
                    g.Select(s => new PoolVariantStackDto(
                        s.ElementId, s.Symbol, s.Dna, s.Phase, s.PhaseLabel,
                        s.Quantity, s.VolumePerUnit, s.LastPrice, s.LineValue,
                        s.PriceRank, s.CatalogSize, s.ChangePercent24h)).ToList());
            })
            .ToList();
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            if (string.IsNullOrEmpty(Tokens.BearerToken))
            {
                _overview = null;
                return;
            }

            await EnsureElementsAsync();
            var res = await Http.GetAsync("/v1/me/pool/view");
            if (!res.IsSuccessStatusCode)
            {
                _error = res.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Kunde inte läsa pool (är du inloggad?)"
                    : "Kunde inte läsa pool.";
                _overview = null;
                return;
            }

            _overview = await res.Content.ReadFromJsonAsync<PoolOverviewDto>();
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
            _overview = null;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EnsureElementsAsync()
    {
        if (_elements.Count > 0)
            return;

        var items = await Http.GetFromJsonAsync<List<ElementContentItem>>("/v1/content/elements?locale=sv");
        _elements = items ?? [];
    }

    private void OpenAnalysisAsync(int elementId)
    {
        _analysisElement = _elements.FirstOrDefault(e => e.Id == elementId);
        _analysisVisible = _analysisElement != null;
    }

    private Task CloseAnalysisAsync()
    {
        _analysisVisible = false;
        return Task.CompletedTask;
    }
}
