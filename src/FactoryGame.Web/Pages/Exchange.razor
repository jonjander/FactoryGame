@page "/exchange"
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using FactoryGame.Contracts.Market
@using FactoryGame.Contracts.Json
@inject HttpClient Http
@inject TokenStore Tokens
@inject WalletState Wallet
@inject SnackbarService Snackbar
@implements IDisposable

<PageTitle>Börs</PageTitle>

<div class="exchange-header panel">
    <h2>Börs</h2>
    <p class="muted">Handla grundämnen i din pool. Marknaden fylls på automatiskt när det saknas motpart.</p>
  <div class="exchange-header-actions">
        <button type="button" class="secondary" @onclick="() => RefreshAsync()" disabled="@(_busy || _placing)">Uppdatera</button>
        @if (Wallet.Cash is { } cash)
        {
            <span class="muted exchange-wallet-hint">Kassa: <strong>@cash.ToString("0.##")</strong></span>
        }
    </div>
    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="error">@_error</p>
    }
</div>

@if (!string.IsNullOrEmpty(Tokens.BearerToken) && _sellInsights.Count > 0)
{
    <div class="panel exchange-insights">
        <h3>Säljmöjligheter — företag som betalar bra</h3>
        <p class="muted">Baserat på öppna köpordrar från sponsrade företag som matchar ditt poolinnehav.</p>
        <ul class="exchange-insights-list">
            @foreach (var insight in _sellInsights.Take(5))
            {
                <li>
                    <strong>@insight.CompanyName</strong> köper
                    <span class="fg-element-badge">@insight.Symbol</span> @insight.PhaseLabel
                    @@ <strong>@insight.LimitPrice.ToString("0.##")</strong>
                    (volym @insight.OpenQuantity)
                    <button type="button" class="secondary" @onclick="() => ApplySellInsightAsync(insight)">Sälj nu</button>
                </li>
            }
        </ul>
    </div>
}

@if (string.IsNullOrEmpty(Tokens.BearerToken))
{
    <div class="panel">
        <p class="muted">Du måste <a href="/">logga in som gäst</a> för att lägga order.</p>
    </div>
}
else if (_summary.Count == 0 && !_busy)
{
    <div class="panel">
        <p class="muted">Inga material i poolen att handla. Öppna sidan igen efter inloggning om du nyss skapade konto — startpaket läggs i poolen automatiskt.</p>
    </div>
}
else if (_summary.Count > 0)
{
    <div class="panel exchange-holdings">
        <h3>Ditt innehav (pool)</h3>
        <p class="muted exchange-holdings-intro">Det här äger du just nu och kan sälja. Efter köp ökar antalet här.</p>
        <table class="exchange-holdings-table">
            <thead><tr><th>Ämne</th><th>Variant</th><th>I pool</th><th>Senaste</th><th>Bästa köp / sälj</th></tr></thead>
            <tbody>
                @foreach (var item in _summary.OrderBy(s => s.DisplayName).ThenBy(s => s.Phase, StringComparer.Ordinal))
                {
                    <tr class="@(IsSelected(item) ? "selected" : "")" @onclick="() => SelectVariantAsync(item)">
                        <td><span class="fg-element-badge">@item.Symbol</span> @item.DisplayName</td>
                        <td><span class="fg-phase-badge fg-phase-@item.Phase.ToLowerInvariant()">@item.PhaseLabel</span></td>
                        <td><strong>@item.PoolQuantity</strong> st</td>
                        <td>@item.LastPrice.ToString("0.##")</td>
                        <td class="muted">@FormatBidAsk(item)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="exchange-layout">
        <aside class="panel exchange-list">
            <h3>Handla</h3>
            <ul class="exchange-elements">
                @foreach (var item in _summary.OrderBy(s => s.DisplayName).ThenBy(s => s.Phase, StringComparer.Ordinal))
                {
                    <li class="@(IsSelected(item) ? "selected" : "")">
                        <button type="button" class="exchange-element-btn" @onclick="() => SelectVariantAsync(item)">
                            <span class="exchange-element-name">@item.Symbol — @item.PhaseLabel</span>
                            <span class="exchange-element-meta">
                                <span>@item.LastPrice.ToString("0.##")</span>
                                @if (item.ChangePercent24h is { } ch)
                                {
                                    <span class="@(ch >= 0 ? "price-up" : "price-down")">
                                        @(ch >= 0 ? "+" : "")@ch.ToString("0.##")%
                                    </span>
                                }
                            </span>
                            <span class="muted exchange-element-qty">@item.PoolQuantity st i pool · @item.DisplayName</span>
                        </button>
                    </li>
                }
            </ul>
        </aside>

        <section class="panel exchange-main">
            @if (_selected is not null)
            {
                <div class="exchange-ticker">
                    <div>
                        <h3>@_selected.Symbol — @_selected.PhaseLabel</h3>
                        <p class="exchange-owned">@_selected.DisplayName · <strong>@_selected.PoolQuantity st</strong> i poolen</p>
                    </div>
                    <span class="exchange-last">@_selected.LastPrice.ToString("0.##")</span>
                    @if (_selected.ChangePercent24h is { } pct)
                    {
                        <span class="@(pct >= 0 ? "price-up" : "price-down")">@(pct >= 0 ? "+" : "")@pct.ToString("0.##")%</span>
                    }
                    <div class="exchange-market-prices muted">
                        <span>Bästa köpare (bid): <strong>@(_selected.BestBid?.ToString("0.##") ?? "—")</strong></span>
                        <span>Bästa säljare (ask): <strong class="price-ask">@(_selected.BestAsk?.ToString("0.##") ?? "—")</strong></span>
                    </div>
                </div>

                <div class="exchange-chart-wrap">
                    @if (_history.Count >= 2)
                    {
                        <svg class="exchange-chart" viewBox="0 0 @ChartWidth @ChartHeight" preserveAspectRatio="none">
                            <polyline class="exchange-chart-line" points="@ChartPoints" />
                        </svg>
                    }
                    else
                    {
                        <p class="muted">Kurshistorik laddas…</p>
                    }
                </div>

                <div class="exchange-depth-grid">
                    <div>
                        <h4>Köp (bid)</h4>
                        <table class="exchange-depth-table">
                            <thead><tr><th>Pris</th><th>Volym</th></tr></thead>
                            <tbody>
                                @foreach (var row in _depthLevels.Where(l => l.BidQuantity > 0).OrderByDescending(l => l.Price))
                                {
                                    <tr class="depth-bid" @onclick="() => PickPrice(row.Price)">
                                        <td>@row.Price.ToString("0.##")</td>
                                        <td>@row.BidQuantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div>
                        <h4>Sälj (ask)</h4>
                        <table class="exchange-depth-table">
                            <thead><tr><th>Pris</th><th>Volym</th></tr></thead>
                            <tbody>
                                @foreach (var row in _depthLevels.Where(l => l.AskQuantity > 0).OrderBy(l => l.Price))
                                {
                                    <tr class="depth-ask" @onclick="() => PickPrice(row.Price)">
                                        <td>@row.Price.ToString("0.##")</td>
                                        <td>@row.AskQuantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="exchange-order panel-inner">
                    <h4>Lägg order</h4>
                    <p class="muted exchange-order-hint">@OrderHintText</p>
                    <p class="exchange-match-preview">@MatchPreviewText</p>

                    <div class="exchange-quick-prices">
                        @if (_selected.BestAsk is { } marketAsk)
                        {
                            <button type="button" class="secondary" disabled="@_placing" @onclick="() => SetBuyAtAsk(marketAsk)">Köp till ask (@marketAsk.ToString("0.##"))</button>
                            <button type="button" class="secondary" disabled="@_placing" @onclick="() => SetBuyAboveAsk(marketAsk)">Ask +0,01</button>
                        }
                        @if (_selected.BestBid is { } marketBid)
                        {
                            <button type="button" class="secondary" disabled="@_placing" @onclick="() => SetSellAtBid(marketBid)">Sälj till bid (@marketBid.ToString("0.##"))</button>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(_orderFeedback))
                    {
                        <div class="exchange-feedback @(_orderFeedbackKind switch { "ok" => "exchange-feedback-ok", "warn" => "exchange-feedback-warn", _ => "exchange-feedback-error" })">
                            @_orderFeedback
                        </div>
                    }

                    <form class="exchange-order-fields" @onsubmit="PlaceAsync" @onsubmit:preventDefault="true">
                        <div>
                            <label for="ex-side">Sida</label>
                            <select id="ex-side" @bind="_side" @bind:after="OnSideChanged">
                                <option value="buy">Köp</option>
                                <option value="sell">Sälj</option>
                            </select>
                        </div>
                        <div>
                            <label for="ex-price">Limitpris</label>
                            <input id="ex-price" type="number" step="0.01" min="0.01"
                                   @bind="_price" @bind:culture="CultureInfo.InvariantCulture" @bind:event="oninput" />
                        </div>
                        <div>
                            <label for="ex-qty">Kvantitet</label>
                            <input id="ex-qty" type="number" step="1" min="1"
                                   @bind="_qty" @bind:culture="CultureInfo.InvariantCulture" @bind:event="oninput" />
                        </div>
                        <div class="exchange-order-submit">
                            <button type="submit" disabled="@(_busy || _placing || !CanSubmit)">
                                @(_placing ? "Skickar order…" : "Skicka order")
                            </button>
                        </div>
                    </form>

                    @if (!string.IsNullOrEmpty(_orderDetails))
                    {
                        <p class="muted exchange-order-details">@_orderDetails</p>
                    }
                </div>

                <div class="exchange-open-orders">
                    <h4>Dina öppna order</h4>
                    @if (_myOpenOrders.Count == 0)
                    {
                        <p class="muted">Inga öppna order för detta ämne.</p>
                    }
                    else
                    {
                        <ul class="exchange-open-order-list">
                            @foreach (var o in _myOpenOrders)
                            {
                                var isBuy = o.Side.Equals("Buy", StringComparison.OrdinalIgnoreCase);
                                var status = DescribeOpenOrderStatus(o, isBuy);
                                var isEditing = _editingOrderId == o.Id;
                                var isActing = _actingOrderId == o.Id;
                                <li class="exchange-open-order-card @status.CssClass">
                                    <div class="exchange-open-order-head">
                                        <span class="exchange-open-order-badge @status.BadgeClass">@status.Badge</span>
                                        <span class="exchange-open-order-side">@(isBuy ? "Köp" : "Sälj")</span>
                                        <span class="exchange-open-order-qty">
                                            <strong>@o.QuantityRemaining</strong> kvar av @o.OriginalQuantity st
                                        </span>
                                    </div>
                                    <div class="exchange-open-order-limit">
                                        Limitpris: <strong>@o.LimitPrice.ToString("0.##")</strong>
                                        @if (o.QuantityRemaining < o.OriginalQuantity)
                                        {
                                            <span class="muted"> · delvis fylld</span>
                                        }
                                    </div>
                                    <p class="exchange-open-order-status">@status.Message</p>
                                    @if (status.Suggestion is { } suggestion)
                                    {
                                        <p class="exchange-open-order-suggestion">@suggestion</p>
                                    }
                                    <div class="exchange-open-order-actions">
                                        @if (isBuy && _selected?.BestAsk is { } askForOrder)
                                        {
                                            <button type="button" class="secondary" disabled="@(_busy || _placing || isActing)"
                                                    @onclick="() => AmendToAskAsync(o, askForOrder)">
                                                Höj till ask (@askForOrder.ToString("0.##"))
                                            </button>
                                        }
                                        @if (!isEditing)
                                        {
                                            <button type="button" class="secondary" disabled="@(_busy || _placing || isActing)"
                                                    @onclick="() => StartEditPrice(o)">
                                                Ändra pris
                                            </button>
                                        }
                                        <button type="button" class="danger-outline" disabled="@(_busy || _placing || isActing)"
                                                @onclick="() => CancelOrderAsync(o)">
                                            @(isActing ? "Avbryter…" : "Avbryt order")
                                        </button>
                                    </div>
                                    @if (isEditing)
                                    {
                                        <form class="exchange-open-order-edit" @onsubmit="() => SubmitAmendAsync(o)" @onsubmit:preventDefault="true">
                                            <label for="@($"edit-price-{o.Id}")">Nytt limitpris</label>
                                            <div class="exchange-open-order-edit-row">
                                                <input id="@($"edit-price-{o.Id}")" type="number" step="0.01" min="0.01"
                                                       @bind="_editingPrice" @bind:culture="CultureInfo.InvariantCulture" />
                                                <button type="submit" disabled="@(_busy || _placing || isActing || _editingPrice <= 0)">
                                                    Spara
                                                </button>
                                                <button type="button" class="secondary" disabled="@isActing" @onclick="CancelEditPrice">Avbryt</button>
                                            </div>
                                        </form>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="exchange-trades">
                    <h4>Senaste avslut (spelare)</h4>
                    <p class="muted exchange-trades-hint">Riktiga handel — syntetisk kurshistorik visas inte här.</p>
                    <table class="exchange-trades-table">
                        <thead><tr><th>Tid</th><th>Pris</th><th>Volym</th><th>Motpart</th></tr></thead>
                        <tbody>
                            @if (_lastFill is { } fill)
                            {
                                <tr class="trade-just-filled">
                                    <td>Nyss</td>
                                    <td>@fill.Price.ToString("0.##")</td>
                                    <td>@fill.Quantity</td>
                                    <td>@(_lastFillCounterparty ?? "—")</td>
                                </tr>
                            }
                            @if (_trades.Count == 0 && _lastFill is null)
                            {
                                <tr><td colspan="4" class="muted">Inga spelaravslut ännu för detta ämne.</td></tr>
                            }
                            @foreach (var t in _trades)
                            {
                                <tr>
                                    <td>@t.CreatedAt.LocalDateTime.ToString("HH:mm:ss")</td>
                                    <td>@t.Price.ToString("0.##")</td>
                                    <td>@t.Quantity</td>
                                    <td>@FormatTradeCounterparty(t)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
}

@code {
    private static readonly CultureInfo Invariant = CultureInfo.InvariantCulture;
    private static readonly JsonSerializerOptions JsonOpts = FactoryGameJson.Api;

    private const int ChartWidth = 320;
    private const int ChartHeight = 80;

    private bool _busy;
    private bool _placing;
    private string? _error;
    private readonly List<MarketElementSummaryDto> _summary = new();
    private readonly List<MarketDepthLevelDto> _depthLevels = new();
    private readonly List<MarketCandleDto> _history = new();
    private readonly List<MarketTradeDto> _trades = new();
    private readonly List<MyOpenOrderDto> _myOpenOrders = new();
    private MarketTradeDto? _lastFill;
    private string? _lastFillCounterparty;
    private readonly List<MarketInsightDto> _sellInsights = new();
    private int _selectedId;
    private long _selectedDna;
    private MarketElementSummaryDto? _selected;
    private string _side = "buy";
    private decimal _price = 10m;
    private long _qty = 1;
    private string _orderFeedback = "";
    private string _orderFeedbackKind = "";
    private string _orderDetails = "";
    private Guid? _editingOrderId;
    private Guid? _actingOrderId;
    private decimal _editingPrice;
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource? _pollCts;

    private bool CanSubmit =>
        _selectedId > 0 && _selectedDna != 0 && _price > 0 && _qty > 0 && !_placing && string.IsNullOrEmpty(Tokens.BearerToken) == false;

    private bool IsSelected(MarketElementSummaryDto item) =>
        item.ElementId == _selectedId && item.Dna == _selectedDna;

    private decimal EstimatedCost => _price > 0 && _qty > 0 ? _price * _qty : 0;

    private string OrderHintText =>
        _selected is null ? ""
        : _side == "sell"
            ? $"Säljer från pool — du har {_selected.PoolQuantity} st."
            : Wallet.Cash is { } c
                ? $"Köp reserverar upp till {EstimatedCost:0.##} av kassa ({c:0.##}). Fylls direkt om limit ≥ bästa ask ({_selected.BestAsk?.ToString("0.##") ?? "—"})."
                : $"Köp kostar upp till {EstimatedCost:0.##} (limit × antal).";

    private string MatchPreviewText
    {
        get
        {
            if (_selected is null || _price <= 0 || _qty <= 0) return "";
            var matchable = MatchableQuantityAtLimit();
            if (_side == "buy")
            {
                if (_selected.BestAsk is not { } ask)
                    return "Ingen säljare i boken ännu — order kan ligga öppen tills motpart finns.";
                if (_price < ask)
                    return $"Ditt limit {_price:0.##} är under bästa ask {ask:0.##} — ordern läggs troligen öppen utan avslut.";
                if (matchable >= _qty)
                    return $"Vid detta pris kan upp till {matchable} st fyllas direkt mot säljare i boken.";
                if (matchable > 0)
                    return $"Upp till {matchable} st kan fyllas direkt; resten ({_qty - matchable} st) kan ligga kvar som öppen order.";
                return $"Limit OK mot ask, men volymen i boken räcker inte — delvis eller ingen fyllning.";
            }

            if (_selected.BestBid is not { } bid)
                return "Ingen köpare i boken ännu — order kan ligga öppen.";
            if (_price > bid)
                return $"Ditt limit {_price:0.##} är över bästa bid {bid:0.##} — ordern läggs troligen öppen.";
            if (matchable >= _qty)
                return $"Vid detta pris kan upp till {matchable} st säljas direkt mot köpare.";
            if (matchable > 0)
                return $"Upp till {matchable} st kan fyllas direkt; resten kan ligga öppen.";
            return "Kontrollera orderdjupet — begränsad volym mot ditt pris.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Wallet.RefreshAsync();
        await RefreshAsync();
        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(60));
        _ = PollLoopAsync(_pollCts.Token);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        if (_pollTimer == null) return;
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(ct))
                await InvokeAsync(async () => await RefreshAsync());
        }
        catch (OperationCanceledException) { }
    }

    private async Task RefreshAsync(bool afterOrder = false)
    {
        if (_placing && !afterOrder) return;

        _busy = true;
        _error = null;
        try
        {
            if (string.IsNullOrEmpty(Tokens.BearerToken))
            {
                _summary.Clear();
                return;
            }

            var summaryRes = await Http.GetAsync("/v1/market/summary");
            if (summaryRes.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _error = "Sessionen har gått ut. Logga in igen från startsidan.";
                _summary.Clear();
                return;
            }

            summaryRes.EnsureSuccessStatusCode();
            var items = await summaryRes.Content.ReadFromJsonAsync<List<MarketElementSummaryDto>>(JsonOpts);
            _summary.Clear();
            if (items != null)
                _summary.AddRange(items);

            if (_summary.Count == 0)
                return;

            if (_selectedId == 0 || _selectedDna == 0 || _summary.All(s => !IsSelected(s)))
            {
                _selectedId = _summary[0].ElementId;
                _selectedDna = _summary[0].Dna;
            }

            _selected = _summary.FirstOrDefault(s => IsSelected(s));
            await LoadVariantDetailAsync(_selectedId, _selectedDna);
            await LoadInsightsAsync();
            await Wallet.RefreshAsync();
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SelectVariantAsync(MarketElementSummaryDto item)
    {
        _selectedId = item.ElementId;
        _selectedDna = item.Dna;
        _selected = item;
        _orderFeedback = "";
        _orderDetails = "";
        await LoadVariantDetailAsync(item.ElementId, item.Dna);
    }

    private async Task LoadVariantDetailAsync(int elementId, long dna)
    {
        await LoadDepthAsync(elementId, dna);
        await LoadHistoryAsync(elementId);
        await LoadTradesAsync(elementId, dna);
        await LoadMyOpenOrdersAsync(elementId, dna);
        ApplySuggestedPrice();
    }

    private async Task LoadDepthAsync(int elementId, long dna)
    {
        try
        {
            var depth = await Http.GetFromJsonAsync<MarketDepthDto>(
                $"/v1/market/elements/{elementId}/depth?dna={dna}", JsonOpts);
            _depthLevels.Clear();
            if (depth?.Levels != null)
                _depthLevels.AddRange(depth.Levels);
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
    }

    private async Task LoadHistoryAsync(int elementId)
    {
        try
        {
            var history = await Http.GetFromJsonAsync<List<MarketCandleDto>>(
                $"/v1/market/elements/{elementId}/history?points=48", JsonOpts);
            _history.Clear();
            if (history != null)
                _history.AddRange(history);
        }
        catch
        {
            // Kurshistorik är sekundär — blockera inte övrig vy.
        }
    }

    private async Task LoadInsightsAsync()
    {
        try
        {
            var insights = await Http.GetFromJsonAsync<MarketInsightsResponse>("/v1/market/insights", JsonOpts);
            _sellInsights.Clear();
            if (insights?.SellOpportunities != null)
                _sellInsights.AddRange(insights.SellOpportunities);
        }
        catch
        {
            _sellInsights.Clear();
        }
    }

    private async Task ApplySellInsightAsync(MarketInsightDto insight)
    {
        var item = _summary.FirstOrDefault(s => s.ElementId == insight.ElementId && s.Dna == insight.Dna);
        if (item != null)
            await SelectVariantAsync(item);
        else
        {
            _selectedId = insight.ElementId;
            _selectedDna = insight.Dna;
        }
        _side = "sell";
        _price = insight.LimitPrice;
        _qty = Math.Min(1, insight.OpenQuantity);
        _orderFeedback = $"Förifyllt från {insight.CompanyName}.";
        _orderFeedbackKind = "info";
    }

    private string FormatTradeCounterparty(MarketTradeDto trade)
    {
        if (trade.BuyerLabel == "Du")
            return trade.SellerLabel ?? "—";
        if (trade.SellerLabel == "Du")
            return trade.BuyerLabel ?? "—";
        if (trade.BuyerIsSponsor)
            return trade.BuyerLabel ?? "Företag";
        if (trade.SellerIsSponsor)
            return trade.SellerLabel ?? "Företag";
        return trade.BuyerLabel ?? trade.SellerLabel ?? "—";
    }

    private async Task LoadTradesAsync(int elementId, long dna)
    {
        try
        {
            var trades = await Http.GetFromJsonAsync<List<MarketTradeDto>>(
                $"/v1/market/trades?elementId={elementId}&limit=50", JsonOpts);
            _trades.Clear();
            if (trades != null)
                _trades.AddRange(trades.Where(t => t.Dna == dna));
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
    }

    private void OnSideChanged() => ApplySuggestedPrice();

    private void ApplySuggestedPrice()
    {
        var sel = _summary.FirstOrDefault(s => IsSelected(s));
        if (sel == null) return;

        if (_side.Equals("buy", StringComparison.OrdinalIgnoreCase) && sel.BestAsk is { } ask)
            _price = ask;
        else if (_side.Equals("sell", StringComparison.OrdinalIgnoreCase) && sel.BestBid is { } bid)
            _price = bid;
    }

    private void PickPrice(decimal price)
    {
        _price = price;
        _orderFeedback = "";
    }

    private void SetBuyAtAsk(decimal ask)
    {
        _side = "buy";
        _price = ask;
        _orderFeedback = "";
    }

    private void SetBuyAboveAsk(decimal ask)
    {
        _side = "buy";
        _price = RoundPrice(ask + 0.01m);
        _orderFeedback = "";
    }

    private void SetSellAtBid(decimal bid)
    {
        _side = "sell";
        _price = bid;
        _orderFeedback = "";
    }

    private static decimal RoundPrice(decimal price) =>
        Math.Round(price, 2, MidpointRounding.AwayFromZero);

    private static string FormatBidAsk(MarketElementSummaryDto item) =>
        $"{item.BestBid?.ToString("0.##") ?? "—"} / {item.BestAsk?.ToString("0.##") ?? "—"}";

    private long MatchableQuantityAtLimit()
    {
        if (_price <= 0) return 0;
        if (_side == "buy")
            return _depthLevels.Where(l => l.AskQuantity > 0 && l.Price <= _price).Sum(l => l.AskQuantity);
        return _depthLevels.Where(l => l.BidQuantity > 0 && l.Price >= _price).Sum(l => l.BidQuantity);
    }

    private async Task LoadMyOpenOrdersAsync(int elementId, long dna)
    {
        try
        {
            var list = await Http.GetFromJsonAsync<List<MyOpenOrderDto>>(
                $"/v1/market/orders/mine?elementId={elementId}", JsonOpts);
            _myOpenOrders.Clear();
            if (list != null)
                _myOpenOrders.AddRange(list.Where(o => o.Dna == dna).OrderByDescending(o => o.CreatedAt));
        }
        catch
        {
            _myOpenOrders.Clear();
        }
    }

    private sealed record OpenOrderStatus(string Badge, string BadgeClass, string Message, string? Suggestion, string CssClass);

    private OpenOrderStatus DescribeOpenOrderStatus(MyOpenOrderDto order, bool isBuy)
    {
        if (_selected is null)
            return new OpenOrderStatus("Öppen", "badge-wait", "Ordern ligger i orderboken.", null, "open-order-wait");

        if (isBuy)
        {
            if (_selected.BestAsk is not { } ask)
                return new OpenOrderStatus(
                    "Väntar",
                    "badge-wait",
                    "Ingen säljare i boken ännu — ordern fylls när någon lägger ut till salu.",
                    "Marknaden fylls på automatiskt med tiden, eller höj ditt limitpris.",
                    "open-order-wait");

            if (order.LimitPrice < ask)
                return new OpenOrderStatus(
                    "För lågt pris",
                    "badge-blocked",
                    $"Ditt limit {order.LimitPrice:0.##} är under bästa ask {ask:0.##} — ingen säljare matchar än.",
                    $"Höj till minst {ask:0.##} för att köpa direkt mot boken.",
                    "open-order-blocked");

            return new OpenOrderStatus(
                "Väntar på volym",
                "badge-wait",
                $"Priset räcker mot ask {ask:0.##}, men det finns inte tillräcklig volym just nu.",
                "Ordern ligger kvar tills en säljare fyller resten.",
                "open-order-wait");
        }

        if (_selected.BestBid is not { } bid)
            return new OpenOrderStatus(
                "Väntar",
                "badge-wait",
                "Ingen köpare i boken ännu.",
                null,
                "open-order-wait");

        if (order.LimitPrice > bid)
            return new OpenOrderStatus(
                "För högt pris",
                "badge-blocked",
                $"Ditt limit {order.LimitPrice:0.##} är över bästa bid {bid:0.##}.",
                $"Sänk till {bid:0.##} eller lägre för snabbare avslut.",
                "open-order-blocked");

        return new OpenOrderStatus(
            "Väntar på volym",
            "badge-wait",
            "Priset matchar köpare men volymen räcker inte.",
            null,
            "open-order-wait");
    }

    private void StartEditPrice(MyOpenOrderDto order)
    {
        _editingOrderId = order.Id;
        _editingPrice = order.LimitPrice;
    }

    private void CancelEditPrice()
    {
        _editingOrderId = null;
    }

    private async Task CancelOrderAsync(MyOpenOrderDto order)
    {
        _actingOrderId = order.Id;
        _orderFeedback = "";
        try
        {
            var res = await Http.PostAsync($"/v1/market/orders/{order.Id}/cancel", null);
            var body = await res.Content.ReadAsStringAsync();
            if (res.IsSuccessStatusCode)
            {
                _orderFeedbackKind = "ok";
                _orderFeedback = "Ordern avbröts.";
                Snackbar.Show("Order avbruten", SnackbarKind.Success);
                _editingOrderId = null;
                await RefreshAfterOrderAsync();
            }
            else
            {
                _orderFeedbackKind = "error";
                _orderFeedback = ParseApiError(body, (int)res.StatusCode);
                Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            }
        }
        catch (Exception ex)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = ApiConnectionErrors.Format(ex);
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
        }
        finally
        {
            _actingOrderId = null;
        }
    }

    private Task SubmitAmendAsync(MyOpenOrderDto order) => AmendOrderAsync(order, _editingPrice);

    private async Task AmendToAskAsync(MyOpenOrderDto order, decimal ask) => await AmendOrderAsync(order, ask);

    private async Task AmendOrderAsync(MyOpenOrderDto order, decimal newPrice)
    {
        if (newPrice <= 0) return;

        _actingOrderId = order.Id;
        _orderFeedback = "";
        try
        {
            var res = await Http.PostAsJsonAsync(
                $"/v1/market/orders/{order.Id}/amend",
                new AmendOrderRequest(newPrice));
            var body = await res.Content.ReadAsStringAsync();
            if (res.IsSuccessStatusCode)
            {
                var result = JsonSerializer.Deserialize<OrderActionResponse>(body, JsonOpts);
                _editingOrderId = null;
                if (result is { QuantityFilled: > 0, QuantityRemaining: 0 })
                {
                    _orderFeedbackKind = "ok";
                    _orderFeedback = $"Order fylld efter prisändring: {result.QuantityFilled} st.";
                    Snackbar.Show("Order fylld", SnackbarKind.Success);
                }
                else if (result is { QuantityFilled: > 0 })
                {
                    _orderFeedbackKind = "warn";
                    _orderFeedback = $"Delvis fylld: {result.QuantityFilled} st. {result.QuantityRemaining} st kvar öppen.";
                    Snackbar.Show("Order delvis fylld", SnackbarKind.Info);
                }
                else
                {
                    _orderFeedbackKind = "warn";
                    _orderFeedback = $"Pris uppdaterat till {newPrice:0.##} — ordern väntar fortfarande på motpart.";
                    Snackbar.Show("Pris uppdaterat", SnackbarKind.Info);
                }
                await RefreshAfterOrderAsync();
            }
            else
            {
                _orderFeedbackKind = "error";
                _orderFeedback = ParseApiError(body, (int)res.StatusCode);
                Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            }
        }
        catch (Exception ex)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = ApiConnectionErrors.Format(ex);
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
        }
        finally
        {
            _actingOrderId = null;
        }
    }

    private string ChartPoints
    {
        get
        {
            if (_history.Count < 2) return "";
            var min = _history.Min(c => c.Close);
            var max = _history.Max(c => c.Close);
            var range = max - min;
            if (range == 0) range = 1;
            var step = (double)(ChartWidth - 4) / (_history.Count - 1);
            var parts = new List<string>();
            for (var i = 0; i < _history.Count; i++)
            {
                var x = 2 + i * step;
                var y = ChartHeight - 2 - (double)((_history[i].Close - min) / range) * (ChartHeight - 4);
                parts.Add($"{x.ToString(Invariant)},{y.ToString(Invariant)}");
            }
            return string.Join(" ", parts);
        }
    }

    private async Task PlaceAsync()
    {
        if (!CanSubmit)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = "Kontrollera pris och kvantitet (måste vara > 0).";
            return;
        }

        if (_side.Equals("sell", StringComparison.OrdinalIgnoreCase) && _selected is { } sel && _qty > sel.PoolQuantity)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = $"Du har bara {sel.PoolQuantity} st i poolen — sänk kvantiteten.";
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            return;
        }

        _placing = true;
        _orderFeedback = "";
        _orderDetails = "";
        _error = null;

        try
        {
            try
            {
                await Http.GetAsync($"/v1/market/elements/{_selectedId}/depth?dna={_selectedDna}");
            }
            catch
            {
                // Försök lägga order ändå — djup kan ha misslyckats utan att matchning är omöjlig.
            }

            var res = await Http.PostAsJsonAsync("/v1/market/orders",
                new PlaceOrderRequest(_selectedId, _selectedDna, _side, _price, _qty, $"web-{Guid.NewGuid():N}"));

            var body = await res.Content.ReadAsStringAsync();

            if (res.IsSuccessStatusCode)
            {
                var order = JsonSerializer.Deserialize<PlaceOrderResponse>(body, JsonOpts);
                if (order != null)
                {
                    ApplyOrderResultFeedback(order);
                }
                else
                {
                    _orderFeedbackKind = "ok";
                    _orderFeedback = "Order skickad till servern.";
                    Snackbar.Show("Order skickad", SnackbarKind.Success);
                }

                try
                {
                    await RefreshAfterOrderAsync();
                }
                catch
                {
                    // Behåll orderbekräftelse även om uppdatering misslyckas.
                }
            }
            else
            {
                _orderFeedbackKind = "error";
                _orderFeedback = ParseApiError(body, (int)res.StatusCode);
                Snackbar.Show(_orderFeedback, SnackbarKind.Error);
            }
        }
        catch (Exception ex)
        {
            _orderFeedbackKind = "error";
            _orderFeedback = ApiConnectionErrors.Format(ex);
            Snackbar.Show(_orderFeedback, SnackbarKind.Error);
        }
        finally
        {
            _placing = false;
        }
    }

    private void ApplyOrderResultFeedback(PlaceOrderResponse order)
    {
        var status = order.Status;
        var filled = order.QuantityFilled;
        var remaining = order.QuantityRemaining;
        var original = order.OriginalQuantity > 0 ? order.OriginalQuantity : _qty;
        var sideLabel = _side == "buy" ? "Köp" : "Sälj";
        var fillPrice = order.AverageFillPrice?.ToString("0.##") ?? _price.ToString("0.##");

        if (status.Equals("Filled", StringComparison.OrdinalIgnoreCase))
        {
            _orderFeedbackKind = "ok";
            _orderFeedback = $"{sideLabel} avslutad: {filled} st till snitt {fillPrice}.";
            Snackbar.Show("Order fylld", SnackbarKind.Success);
            SetLastFill(filled, order.AverageFillPrice ?? _price);
        }
        else if (filled > 0)
        {
            _orderFeedbackKind = "warn";
            _orderFeedback = $"{sideLabel} delvis fylld: {filled} av {original} st (snitt {fillPrice}). {remaining} st ligger kvar öppen.";
            Snackbar.Show("Order delvis fylld", SnackbarKind.Info);
            SetLastFill(filled, order.AverageFillPrice ?? _price);
        }
        else if (status.Equals("Open", StringComparison.OrdinalIgnoreCase))
        {
            _orderFeedbackKind = "warn";
            _orderFeedback = BuildNoFillExplanation(sideLabel, remaining);
            Snackbar.Show("Order öppen — ingen matchning", SnackbarKind.Info);
        }
        else
        {
            _orderFeedbackKind = "warn";
            _orderFeedback = $"{sideLabel} status {status}: {remaining} st kvar.";
            Snackbar.Show("Order registrerad", SnackbarKind.Info);
        }

        _orderDetails = $"Order-id: {order.OrderId:N}";
    }

    private string BuildNoFillExplanation(string sideLabel, long remaining)
    {
        if (_selected is null)
            return $"{sideLabel} ligger öppen ({remaining} st) — ingen motpart matchade ditt limitpris {_price:0.##}.";

        if (_side == "buy")
        {
            var ask = _selected.BestAsk?.ToString("0.##") ?? "—";
            if (_selected.BestAsk is { } best && _price < best)
                return $"{sideLabel} öppen ({remaining} st): limit {_price:0.##} är under bästa ask {best:0.##}. Höj priset eller tryck «Köp till ask».";
            return $"{sideLabel} öppen ({remaining} st): inget avslut mot säljare i boken just nu (bästa ask {ask}). Ordern syns under «Dina öppna order».";
        }

        var bid = _selected.BestBid?.ToString("0.##") ?? "—";
        if (_selected.BestBid is { } bestBid && _price > bestBid)
            return $"{sideLabel} öppen ({remaining} st): limit {_price:0.##} är över bästa bid {bestBid:0.##}. Sänk priset eller «Sälj till bid».";
        return $"{sideLabel} öppen ({remaining} st): ingen köpare matchade (bästa bid {bid}).";
    }

    private void SetLastFill(long quantity, decimal price, string? counterparty = null)
    {
        _lastFill = new MarketTradeDto(
            Guid.Empty, _selectedId, _selectedDna, price, quantity, DateTimeOffset.UtcNow,
            null, counterparty, false, false, null, null);
        _lastFillCounterparty = counterparty;
    }

    private async Task RefreshAfterOrderAsync()
    {
        var savedFeedback = _orderFeedback;
        var savedKind = _orderFeedbackKind;
        var savedDetails = _orderDetails;
        var savedFill = _lastFill;
        var savedFillCounterparty = _lastFillCounterparty;

        await RefreshAsync(afterOrder: true);
        await LoadTradesAsync(_selectedId, _selectedDna);
        await Wallet.RefreshAsync();

        if (savedFill is not null && _trades.FirstOrDefault(t =>
                t.Quantity == savedFill.Quantity
                && t.Price == savedFill.Price
                && (DateTimeOffset.UtcNow - t.CreatedAt).TotalMinutes < 5) is { } matched)
        {
            savedFillCounterparty = FormatTradeCounterparty(matched);
        }

        _orderFeedback = savedFeedback;
        _orderFeedbackKind = savedKind;
        _orderDetails = savedDetails;
        _lastFill = savedFill;
        _lastFillCounterparty = savedFillCounterparty;
        if (_lastFill is { } lf && _trades.Any(t =>
                t.Quantity == lf.Quantity
                && t.Price == lf.Price
                && (DateTimeOffset.UtcNow - t.CreatedAt).TotalMinutes < 5))
            _lastFill = null;
        if (_selected is { } sel)
            _orderDetails += $" · Pool nu: {sel.PoolQuantity} st.";
        if (Wallet.Cash is { } cash)
            _orderDetails += $" · Kassa: {cash:0.##}.";
    }

    private static string ParseApiError(string body, int statusCode)
    {
        if (string.IsNullOrWhiteSpace(body))
            return statusCode switch
            {
                401 => "Ej inloggad — logga in igen.",
                409 => "Ordern kunde inte läggas (t.ex. för lite i pool eller full pool).",
                400 => "Ogiltig order.",
                _ => $"Servern svarade med fel ({statusCode})."
            };

        try
        {
            using var doc = JsonDocument.Parse(body);
            if (doc.RootElement.TryGetProperty("error", out var err))
                return err.GetString() ?? body;
        }
        catch
        {
            // ignore
        }

        return body.Length > 200 ? body[..200] + "…" : body;
    }

