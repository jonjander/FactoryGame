@page "/exchange"
@using FactoryGame.Contracts.Market
@inject HttpClient Http
@implements IDisposable

<PageTitle>Börs</PageTitle>

<div class="exchange-header panel">
    <h2>Börs</h2>
    <p class="muted">Handla grundämnen i din pool. Marknaden fylls på automatiskt när det saknas motpart.</p>
    <button type="button" class="secondary" @onclick="RefreshAsync" disabled="@_busy">Uppdatera</button>
    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="error">@_error</p>
    }
</div>

@if (_summary.Count == 0 && !_busy)
{
    <div class="panel">
        <p class="muted">Inga material i poolen att handla. Köp eller producera grundämnen först.</p>
    </div>
}
else if (_summary.Count > 0)
{
    <div class="exchange-layout">
        <aside class="panel exchange-list">
            <h3>Dina ämnen</h3>
            <ul class="exchange-elements">
                @foreach (var item in _summary)
                {
                    <li class="@(item.ElementId == _selectedId ? "selected" : "")">
                        <button type="button" class="exchange-element-btn" @onclick="() => SelectElementAsync(item.ElementId)">
                            <span class="exchange-element-name">@item.DisplayName</span>
                            <span class="exchange-element-meta">
                                <span>@item.LastPrice.ToString("0.##")</span>
                                @if (item.ChangePercent24h is { } ch)
                                {
                                    <span class="@(ch >= 0 ? "price-up" : "price-down")">
                                        @(ch >= 0 ? "+" : "")@ch.ToString("0.##")%
                                    </span>
                                }
                            </span>
                            <span class="muted exchange-element-qty">@item.PoolQuantity st i pool</span>
                        </button>
                    </li>
                }
            </ul>
        </aside>

        <section class="panel exchange-main">
            @if (_selected is not null)
            {
                <div class="exchange-ticker">
                    <h3>@_selected.DisplayName</h3>
                    <span class="exchange-last">@_selected.LastPrice.ToString("0.##")</span>
                    @if (_selected.ChangePercent24h is { } pct)
                    {
                        <span class="@(pct >= 0 ? "price-up" : "price-down")">@(pct >= 0 ? "+" : "")@pct.ToString("0.##")%</span>
                    }
                    <span class="muted">Bid @_selected.BestBid?.ToString("0.##") · Ask @_selected.BestAsk?.ToString("0.##")</span>
                </div>

                <div class="exchange-chart-wrap">
                    @if (_history.Count >= 2)
                    {
                        <svg class="exchange-chart" viewBox="0 0 @ChartWidth @ChartHeight" preserveAspectRatio="none">
                            <polyline class="exchange-chart-line" points="@ChartPoints" />
                        </svg>
                    }
                    else
                    {
                        <p class="muted">Kurshistorik laddas…</p>
                    }
                </div>

                <div class="exchange-depth-grid">
                    <div>
                        <h4>Köp (bid)</h4>
                        <table class="exchange-depth-table">
                            <thead><tr><th>Pris</th><th>Volym</th></tr></thead>
                            <tbody>
                                @foreach (var row in _depthLevels.Where(l => l.BidQuantity > 0).OrderByDescending(l => l.Price))
                                {
                                    <tr class="depth-bid" @onclick="() => PickPrice(row.Price)">
                                        <td>@row.Price.ToString("0.##")</td>
                                        <td>@row.BidQuantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div>
                        <h4>Sälj (ask)</h4>
                        <table class="exchange-depth-table">
                            <thead><tr><th>Pris</th><th>Volym</th></tr></thead>
                            <tbody>
                                @foreach (var row in _depthLevels.Where(l => l.AskQuantity > 0).OrderBy(l => l.Price))
                                {
                                    <tr class="depth-ask" @onclick="() => PickPrice(row.Price)">
                                        <td>@row.Price.ToString("0.##")</td>
                                        <td>@row.AskQuantity</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="exchange-order panel-inner">
                    <h4>Lägg order</h4>
                    <div class="exchange-order-fields">
                        <label>Sida</label>
                        <select @bind="_side">
                            <option value="buy">Köp</option>
                            <option value="sell">Sälj</option>
                        </select>
                        <label>Limitpris</label>
                        <input type="number" step="0.01" @bind="_price" />
                        <label>Kvantitet</label>
                        <input type="number" @bind="_qty" />
                        <button type="button" @onclick="PlaceAsync" disabled="@_busy">Skicka</button>
                    </div>
                    @if (!string.IsNullOrEmpty(_orderResult))
                    {
                        <pre class="exchange-order-result">@_orderResult</pre>
                    }
                </div>

                <div class="exchange-trades">
                    <h4>Senaste avslut</h4>
                    <table class="exchange-trades-table">
                        <thead><tr><th>Tid</th><th>Pris</th><th>Volym</th></tr></thead>
                        <tbody>
                            @foreach (var t in _trades)
                            {
                                <tr>
                                    <td>@t.CreatedAt.LocalDateTime.ToString("HH:mm")</td>
                                    <td>@t.Price.ToString("0.##")</td>
                                    <td>@t.Quantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
}

@code {
    private const int ChartWidth = 320;
    private const int ChartHeight = 80;

    private bool _busy;
    private string? _error;
    private readonly List<MarketElementSummaryDto> _summary = new();
    private readonly List<MarketDepthLevelDto> _depthLevels = new();
    private readonly List<MarketCandleDto> _history = new();
    private readonly List<MarketTradeDto> _trades = new();
    private int _selectedId;
    private MarketElementSummaryDto? _selected;
    private string _side = "buy";
    private decimal _price = 10m;
    private long _qty = 1;
    private string _orderResult = "";
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(12));
        _ = PollLoopAsync(_pollCts.Token);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        if (_pollTimer == null) return;
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(ct))
                await InvokeAsync(async () => await RefreshAsync());
        }
        catch (OperationCanceledException) { }
    }

    private async Task RefreshAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var summaryRes = await Http.GetAsync("/v1/market/summary");
            if (summaryRes.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _error = "Logga in för att handla.";
                return;
            }

            summaryRes.EnsureSuccessStatusCode();
            var items = await summaryRes.Content.ReadFromJsonAsync<List<MarketElementSummaryDto>>();
            _summary.Clear();
            if (items != null)
                _summary.AddRange(items);

            if (_summary.Count == 0)
                return;

            if (_selectedId == 0 || _summary.All(s => s.ElementId != _selectedId))
                _selectedId = _summary[0].ElementId;

            _selected = _summary.FirstOrDefault(s => s.ElementId == _selectedId);
            await LoadElementDetailAsync(_selectedId);
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SelectElementAsync(int elementId)
    {
        _selectedId = elementId;
        _selected = _summary.FirstOrDefault(s => s.ElementId == elementId);
        await LoadElementDetailAsync(elementId);
    }

    private async Task LoadElementDetailAsync(int elementId)
    {
        try
        {
            var depthTask = Http.GetFromJsonAsync<MarketDepthDto>($"/v1/market/elements/{elementId}/depth");
            var histTask = Http.GetFromJsonAsync<List<MarketCandleDto>>($"/v1/market/elements/{elementId}/history?points=48");
            var tradesTask = Http.GetFromJsonAsync<List<MarketTradeDto>>($"/v1/market/trades?elementId={elementId}&limit=20");
            await Task.WhenAll(depthTask!, histTask!, tradesTask!);

            _depthLevels.Clear();
            if (depthTask?.Result?.Levels != null)
                _depthLevels.AddRange(depthTask.Result.Levels);

            _history.Clear();
            if (histTask?.Result != null)
                _history.AddRange(histTask.Result);

            _trades.Clear();
            if (tradesTask?.Result != null)
                _trades.AddRange(tradesTask.Result);

            var sel = _summary.FirstOrDefault(s => s.ElementId == elementId);
            if (sel?.BestAsk is { } ask && _side == "buy")
                _price = ask;
            else if (sel?.BestBid is { } bid && _side == "sell")
                _price = bid;
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
    }

    private void PickPrice(decimal price) => _price = price;

    private string ChartPoints
    {
        get
        {
            if (_history.Count < 2) return "";
            var min = _history.Min(c => c.Close);
            var max = _history.Max(c => c.Close);
            var range = max - min;
            if (range == 0) range = 1;
            var step = (double)(ChartWidth - 4) / (_history.Count - 1);
            var parts = new List<string>();
            for (var i = 0; i < _history.Count; i++)
            {
                var x = 2 + i * step;
                var y = ChartHeight - 2 - (double)((_history[i].Close - min) / range) * (ChartHeight - 4);
                parts.Add($"{x:F1},{y:F1}");
            }
            return string.Join(" ", parts);
        }
    }

    private async Task PlaceAsync()
    {
        _busy = true;
        _orderResult = "";
        try
        {
            var res = await Http.PostAsJsonAsync("/v1/market/orders",
                new PlaceOrderRequest(_selectedId, _side, _price, _qty, $"web-{Guid.NewGuid():N}"));
            _orderResult = await res.Content.ReadAsStringAsync();
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _orderResult = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
    }
}
