@page "/boards"
@using System.Text.Json
@using FactoryGame.Contracts.Boards
@using FactoryGame.Contracts.Machines
@using FactoryGame.Contracts.Pool
@using FactoryGame.Contracts.Json
@using FactoryGame.Web.Components
@using FactoryGame.Web.Models
@implements IDisposable
@inject HttpClient Http
@inject OfflineCommandQueue Queue
@inject BrowserStorage Storage
@inject WalletState Wallet
@inject SnackbarService Snackbar

<PageTitle>Fabrik</PageTitle>

<ConfirmDialog Visible="_confirmVisible"
               Message="_confirmMessage"
               ConfirmLabel="Ja, byt koppling"
               OnConfirm="OnConfirmDialogYesAsync"
               OnCancel="OnConfirmDialogNoAsync" />

<MachineStoreInfoModal Visible="_storeInfoVisible"
                       Item="_storeInfoItem"
                       OnClose="CloseStoreInfo" />

<div class="panel">
    <h2>Spelplaner</h2>
    <button type="button" class="secondary" @onclick="LoadBoardsAsync" disabled="@_busy">Lista</button>
    <button type="button" @onclick="CreateBoardAsync" disabled="@_busy">Ny plan</button>
    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="error">@_error</p>
    }
    <ul class="fg-board-tiles">
        @foreach (var b in _boards)
        {
            var selected = _selected == b.Id;
            <li class="fg-board-tile @GetBoardTileCss(b) @(selected ? "fg-board-tile-selected" : "")">
                <button type="button"
                        class="fg-board-tile-main"
                        @onclick="async () => await SelectBoardAsync(b.Id)"
                        aria-pressed="@selected">
                    <span class="fg-board-tile-head">
                        <span class="fg-board-tile-status-dot" title="@b.StatusHint"></span>
                        <span class="fg-board-tile-name">@b.Name</span>
                        <span class="fg-status-pill @GetBoardStatusPillCss(b)">@GetBoardStatusLabel(b)</span>
                    </span>
                    <span class="fg-board-tile-meta muted">
                        @b.PlanMachineCount maskin@(b.PlanMachineCount == 1 ? "" : "er")
                        · @b.PlanConnectionCount rör
                        · rev @b.RevisionVersion
                        @if (b.SimulationTick > 0)
                        {
                            <span> · tick @b.SimulationTick</span>
                        }
                    </span>
                    @if (!string.IsNullOrEmpty(b.StatusHint))
                    {
                        <span class="fg-board-tile-hint">@b.StatusHint</span>
                    }
                </button>
            </li>
        }
    </ul>
</div>

<div class="panel fg-store">
    <h2>Maskinbutik & lager</h2>
    <p class="muted">Köp maskiner till ditt lager. Placera dem på en sparad plan med valfritt maskin-id (bokstäver, siffror, <code>_</code>, <code>-</code>). Seaport: köp <strong>Seaport connector</strong> och placera som vanlig maskin.</p>
    @if (_storeItems.Count == 0 && _connectors.Count == 0)
    {
        <p class="muted">Laddar butik…</p>
    }
    else
    {
        <div class="fg-table-wrap">
            <table class="fg-table">
                <thead>
                <tr><th>Maskin</th><th>Pris</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var item in _storeItems)
                {
                    <tr>
                        <td>@item.DisplayName <span class="muted">(@item.Type)</span></td>
                        <td>@item.Price.ToString("0.##")</td>
                        <td>
                            <button type="button" class="secondary" @onclick="() => ShowStoreInfo(item)">Info</button>
                            <button type="button" class="secondary" @onclick="async () => await PurchaseAsync(item.Type)" disabled="@_busy">Köp</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <h3>Ditt maskinlager</h3>
        @if (_inventory.Count == 0)
        {
            <p class="muted">Inga köpta maskiner i lager.</p>
        }
        else
        {
            <ul>
                @foreach (var row in _inventory)
                {
                    <li><span class="fg-id-short" title="@row.Id">@DisplayIds.ShortGuid(row.Id)</span> — @row.MachineType</li>
                }
            </ul>
        }
    }
</div>

@if (_selected != null)
{
    <div class="panel fg-board">
        <div class="fg-board-title-row">
            @if (_renamingBoard)
            {
                <div class="fg-board-rename-row">
                    <label for="fg-board-rename">Namn</label>
                    <input id="fg-board-rename" @bind="_renameDraft" maxlength="120" />
                    <button type="button" @onclick="SaveRenameAsync" disabled="@_busy">Spara namn</button>
                    <button type="button" class="secondary" @onclick="CancelRename" disabled="@_busy">Avbryt</button>
                </div>
            }
            else
            {
                <h3>
                    @GetSelectedBoardName()
                    <span class="fg-id-short muted" title="@_selected.Value.ToString()">@DisplayIds.ShortGuid(_selected.Value)</span>
                </h3>
                <button type="button" class="secondary" @onclick="BeginRename" disabled="@_busy">Byt namn</button>
            }
        </div>

        <div class="fg-toolbar">
            <button type="button" class="secondary" @onclick="ReloadPlanUiAsync" disabled="@_busy">Läs om plan från server</button>
            <button type="button" class="secondary" @onclick="RefreshBoardInfoAsync" disabled="@_busy">Uppdatera info</button>
        </div>

        @if (_boardInfo != null)
        {
            <div class="fg-board-mode-banner @GetBoardModeCss()">
                @if (IsSelectedBoardRunning())
                {
                    <span class="fg-status-pill fg-status-running">Kör</span>
                    <span class="muted">Redigering låst tills du stoppar</span>
                }
                else
                {
                    <span class="fg-status-pill fg-status-stopped">Stoppad</span>
                    <span class="muted">Redigera plan, spara och starta simulering</span>
                }
            </div>
            <BoardInfoPanel Info="_boardInfo" />
        }

        @if (TryDeserializePlan(out var canvasPlan))
        {
            <div class="panel fg-sub fg-factory-view">
                <h4>Fabrik (visuell)</h4>
                <FactoryCanvas @key="_planJson"
                               Plan="canvasPlan"
                               ReadOnly="@IsSelectedBoardRunning()"
                               IsFactoryRunning="@IsSelectedBoardRunning()"
                               UnitsPerSecond="@GetEstimatedUnitsPerSecond()"
                               MachineMeta="_machineMeta"
                               LatestKeyframe="_latestKeyframe"
                               SeaportPortFlows="@(_boardInfo?.SeaportPorts ?? Array.Empty<SeaportPortFlowDto>())"
                               MachinePortFlows="@(_boardInfo?.MachinePortFlows ?? Array.Empty<MachinePortFlowDto>())"
                               BoardIssues="@(_boardInfo?.Issues ?? Array.Empty<BoardIssueDto>())"
                               SelectedMachineId="@_settingsMachineId"
                               SelectedMachineIdChanged="OnCanvasMachineSelectedAsync"
                               PlanChanged="OnCanvasPlanChangedAsync"
                               ConnectionAdded="OnCanvasConnectionAddedAsync"
                               ConnectionRemoved="OnCanvasConnectionRemovedAsync"
                               MachineRemoved="OnCanvasMachineRemovedAsync"
                               LayoutCommitted="OnCanvasLayoutCommittedAsync" />
            </div>
        }

        @if (GetPlanMachines().Count > 0)
        {
            <div class="panel fg-sub">
                <h4>Maskininställningar</h4>
                <p class="muted">Klicka en maskin i canvas eller välj i listan. Endast fasta steg (dropdown). Spara planen efter ändring.</p>
                <label for="fg-settings-machine-pick">Maskin</label>
                <select id="fg-settings-machine-pick"
                        class="fg-select fg-settings-machine-pick"
                        disabled="@(_busy || IsSelectedBoardRunning())"
                        @bind="_settingsMachineId">
                    <option value="">— Välj —</option>
                    @foreach (var m in GetPlanMachines())
                    {
                        <option value="@m.Id">@m.Id (@m.Type)</option>
                    }
                </select>
            </div>
            <MachineSettingsPanel Machine="@GetSettingsMachine()"
                                  Disabled="@(_busy || IsSelectedBoardRunning())"
                                  Elements="_elements"
                                  OwnedPoolElementIds="_ownedPoolElementIds"
                                  PoolVariants="_ownedPoolVariants"
                                  PlanMachines="@GetPlanMachines()"
                                  PlanConnections="@GetPlanConnections()"
                                  MachineMeta="_machineMeta"
                                  MachineChanged="OnMachineSettingsChangedAsync" />
        }

        <div class="panel fg-sub">
            <h4>Placera från lager</h4>
            <div class="fg-row">
                <div>
                    <label>Lagerpost</label>
                    <select class="fg-select" @bind="_placeStockId" @bind:after="OnPlaceStockChanged">
                        <option value="">— Välj —</option>
                        @foreach (var row in _inventory)
                        {
                            <option value="@row.Id">@row.MachineType (@DisplayIds.ShortGuid(row.Id))</option>
                        }
                    </select>
                </div>
                <div>
                    <label>Nytt maskin-id på planen</label>
                    <input @bind="_placeMachineId" placeholder="t.ex. boiler1" />
                </div>
                <button type="button" @onclick="PlaceFromStockAsync" disabled="@_busy">Placera</button>
            </div>
        </div>

        <div class="panel fg-sub">
            <h4>Koppla rör</h4>
            <p class="muted">Alla portar kan väljas. Om en port redan är kopplad får du bekräfta innan den gamla kopplingen byts ut.</p>
            <div class="fg-pipe-grid">
                <div>
                    <label>Från maskin</label>
                    <select class="fg-select" @bind="_pipeFromId" @bind:after="OnPipeEndpointChanged">
                        <option value="">— Välj —</option>
                        @foreach (var m in GetPlanMachines())
                        {
                            <option value="@m.Id">@m.Id (@m.Type)</option>
                        }
                    </select>
                </div>
                <div>
                    <label>Från utgång</label>
                    <select class="fg-select" @bind="_pipeFromPort" @bind:after="OnPipeEndpointChanged">
                        <option value="">— Välj —</option>
                        @foreach (var p in GetOutputPortChoices(_pipeFromId))
                        {
                            <option value="@p.Name">@p.Label</option>
                        }
                    </select>
                </div>
                <div>
                    <label>Till maskin</label>
                    <select class="fg-select" @bind="_pipeToId" @bind:after="OnPipeEndpointChanged">
                        <option value="">— Välj —</option>
                        @foreach (var m in GetPlanMachines())
                        {
                            <option value="@m.Id">@m.Id (@m.Type)</option>
                        }
                    </select>
                </div>
                <div>
                    <label>Till ingång</label>
                    <select class="fg-select" @bind="_pipeToPort" @bind:after="OnPipeEndpointChanged">
                        <option value="">— Välj —</option>
                        @foreach (var p in GetInputPortChoices(_pipeToId))
                        {
                            <option value="@p.Name">@p.Label</option>
                        }
                    </select>
                </div>
                <div class="fg-pipe-actions">
                    <button type="button" class="secondary" @onclick="AddPipeToPlanAsync" disabled="@_busy">Lägg rör</button>
                </div>
            </div>
            @{
                var planConnections = GetPlanConnections();
            }
            @if (planConnections.Count > 0)
            {
                <ul class="fg-connection-list">
                    @for (var ci = 0; ci < planConnections.Count; ci++)
                    {
                        var conn = planConnections[ci];
                        var connIndex = ci;
                        <li>
                            <span class="fg-connection-label">@conn.FromId.@conn.FromPort → @conn.ToId.@conn.ToPort</span>
                            <button type="button"
                                    class="secondary"
                                    disabled="@(_busy || IsSelectedBoardRunning())"
                                    @onclick="@(async () => await RemoveConnectionAtAsync(connIndex))">
                                Ta bort
                            </button>
                        </li>
                    }
                </ul>
            }
        </div>

        <h4>Plan (JSON)</h4>
        <textarea class="fg-json" rows="14" @bind="_planJson" @bind:event="oninput"></textarea>
        <div class="fg-toolbar fg-sim-controls">
            <button type="button" @onclick="SavePlanAsync" disabled="@(_busy || IsSelectedBoardRunning())">Spara</button>
            <button type="button"
                    class="@(IsSelectedBoardRunning() ? "secondary fg-btn-disabled-visual" : "")"
                    @onclick="StartAsync"
                    disabled="@(_busy || IsSelectedBoardRunning())"
                    title="@(IsSelectedBoardRunning() ? "Fabriken kör redan" : "Starta simulering")">
                Start
            </button>
            <button type="button"
                    class="@(!IsSelectedBoardRunning() ? "secondary fg-btn-disabled-visual" : "")"
                    @onclick="StopAsync"
                    disabled="@(_busy || !IsSelectedBoardRunning())"
                    title="@(!IsSelectedBoardRunning() ? "Fabriken är redan stoppad" : "Stoppa simulering")">
                Stopp
            </button>
            <button type="button" class="secondary" @onclick="SnapshotAsync" disabled="@_busy">Snapshot</button>
        </div>
        @if (!string.IsNullOrEmpty(_saveHint))
        {
            <p class="muted">@_saveHint</p>
        }
        <pre class="fg-snapshot">@_snapshot</pre>
    </div>
}

@code {
    private static readonly JsonSerializerOptions JsonRelaxed = FactoryGameJson.Api;

    private static readonly JsonSerializerOptions PlanJson = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = true
    };

    private bool _busy;
    private string? _error;
    private List<BoardSummaryDto> _boards = new();
    private Guid? _selected;
    private string _planJson = DefaultPlan();
    private string _snapshot = "";
    private string? _saveHint;
    private BoardInfoDto? _boardInfo;
    private BoardKeyframeDto? _latestKeyframe;
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource? _pollCts;
    private bool _confirmVisible;
    private string _confirmMessage = "";
    private TaskCompletionSource<bool>? _confirmTcs;

    private string _pipeFromId = "";
    private string _pipeFromPort = "";
    private string _pipeToId = "";
    private string _pipeToPort = "";
    private string _placeStockId = "";
    private string _placeMachineId = "";
    private List<MachineStoreItemDto> _storeItems = new();
    private List<MachineStoreItemDto> _connectors = new();
    private List<PlayerMachineStockDto> _inventory = new();
    private readonly Dictionary<string, MachineStoreItemDto> _machineMeta = new(StringComparer.OrdinalIgnoreCase);
    private List<ElementContentItem> _elements = [];
    private string _settingsMachineId = "";
    private HashSet<int> _ownedPoolElementIds = [];
    private List<PoolVariantStackDto> _ownedPoolVariants = [];
    private bool _storeInfoVisible;
    private MachineStoreItemDto? _storeInfoItem;
    private bool _renamingBoard;
    private string _renameDraft = "";

    private sealed class MachineStorePayload
    {
        public List<MachineStoreItemDto> Store { get; set; } = new();
        public List<MachineStoreItemDto> Connectors { get; set; } = new();
    }

    private static string DefaultPlan() =>
        """{"machines":[{"id":"mix1","type":"Mixer"}],"connections":[]}""";

    protected override async Task OnInitializedAsync()
    {
        await LoadBoardsAsync();
        await Wallet.RefreshAsync();
        await LoadMachineStoreAsync();
        await LoadInventoryAsync();
        await EnsureElementsAsync();
        await LoadPoolOwnershipAsync();
        StartPollingIfRunning();
    }

    public void Dispose()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
    }

    private bool IsSelectedBoardRunning()
    {
        if (_selected is not { } id)
            return false;
        var b = _boards.FirstOrDefault(x => x.Id == id);
        return b != null && string.Equals(b.Mode, "Running", StringComparison.OrdinalIgnoreCase);
    }

    private void StartPollingIfRunning()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
        _pollCts = null;
        _pollTimer = null;

        if (!IsSelectedBoardRunning() || _selected is not { } boardId)
            return;

        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = PollRunningBoardAsync(boardId, _pollCts.Token);
    }

    private async Task PollRunningBoardAsync(Guid boardId, CancellationToken ct)
    {
        if (_pollTimer == null)
            return;
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(ct))
            {
                await LoadBoardInfoAsync();
                await LoadLatestKeyframeAsync(boardId);
                await LoadPoolOwnershipAsync();
                await LoadBoardsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            /* stopped */
        }
    }

    private async Task LoadLatestKeyframeAsync(Guid boardId)
    {
        try
        {
            _latestKeyframe = await Http.GetFromJsonAsync<BoardKeyframeDto>(
                $"/v1/boards/{boardId}/keyframes/latest", JsonRelaxed);
        }
        catch
        {
            _latestKeyframe = null;
        }
    }

    private async Task OnCanvasPlanChangedAsync(BoardPlanDto plan)
    {
        _planJson = SerializePlan(plan);
        await SyncBoardInfoFromEditorAsync();
    }

    private async Task OnCanvasLayoutCommittedAsync()
    {
        if (IsSelectedBoardRunning())
            return;
        await SavePlanQuietAsync();
    }

    private async Task OnCanvasConnectionAddedAsync((string FromId, string FromPort, string ToId, string ToPort) pipe) =>
        await TryApplyConnectionAsync(pipe.FromId, pipe.FromPort, pipe.ToId, pipe.ToPort);

    private Task OnCanvasConnectionRemovedAsync(int index) => RemoveConnectionAtAsync(index);

    private async Task OnCanvasMachineRemovedAsync(string machineId)
    {
        if (IsSelectedBoardRunning() || string.IsNullOrWhiteSpace(machineId))
            return;
        if (!TryDeserializePlan(out var plan))
            return;

        var machines = plan.Machines.Where(m => !m.Id.Equals(machineId, StringComparison.Ordinal)).ToList();
        if (machines.Count == plan.Machines.Count)
            return;

        var connections = plan.Connections
            .Where(c => c.FromId != machineId && c.ToId != machineId)
            .ToList();
        _planJson = SerializePlan(new BoardPlanDto(machines, connections));
        _settingsMachineId = "";
        _saveHint = $"Maskin {machineId} borttagen (ej sparat).";
        Snackbar.Show($"Maskin {machineId} borttagen — spara planen.", SnackbarKind.Info);
        await SyncBoardInfoFromEditorAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ShowStoreInfo(MachineStoreItemDto item)
    {
        _storeInfoItem = item;
        _storeInfoVisible = true;
    }

    private void CloseStoreInfo()
    {
        _storeInfoVisible = false;
        _storeInfoItem = null;
    }

    private string GetBoardModeCss() =>
        IsSelectedBoardRunning() ? "fg-board-mode-running" : "fg-board-mode-stopped";

    private static string GetBoardTileCss(BoardSummaryDto board) => board.Health switch
    {
        "running" => "fg-board-tile-running",
        "error" => "fg-board-tile-error",
        "warning" => "fg-board-tile-warning",
        _ => "fg-board-tile-stopped"
    };

    private static string GetBoardStatusPillCss(BoardSummaryDto board) => board.Health switch
    {
        "running" => "fg-status-running",
        "error" => "fg-status-error",
        "warning" => "fg-status-warning",
        _ => "fg-status-stopped"
    };

    private static string GetBoardStatusLabel(BoardSummaryDto board) => board.Health switch
    {
        "running" => "Kör",
        "error" => "Fel",
        "warning" => "Varning",
        _ => "Stoppad"
    };

    private string GetSelectedBoardName()
    {
        if (_selected is not { } id)
            return "Plan";
        return _boards.FirstOrDefault(b => b.Id == id)?.Name
               ?? _boardInfo?.Name
               ?? "Plan";
    }

    private void BeginRename()
    {
        _renameDraft = GetSelectedBoardName();
        _renamingBoard = true;
    }

    private void CancelRename()
    {
        _renamingBoard = false;
        _renameDraft = "";
    }

    private async Task SaveRenameAsync()
    {
        if (_selected is not { } boardId)
            return;
        if (string.IsNullOrWhiteSpace(_renameDraft))
        {
            _error = "Ange ett namn.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var res = await Http.PatchAsJsonAsync($"/v1/boards/{boardId}", new RenameBoardRequest(_renameDraft.Trim()));
            if (!res.IsSuccessStatusCode)
            {
                _error = await res.Content.ReadAsStringAsync();
                return;
            }

            _renamingBoard = false;
            _renameDraft = "";
            await LoadBoardsAsync();
            if (_boardInfo != null)
                _boardInfo = _boardInfo with { Name = GetSelectedBoardName() };
            Snackbar.Show("Spelplanens namn uppdaterat.");
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private double GetEstimatedUnitsPerSecond() =>
        _boardInfo?.Throughput.TotalUnitsPerSecond ?? 0;

    private async Task LoadPoolOwnershipAsync()
    {
        try
        {
            var view = await Http.GetFromJsonAsync<PoolOverviewDto>("/v1/me/pool/view", JsonRelaxed);
            _ownedPoolVariants = view?.Groups
                .SelectMany(g => g.Variants)
                .Where(v => v.Quantity > 0)
                .ToList() ?? [];
            if (_ownedPoolVariants.Count == 0 && view?.Stacks is { Count: > 0 } stacks)
            {
                _ownedPoolVariants = stacks
                    .Where(s => s.Quantity > 0)
                    .Select(s => new PoolVariantStackDto(
                        s.ElementId, s.Symbol, s.Dna, s.Phase, s.PhaseLabel,
                        s.Quantity, s.VolumePerUnit, s.LastPrice, s.LineValue,
                        s.PriceRank, s.CatalogSize, s.ChangePercent24h))
                    .ToList();
            }
            _ownedPoolElementIds = _ownedPoolVariants
                .Select(v => v.ElementId)
                .ToHashSet();
        }
        catch
        {
            _ownedPoolElementIds = [];
            _ownedPoolVariants = [];
        }
    }

    private async Task RemoveConnectionAtAsync(int index)
    {
        if (!TryDeserializePlan(out var plan))
            return;
        if (index < 0 || index >= plan.Connections.Count)
            return;

        var connections = plan.Connections.ToList();
        var removed = connections[index];
        connections.RemoveAt(index);
        _planJson = SerializePlan(new BoardPlanDto(plan.Machines, connections));
        _saveHint = "Rör borttaget (ej sparat).";
        _error = null;
        Snackbar.Show(
            $"Rör borttaget: {removed.FromId}.{removed.FromPort} → {removed.ToId}.{removed.ToPort}",
            SnackbarKind.Info);
        await SyncBoardInfoFromEditorAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void RebuildMachineMeta()
    {
        _machineMeta.Clear();
        foreach (var x in _storeItems)
            _machineMeta[x.Type] = x;
        foreach (var x in _connectors)
            _machineMeta[x.Type] = x;
    }

    private async Task LoadMachineStoreAsync()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<MachineStorePayload>("/v1/content/machine-store", JsonRelaxed);
            _storeItems = res?.Store ?? new List<MachineStoreItemDto>();
            _connectors = res?.Connectors ?? new List<MachineStoreItemDto>();
            RebuildMachineMeta();
        }
        catch
        {
            /* tyst: butiken är valfri för listning */
        }
    }

    private async Task LoadInventoryAsync()
    {
        try
        {
            var rows = await Http.GetFromJsonAsync<List<PlayerMachineStockDto>>("/v1/me/machine-inventory", JsonRelaxed);
            _inventory = rows ?? new List<PlayerMachineStockDto>();
        }
        catch
        {
            _inventory = new List<PlayerMachineStockDto>();
        }
    }

    private async Task PurchaseAsync(string machineType)
    {
        _busy = true;
        _error = null;
        try
        {
            var res = await Http.PostAsJsonAsync("/v1/me/machine-inventory/purchase", new PurchaseMachineRequest(machineType));
            if (!res.IsSuccessStatusCode)
                _error = await res.Content.ReadAsStringAsync();
            else
            {
                await Wallet.RefreshAsync();
                await LoadInventoryAsync();
                var label = _machineMeta.TryGetValue(machineType, out var meta)
                    ? meta.DisplayName
                    : machineType;
                Snackbar.Show($"Köpte {label}.");
            }
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PlaceFromStockAsync()
    {
        if (_selected is not { } boardId)
        {
            _error = "Välj en spelplan först.";
            return;
        }

        if (!Guid.TryParse(_placeStockId, out var stockId) || stockId == Guid.Empty)
        {
            _error = "Välj en lagerpost.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_placeMachineId))
        {
            _error = "Ange maskin-id.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var res = await Http.PostAsJsonAsync($"/v1/boards/{boardId}/place-from-stock",
                new PlaceMachineFromStockRequest(stockId, _placeMachineId.Trim()));
