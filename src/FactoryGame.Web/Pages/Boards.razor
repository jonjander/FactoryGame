    private async Task SavePlanCoreAsync(Guid boardId, BoardPlanDto plan, bool showConflictHint)
    {
        var normalized = PlanMachineLayout.NormalizeLayout(plan);
        _planJson = SerializePlan(normalized);
        var body = new SavePlanRequest(normalized);

        if (await Storage.IsOnlineAsync())
        {
            var res = await Http.PutAsJsonAsync($"/v1/boards/{boardId}/plan", body);
            if (res.StatusCode == System.Net.HttpStatusCode.Conflict && showConflictHint)
            {
                _saveHint = "Konflikt med servern (409). Öppna CLI och använd merge-flöde: jämför revision manuellt eller välj att skriva över via ny sparning.";
            }
            else if (!res.IsSuccessStatusCode)
            {
                _error = await res.Content.ReadAsStringAsync();
            }
            else
            {
                _saveHint = showConflictHint ? "Sparat på servern." : "Layout sparad.";
                await LoadBoardInfoAsync();
            }
        }
        else
        {
            await Queue.EnqueueAsync("PUT", $"/v1/boards/{boardId}/plan", body);
            _saveHint = showConflictHint
                ? "Offline: sparning köad. Synka under CLI när du är online."
                : "Layout köad (offline).";
        }
    }

