@page "/wiki"
@inject HttpClient Http

<PageTitle>Wiki</PageTitle>

<div class="panel">
    <h2>Wiki (genererad)</h2>
    <button type="button" class="secondary" @onclick="LoadAsync" disabled="@_busy">Hämta</button>
    @if (!string.IsNullOrEmpty(_error))
    {
        <p class="error">@_error</p>
    }
    <pre style="white-space:pre-wrap;font-size:0.85rem;margin-top:0.75rem;">@_json</pre>
</div>

@code {
    private bool _busy;
    private string? _error;
    private string _json = "";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var res = await Http.GetAsync("/v1/content/wiki");
            _json = await res.Content.ReadAsStringAsync();
            if (!res.IsSuccessStatusCode)
                _error = _json;
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }
}
