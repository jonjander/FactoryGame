@page "/wiki"
@using System.Net.Http.Json
@using FactoryGame.Web.Models
@using FactoryGame.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Wiki</PageTitle>

<div class="wiki-page">
    <header class="panel wiki-hero">
        <div class="wiki-hero-top">
            <div>
                <h2 class="wiki-title">Spelwiki</h2>
                <p class="muted wiki-subtitle">100&nbsp;% genererad från samma regeldata som servern — maskiner, DNA och grundämnen i realtid.</p>
            </div>
            <button type="button" class="secondary wiki-refresh" @onclick="LoadAsync" disabled="@_busy">
                @(_busy ? "Hämtar…" : "Uppdatera")
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="error">@_error</p>
        }
        else if (_wiki is not null)
        {
            <div class="wiki-meta">
                <span>@_wiki.Machines.Count maskiner</span>
                <span aria-hidden="true">·</span>
                <span>@_wiki.Elements.Count grundämnen</span>
                <span aria-hidden="true">·</span>
                <span>namn v@_wiki.NameGeneratorVersion</span>
            </div>
            <p class="wiki-daily-tip">💡 @WikiPresentation.DailyTip(_wiki.Machines)</p>
        }

        <div class="wiki-search-row">
            <input type="search"
                   class="wiki-search"
                   placeholder="Sök maskin, symbol, namn, fas… (prova ”aska” eller ”dna”)"
                   @bind="_search"
                   @bind:event="oninput"
                   aria-label="Sök i wiki" />
            @if (!string.IsNullOrWhiteSpace(_search))
            {
                <button type="button" class="secondary wiki-search-clear" @onclick="ClearSearch">Rensa</button>
            }
        </div>

        <nav class="wiki-tabs" aria-label="Wiki-sektioner">
            @foreach (var tab in Tabs)
            {
                <button type="button"
                        class="wiki-tab @(_activeTab == tab.Id ? "wiki-tab-active" : "")"
                        @onclick="() => SelectTab(tab.Id)">
                    @tab.Label
                </button>
            }
        </nav>
    </header>

    @if (_showFallbackCard)
    {
        <section class="panel wiki-fallback-card">
            <h3>🧹 Fallback-material</h3>
            <p>När en maskin inte får rätt input (fel fas, blockerande egenskaper, trasiga regler) blir output <strong>aska</strong> eller <strong>goo</strong> — värdelöst skräp som syns tydligt i loggar och fabrikinformation.</p>
            <p class="muted">Tips: läs maskinens krav här i wiki innan du kopplar rör — eller kolla varför en maskin är röd/blockerad på fabriksplanen.</p>
        </section>
    }

    @if (_showDnaExplainerFlag)
    {
        <section class="panel wiki-dna-explainer">
            <h3>🧬 DNA — spelets kemiska fingeravtryck</h3>
            <p>Varje grundämne har ett 64-bitars DNA som kodar fas, explosivitet, kok/fryspunkt och familj. Maskiner läser och skriver i band — deterministiskt, inga magiska undantag per ämne.</p>
            <div class="wiki-dna-legend">
                <span class="wiki-legend-chip wiki-dna-bar-phase">Fas</span>
                <span class="wiki-legend-chip wiki-dna-bar-explosive">Explosiv</span>
                <span class="wiki-legend-chip wiki-dna-bar-fire">Brand</span>
                <span class="wiki-legend-chip wiki-dna-bar-toxic">Toxisk</span>
                <span class="wiki-legend-chip wiki-dna-bar-boil">Kok</span>
                <span class="wiki-legend-chip wiki-dna-bar-freeze">Frys</span>
            </div>
        </section>
    }

    @if (_wiki is null && !_busy && string.IsNullOrEmpty(_error))
    {
        <div class="panel"><p class="muted">Laddar wiki…</p></div>
    }
    else if (_wiki is not null)
    {
        <div class="wiki-layout">
            <aside class="wiki-sidebar panel">
                @if (_activeTab == "overview")
                {
                    <h3 class="wiki-sidebar-title">Snabblänkar</h3>
                    <ul class="wiki-quick-links">
                        <li><button type="button" class="wiki-link-btn" @onclick='() => SelectTab("machines")'>⚙️ Alla maskiner</button></li>
                        <li><button type="button" class="wiki-link-btn" @onclick='() => SelectTab("elements")'>🧪 Grundämnen</button></li>
                        <li><button type="button" class="wiki-link-btn" @onclick="ShowDnaExplainer">🧬 Vad är DNA?</button></li>
                        <li><a href="/boards">🏭 Till fabriken</a></li>
                        <li><a href="/pool">🚢 Seaport-pool</a></li>
                        <li><a href="/exchange">📈 Börsen</a></li>
                    </ul>

                    @if (_phaseStats.Count > 0)
                    {
                        <h4 class="wiki-sidebar-subtitle">Fasfördelning</h4>
                        <div class="wiki-phase-bars">
                            @foreach (var stat in _phaseStats)
                            {
                                <div class="wiki-phase-bar-row">
                                    <span class="@WikiPresentation.PhaseCssClass(stat.Phase)">@WikiPresentation.PhaseLabelSv(stat.Phase)</span>
                                    <div class="wiki-phase-bar-track">
                                        <div class="wiki-phase-bar-fill wiki-phase-fill-@stat.Phase.ToLowerInvariant()"
                                             style="width: @(stat.Percent)%"></div>
                                    </div>
                                    <span class="muted">@stat.Count</span>
                                </div>
                            }
                        </div>
                    }
                }
                else if (_activeTab == "machines")
                {
                    <h3 class="wiki-sidebar-title">Filter</h3>
                    <div class="wiki-filter-chips">
                        <button type="button" class="wiki-chip @(_machineCategory == "" ? "wiki-chip-active" : "")" @onclick='() => _machineCategory = ""'>Alla</button>
                        @foreach (var cat in MachineCategories)
                        {
                            <button type="button"
                                    class="wiki-chip @(_machineCategory == cat ? "wiki-chip-active" : "")"
                                    @onclick="() => _machineCategory = cat">
                                @WikiPresentation.MachineCategoryLabel(cat)
                            </button>
                        }
                    </div>
                    <p class="muted wiki-sidebar-hint">@FilteredMachines.Count() träffar</p>
                    <ul class="wiki-sidebar-list">
                        @foreach (var m in FilteredMachines)
                        {
                            <li class="@(_selectedMachine?.Type == m.Type ? "selected" : "")">
                                <button type="button" class="wiki-sidebar-item" @onclick="() => SelectMachine(m)">
                                    <span class="wiki-sidebar-emoji">@WikiPresentation.MachineEmoji(m.Type)</span>
                                    <span>@WikiPresentation.MachineDisplayName(m.Type)</span>
                                </button>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <h3 class="wiki-sidebar-title">Grundämnen</h3>
                    <div class="wiki-filter-chips">
                        <button type="button" class="wiki-chip @(_elementPhaseFilter == "" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = ""'>Alla faser</button>
                        <button type="button" class="wiki-chip @(_elementPhaseFilter == "Gas" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = "Gas"'>Gas</button>
                        <button type="button" class="wiki-chip @(_elementPhaseFilter == "Liquid" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = "Liquid"'>Vätska</button>
                        <button type="button" class="wiki-chip @(_elementPhaseFilter == "Solid" ? "wiki-chip-active" : "")" @onclick='() => _elementPhaseFilter = "Solid"'>Fast</button>
                    </div>
                    <p class="muted wiki-sidebar-hint">@FilteredElements.Count() träffar</p>
                    <ul class="wiki-sidebar-list wiki-sidebar-list-elements">
                        @foreach (var item in FilteredElements.Take(120))
                        {
                            var el = GetElementDetail(item.Id);
                            <li class="@(_selectedElementId == item.Id ? "selected" : "")">
                                <button type="button" class="wiki-sidebar-item" @onclick="() => SelectElement(item.Id)">
                                    <span class="fg-element-badge">@item.Symbol</span>
                                    <span class="wiki-sidebar-item-name">@item.DisplayName</span>
                                    @if (el is not null)
                                    {
                                        <span class="fg-phase-badge @WikiPresentation.PhaseCssClass(el.Decoded.Phase) wiki-sidebar-phase">
                                            @WikiPresentation.PhaseLabelSv(el.Decoded.Phase)
                                        </span>
                                    }
                                </button>
                            </li>
                        }
                    </ul>
                }
            </aside>

            <main class="wiki-main">
                @if (_activeTab == "overview")
                {
                    <section class="panel wiki-overview">
                        <h3>Välkommen till fabrikens uppslagsverk</h3>
                        <p>Här växer allt från samma regler som simuleringen kör. Välj en maskin eller ett grundämne till vänster — eller hoppa direkt till det du bygger med.</p>

                        <div class="wiki-feature-grid">
                            <button type="button" class="wiki-feature-card wiki-feature-heat" @onclick='() => { _machineCategory = "heat"; SelectTab("machines"); }'>
                                <span class="wiki-feature-icon">🔥</span>
                                <strong>Värme & smältning</strong>
                                <span class="muted">Panna, värmare, kylare, smältugn</span>
                            </button>
                            <button type="button" class="wiki-feature-card wiki-feature-sep" @onclick='() => { _machineCategory = "separation"; SelectTab("machines"); }'>
                                <span class="wiki-feature-icon">⚗️</span>
                                <strong>Separation</strong>
                                <span class="muted">Blandare, destillator, sorterare</span>
                            </button>
                            <button type="button" class="wiki-feature-card wiki-feature-logistics" @onclick='() => { _machineCategory = "logistics"; SelectTab("machines"); }'>
                                <span class="wiki-feature-icon">🚢</span>
                                <strong>Seaport</strong>
                                <span class="muted">Pool ↔ fabrik</span>
                            </button>
                            <button type="button" class="wiki-feature-card wiki-feature-elements" @onclick='() => SelectTab("elements")'>
                                <span class="wiki-feature-icon">🧪</span>
                                <strong>Grundämnen</strong>
                                <span class="muted">@_wiki.Elements.Count st med genererade namn</span>
                            </button>
                        </div>

                        @if (_highlightElement is not null && GetElementDetail(_highlightElement.Id) is { } highlighted)
                        {
                            <div class="wiki-highlight-banner">
                                <p>Du kom hit från pool-analys — visar <strong>@highlighted.Name</strong>.</p>
                                <button type="button" class="secondary" @onclick="() => SelectElement(highlighted.Id)">Visa detaljer</button>
                            </div>
                        }
                    </section>

                    <section class="wiki-machine-grid">
                        @foreach (var m in _wiki.Machines.Take(6))
                        {
                            <button type="button" class="panel wiki-machine-card" @onclick="() => SelectMachine(m)">
                                <WikiMachineIcon Type="@m.Type" />
                                <h4>@WikiPresentation.MachineDisplayName(m.Type)</h4>
                                <p class="muted">@m.Ports in→ut · @Truncate(m.Summary, 90)</p>
                            </button>
                        }
                    </section>
                }
                else if (_activeTab == "machines" && _selectedMachine is { } machine)
                {
                    <article class="panel wiki-detail wiki-machine-detail">
                        <div class="wiki-detail-header">
                            <WikiMachineIcon Type="@machine.Type" />
                            <div>
                                <h3>@WikiPresentation.MachineDisplayName(machine.Type)</h3>
                                <p class="muted wiki-detail-meta">
                                    <span class="wiki-type-mono">@machine.Type</span>
                                    · portar @machine.Ports
                                    · @WikiPresentation.MachineCategoryLabel(WikiPresentation.MachineCategory(machine.Type))
                                </p>
                            </div>
                        </div>

                        <div class="wiki-port-diagram" aria-label="Portschema">
                            @{
                                var ratio = WikiPresentation.ParsePortRatio(machine.Ports).FirstOrDefault();
                            }
                            <span class="wiki-port-node wiki-port-in">IN @ratio.In</span>
                            <span class="wiki-port-pipe"></span>
                            <span class="wiki-port-box">@WikiPresentation.MachineEmoji(machine.Type)</span>
                            <span class="wiki-port-pipe"></span>
                            <span class="wiki-port-node wiki-port-out">UT @ratio.Out</span>
                        </div>

                        <p class="wiki-detail-summary">@WikiPresentation.ExtendedSummary(machine.Type, machine.Summary)</p>

                        <h4 class="wiki-section-label">Tips från regelmotorn</h4>
                        <ul class="wiki-tips-list">
                            @foreach (var tip in WikiPresentation.MachineTips(machine.Type))
                            {
                                <li>@tip</li>
                            }
                        </ul>

                        <div class="wiki-detail-actions">
                            <a class="button-link" href="/boards">Bygg i fabriken →</a>
                            <button type="button" class="secondary" @onclick="ClearMachineSelection">Stäng</button>
                        </div>
                    </article>
                }
                else if (_activeTab == "machines")
                {
                    <section class="wiki-machine-grid">
                        @foreach (var m in FilteredMachines)
                        {
                            <button type="button" class="panel wiki-machine-card" @onclick="() => SelectMachine(m)">
                                <WikiMachineIcon Type="@m.Type" />
                                <h4>@WikiPresentation.MachineDisplayName(m.Type)</h4>
                                <p class="muted">@m.Ports · @Truncate(m.Summary, 72)</p>
                            </button>
                        }
                    </section>
                }
                else if (_activeTab == "elements" && _selectedElementId is int eid && GetElementDetail(eid) is { } element)
                {
                    <article class="panel wiki-detail wiki-element-detail">
                        <div class="wiki-detail-header wiki-element-detail-header">
                            <WikiElementOrb Element="element" />
                            <div>
                                <h3>@element.Name</h3>
                                <p class="muted wiki-detail-meta">
                                    <span class="fg-element-badge">@element.Symbol</span>
                                    Element @element.Id
                                    · <span class="fg-phase-badge @WikiPresentation.PhaseCssClass(element.Decoded.Phase)">@WikiPresentation.PhaseLabelSv(element.Decoded.Phase)</span>
                                </p>
                            </div>
                        </div>

                        <p class="wiki-detail-narrative">@ElementPropertyNarrator.Describe(element)</p>

                        <h4 class="wiki-section-label">DNA-uppbyggnad</h4>
                        <WikiDnaChart Element="element" />
                        <p class="muted pool-dna-hex">DNA: 0x@element.Dna.ToString("X16")</p>

                        <h4 class="wiki-section-label">Egenskaper</h4>
                        <dl class="pool-props-grid">
                            <dt>Fas</dt><dd>@WikiPresentation.PhaseLabelSv(element.Decoded.Phase)</dd>
                            <dt>Explosivitet</dt><dd>@element.Decoded.Explosivity %</dd>
                            <dt>Brandfarlighet</dt><dd>@element.Decoded.Flammability %</dd>
                            <dt>Toxicitet</dt><dd>@element.Decoded.Toxicity %</dd>
                            <dt>Kokpunkt</dt><dd>@element.Decoded.BoilingPoint</dd>
                            <dt>Fryspunkt</dt><dd>@element.Decoded.FreezePoint</dd>
                            <dt>Familj</dt><dd>@element.Decoded.FamilyId</dd>
                        </dl>

                        <div class="wiki-detail-actions">
                            <a class="button-link" href="/exchange">Handla på börsen →</a>
                            <a class="button-link secondary-link" href="/pool">Se pool →</a>
                            <button type="button" class="secondary" @onclick="ClearElementSelection">Stäng</button>
                        </div>
                    </article>
                }
                else if (_activeTab == "elements")
                {
                    <div class="panel wiki-empty-detail">
                        <p class="muted">Välj ett grundämne i listan — eller sök på symbol, namn eller fas.</p>
                    </div>
                }
            </main>
        </div>
    }
</div>

@code {
    private static readonly (string Id, string Label)[] Tabs =
    [
        ("overview", "Översikt"),
        ("machines", "Maskiner"),
        ("elements", "Grundämnen")
    ];

    private static readonly string[] MachineCategories = ["heat", "phase", "separation", "logistics"];

    private bool _busy;
    private string? _error;
    private WikiContentResponse? _wiki;
    private List<ElementContentItem> _elementDetails = [];
    private WikiElementItem? _highlightElement;

    private string _activeTab = "overview";
    private string _search = "";
    private string _machineCategory = "";
    private string _elementPhaseFilter = "";
    private WikiMachineItem? _selectedMachine;
    private int? _selectedElementId;
    private bool _showDnaExplainer;
    private List<PhaseStat> _phaseStats = [];

    protected override async Task OnInitializedAsync()
    {
        ApplyQueryRoute();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var wikiTask = Http.GetFromJsonAsync<WikiContentResponse>("/v1/content/wiki?locale=sv");
            var elementsTask = Http.GetFromJsonAsync<List<ElementContentItem>>("/v1/content/elements?locale=sv");
            await Task.WhenAll(wikiTask, elementsTask);

            _wiki = await wikiTask;
            _elementDetails = await elementsTask ?? [];

            if (_wiki == null)
            {
                _error = "Kunde inte läsa wiki.";
                return;
            }

            BuildPhaseStats();
            ApplyHighlightFromQuery();
        }
        catch (Exception ex)
        {
            _error = ApiConnectionErrors.Format(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private void BuildPhaseStats()
    {
        if (_elementDetails.Count == 0)
        {
            _phaseStats = [];
            return;
        }

        var total = _elementDetails.Count;
        _phaseStats = _elementDetails
            .GroupBy(e => e.Decoded.Phase)
            .OrderByDescending(g => g.Count())
            .Select(g => new PhaseStat(g.Key, g.Count(), (int)Math.Round(g.Count() * 100.0 / total)))
            .ToList();
    }

    private void ApplyHighlightFromQuery()
    {
        if (_wiki == null)
            return;

        if (TryGetQueryInt("elementId", out var elementId))
        {
            _highlightElement = _wiki.Elements.FirstOrDefault(e => e.Id == elementId);
            if (_highlightElement != null)
                SelectElement(elementId, updateUrl: false);
        }

        if (TryGetQueryString("machine", out var machineType))
        {
            var machine = _wiki.Machines.FirstOrDefault(m =>
                m.Type.Equals(machineType, StringComparison.OrdinalIgnoreCase));
            if (machine != null)
                SelectMachine(machine, updateUrl: false);
        }

        if (TryGetQueryString("tab", out var tab) && Tabs.Any(t => t.Id == tab))
            _activeTab = tab;
    }

    private void ApplyQueryRoute()
    {
        if (TryGetQueryString("tab", out var tab) && Tabs.Any(t => t.Id == tab))
            _activeTab = tab;
    }

    private IEnumerable<WikiMachineItem> FilteredMachines
    {
        get
        {
            if (_wiki == null)
                return [];

            IEnumerable<WikiMachineItem> q = _wiki.Machines;
            if (!string.IsNullOrWhiteSpace(_machineCategory))
                q = q.Where(m => WikiPresentation.MachineCategory(m.Type) == _machineCategory);

            if (string.IsNullOrWhiteSpace(_search))
                return q.OrderBy(m => WikiPresentation.MachineDisplayName(m.Type));

            var s = _search.Trim();
            return q.Where(m =>
                    WikiPresentation.MachineDisplayName(m.Type).Contains(s, StringComparison.OrdinalIgnoreCase)
                    || m.Type.Contains(s, StringComparison.OrdinalIgnoreCase)
                    || m.Summary.Contains(s, StringComparison.OrdinalIgnoreCase))
                .OrderBy(m => WikiPresentation.MachineDisplayName(m.Type));
        }
    }

    private IEnumerable<WikiElementItem> FilteredElements
    {
        get
        {
            if (_wiki == null)
                return [];

            IEnumerable<WikiElementItem> q = _wiki.Elements;
            if (!string.IsNullOrWhiteSpace(_elementPhaseFilter))
            {
                q = q.Where(item =>
                {
                    var detail = GetElementDetail(item.Id);
                    return detail != null
                           && detail.Decoded.Phase.Equals(_elementPhaseFilter, StringComparison.OrdinalIgnoreCase);
                });
            }

            if (string.IsNullOrWhiteSpace(_search))
                return q.OrderBy(e => e.DisplayName);

            var s = _search.Trim();
            return q.Where(e =>
            {
                var detail = GetElementDetail(e.Id);
                return e.Symbol.Contains(s, StringComparison.OrdinalIgnoreCase)
                       || e.DisplayName.Contains(s, StringComparison.OrdinalIgnoreCase)
                       || e.Id.ToString() == s
                       || (detail != null && WikiPresentation.PhaseLabelSv(detail.Decoded.Phase)
                           .Contains(s, StringComparison.OrdinalIgnoreCase));
            }).OrderBy(e => e.DisplayName);
        }
    }

    private bool _showFallbackCard =>
        _search.Contains("aska", StringComparison.OrdinalIgnoreCase)
        || _search.Contains("goo", StringComparison.OrdinalIgnoreCase)
        || _search.Contains("fallback", StringComparison.OrdinalIgnoreCase);

    private bool _showDnaExplainerFlag =>
        _showDnaExplainer
        || _search.Contains("dna", StringComparison.OrdinalIgnoreCase);

    private ElementContentItem? GetElementDetail(int id) =>
        _elementDetails.FirstOrDefault(e => e.Id == id);

    private void SelectTab(string tabId)
    {
        _activeTab = tabId;
        UpdateUrl();
    }

    private void SelectMachine(WikiMachineItem machine, bool updateUrl = true)
    {
        _selectedMachine = machine;
        _activeTab = "machines";
        if (updateUrl)
            UpdateUrl(machine: machine.Type);
    }

    private void SelectElement(int elementId, bool updateUrl = true)
    {
        _selectedElementId = elementId;
        _activeTab = "elements";
        if (updateUrl)
            UpdateUrl(elementId: elementId);
    }

    private void ClearMachineSelection()
    {
        _selectedMachine = null;
        UpdateUrl();
    }

    private void ClearElementSelection()
    {
        _selectedElementId = null;
        UpdateUrl();
    }

    private void ClearSearch() => _search = "";

    private void ShowDnaExplainer()
    {
        _showDnaExplainer = true;
        _search = "dna";
    }

    private void UpdateUrl(string? machine = null, int? elementId = null)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase)
        {
            ["tab"] = _activeTab
        };

        if (_activeTab == "machines" && (_selectedMachine != null || machine != null))
            q["machine"] = machine ?? _selectedMachine?.Type;
        else if (_activeTab == "elements" && (_selectedElementId != null || elementId != null))
            q["elementId"] = (elementId ?? _selectedElementId)?.ToString();

        var qs = string.Join("&", q.Where(kv => !string.IsNullOrEmpty(kv.Value)).Select(kv =>
            $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value!)}"));

        Nav.NavigateTo(qs.Length > 0 ? $"/wiki?{qs}" : "/wiki", replace: true);
    }

    private bool TryGetQueryInt(string key, out int value)
    {
        value = 0;
        return TryGetQueryString(key, out var raw) && int.TryParse(raw, out value) && value > 0;
    }

    private bool TryGetQueryString(string key, out string value)
    {
        value = "";
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query;
        if (string.IsNullOrEmpty(query))
            return false;

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0].Equals(key, StringComparison.OrdinalIgnoreCase))
            {
                value = Uri.UnescapeDataString(kv[1]);
                return true;
            }
        }

        return false;
    }

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..(max - 1)] + "…";

    private sealed record PhaseStat(string Phase, int Count, int Percent);
}
