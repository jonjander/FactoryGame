@using FactoryGame.Contracts.Machines

@if (Visible && Item != null)
{
    <div class="fg-modal-backdrop" @onclick="CloseAsync">
        <div class="fg-modal fg-modal-wide fg-machine-info-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true">
            <div class="pool-analysis-header">
                <div>
                    <h3 class="fg-modal-title">@Item.DisplayName</h3>
                    <p class="muted pool-analysis-subtitle">@Item.Type · @FormatPorts(Item)</p>
                </div>
                <button type="button" class="secondary pool-analysis-close" @onclick="CloseAsync" aria-label="Close">X</button>
            </div>

            <div class="fg-machine-info-icon" aria-hidden="true">
                @((MarkupString)BuildIconSvg(Item.Type))
            </div>

            <p class="fg-machine-info-summary">@GetSummary(Item.Type)</p>

            <h4 class="pool-analysis-section-title">Tips</h4>
            <ul class="fg-machine-info-tips">
                @foreach (var tip in GetTips(Item.Type))
                {
                    <li>@tip</li>
                }
            </ul>

            <div class="fg-modal-actions">
                <button type="button" class="secondary" @onclick="CloseAsync">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public MachineStoreItemDto? Item { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private Task CloseAsync() => OnClose.InvokeAsync();

    private static string FormatPorts(MachineStoreItemDto item)
    {
        var ins = item.Ports.Count(p => p.Direction == "in");
        var outs = item.Ports.Count(p => p.Direction == "out");
        return $"{ins} in · {outs} out";
    }

    private static string GetSummary(string type) => type switch
    {
        "Boiler" => "Pressurized liquid boiler — heats batches until they are ready for separation.",
        "Heater" => "Direct heat coils for stepwise warming. Avoid highly explosive materials.",
        "Cooler" => "Heat exchanger that pulls energy from the stream. Toxic materials can block cooling.",
        "Condenser" => "Chilled coil converts gas to liquid. Output symbol may stay the same (e.g. E04) — check phase and pool variant.",
        "Crystallizer" => "Supercooled bath locks unruly liquid into solid crystal.",
        "Melter" => "Induction furnace melts solid feed into pourable liquid.",
        "Mixer" => "Blends two inputs. Gentle mix keeps a stable blend; hard mix makes a volatile blend for distillation.",
        "Destilator" => "Separates liquid/gas into two fractions based on boiling point and reflux settings.",
        "LiquidSeparator" => "Splits liquid into two outputs at the chosen cut.",
        "Sorter" => "Routes configured base elements to ports 1-3; everything else goes to the rest port.",
        "SeaportConnector" => "Connects the factory to your seaport pool: out from pool (out), in to pool (in).",
        _ => "Factory machine -- wire pipes to in/out ports per the schema."
    };

    private static IReadOnlyList<string> GetTips(string type) => type switch
    {
        "Boiler" => ["Requires liquid phase.", "Wire seaport out -> boiler in for a starter loop.", "Adjust heat for the process you want."],
        "Condenser" => ["Requires gas phase.", "Symbol may stay the same -- phase (gas->liquid) shows in factory info.", "Condensed liquid becomes its own pool variant at seaport in."],
        "Destilator" => ["Requires liquid or gas phase — not solid.", "Use Mixer on hard mix for a volatile blend.", "Set boil cut and reflux for desired fractions."],
        "Mixer" => ["Two inputs (in1, in2).", "Balanced ratio gives predictable blending.", "Hard mix -> better distillation downstream."],
        "Sorter" => ["Pick unique base elements on ports 1-3.", "Check that downstream machines tolerate the incoming material.", "Rest port catches everything unmatched."],
        "SeaportConnector" => ["Pick pool variant (phase) — e.g. E04 gas vs E04 liquid.", "Default is no outflow until you pick a variant.", "Wire in to pool to store production per variant."],
        "LiquidSeparator" => ["Liquids only.", "Cut controls where the split goes between out1 and out2."],
        _ => ["Place from machine inventory with a unique id.", "Save the plan after wiring and settings.", "Start the factory when seaport and loop are wired."]
    };

    private static string BuildIconSvg(string type)
    {
        var (body, accent) = type switch
        {
            "Boiler" or "Heater" => ("#5c2a1a", "#f0883e"),
            "Cooler" or "Condenser" or "Crystallizer" => ("#1a3d5c", "#58a6ff"),
            "Mixer" => ("#3d2a5c", "#bc8cff"),
            "Destilator" or "LiquidSeparator" => ("#2a4a22", "#79c27a"),
            "Sorter" => ("#4a4222", "#d29922"),
            "SeaportConnector" => ("#1a3d3d", "#39d353"),
            _ => ("#21262d", "#8b949e")
        };

        return $"""
            <svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg" class="fg-machine-info-icon-svg">
              <rect x="8" y="12" width="104" height="48" rx="8" fill="{body}" stroke="{accent}" stroke-width="2"/>
              <circle cx="8" cy="36" r="5" fill="#238636"/>
              <circle cx="112" cy="28" r="5" fill="#1f6feb"/>
              <circle cx="112" cy="44" r="5" fill="#1f6feb"/>
              <text x="60" y="42" text-anchor="middle" fill="#e6edf3" font-size="11" font-family="system-ui,sans-serif">{Escape(type.Length > 10 ? type[..10] : type)}</text>
            </svg>
            """;
    }

    private static string Escape(string s) =>
        s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
}
