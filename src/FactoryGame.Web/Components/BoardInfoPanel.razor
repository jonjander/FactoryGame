@using FactoryGame.Contracts.Boards
@using FactoryGame.Web.Services

<div class="panel fg-sub fg-board-info">
    <h4>Factory info — @Info.Name</h4>
    <p class="muted">
        Mode: <strong>@Info.Mode</strong>
        · @Info.PlanMachineCount machine(s), @Info.PlanConnectionCount pipe(s)
        @if (Info.PlanHasCycle) { <span> · loop</span> }
        @if (Info.Throughput.IsEstimate) { <span> · estimate</span> }
    </p>

    <div class="fg-info-grid">
        <div>
            <h5>Throughput</h5>
            <p><strong>@Info.Throughput.TotalUnitsPerSecond.ToString("0.##")</strong> units/s</p>
            <p class="muted">@Info.Throughput.Note</p>
        </div>
        <div>
            <h5>Estimated value</h5>
            <p><strong>@Info.Value.EstimatedValuePerSecond.ToString("0.##")</strong> /s</p>
            <p class="muted">@Info.Value.Note</p>
        </div>
    </div>

    @{
        var seaportInPorts = (Info.SeaportPorts ?? Array.Empty<SeaportPortFlowDto>())
            .Where(p => p.Direction == "in")
            .OrderBy(p => p.MachineId, StringComparer.Ordinal)
            .ToList();
    }
    @if (seaportInPorts.Count > 0)
    {
        <h5>Seaport — input «in» (factory → pool)</h5>
        <ul class="fg-seaport-port-list">
            @foreach (var port in seaportInPorts)
            {
                <li class="fg-seaport-port-card @(port.IsConnected ? "" : "fg-seaport-port-idle")">
                    <div class="fg-seaport-port-header">
                        <strong>@port.MachineId</strong>
                        <span class="muted">@port.MachineType · port @port.Port</span>
                        @if (port.IsEstimate)
                        {
                            <span class="fg-badge fg-badge-muted">estimate</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(port.ElementSymbol))
                    {
                        <p class="fg-seaport-element">
                            <span class="fg-element-badge" title="Element @port.ElementId">@port.ElementSymbol</span>
                            @if (port.LinkedMachineId != null)
                            {
                                <span class="muted">from @port.LinkedMachineId.@port.LinkedPort</span>
                            }
                        </p>
                    }
                    <p class="fg-seaport-port-summary">@port.Summary</p>
                    @if (!port.IsConnected)
                    {
                        <p class="muted">Connect e.g. <code>boiler1.out</code> → <code>@(port.MachineId).in</code></p>
                    }
                </li>
            }
        </ul>
    }

    <h5>In from seaport (pool → factory)</h5>
    @if (Info.Seaport.IntoFactory.Count == 0)
    {
        <p class="muted">No active inflows.</p>
    }
    else
    {
        <ul class="fg-info-list">
            @foreach (var line in Info.Seaport.IntoFactory)
            {
                <li><strong>@line.UnitsPerSecond.ToString("0.##")</strong>/s — @line.Description</li>
            }
        </ul>
    }

    <h5>Out to seaport (factory → pool)</h5>
    @if (Info.Seaport.OutOfFactory.Count == 0)
    {
        <p class="muted">No active outflows.</p>
    }
    else
    {
        <ul class="fg-info-list">
            @foreach (var line in Info.Seaport.OutOfFactory)
            {
                <li><strong>@line.UnitsPerSecond.ToString("0.##")</strong>/s — @line.Description</li>
            }
        </ul>
    }

    @{
        var seaportOutPorts = (Info.SeaportPorts ?? Array.Empty<SeaportPortFlowDto>())
            .Where(p => p.Direction == "out")
            .OrderBy(p => p.MachineId, StringComparer.Ordinal)
            .ToList();
    }
    @if (seaportOutPorts.Count > 0)
    {
        <h5>Seaport — output «out» (pool → factory)</h5>
        <p class="muted">Pick pool variant in machine settings (<code>outElementId</code> + <code>outMaterialDna</code>).</p>
        <ul class="fg-seaport-port-list">
            @foreach (var port in seaportOutPorts)
            {
                <li class="fg-seaport-port-card">
                    <div class="fg-seaport-port-header">
                        <strong>@port.MachineId</strong>
                        <span class="muted">@port.MachineType · port @port.Port</span>
                    </div>
                    @if (!string.IsNullOrEmpty(port.ElementSymbol))
                    {
                        <p class="fg-seaport-element">
                            <span class="fg-element-badge">@port.ElementSymbol</span>
                            <span class="muted">from pool</span>
                            @if (port.LinkedMachineId != null)
                            {
                                <span class="muted">→ @port.LinkedMachineId.@port.LinkedPort</span>
                            }
                        </p>
                    }
                    <p class="fg-seaport-port-summary">@port.Summary</p>
                </li>
            }
        </ul>
    }

    @{
        var machineFlows = (Info.MachinePortFlows ?? Array.Empty<MachinePortFlowDto>())
            .Where(f => !f.IsPoolSource)
            .OrderBy(f => f.MachineId, StringComparer.Ordinal)
            .ThenBy(f => f.Port, StringComparer.Ordinal)
            .ToList();
    }
    @if (machineFlows.Count > 0)
    {
        <h5>Machines — results (in → out)</h5>
        <ul class="fg-seaport-port-list">
            @foreach (var flow in machineFlows)
            {
                <li class="fg-seaport-port-card">
                    <div class="fg-seaport-port-header">
                        <strong>@flow.MachineId.@flow.Port</strong>
                        <span class="muted">@flow.MachineType</span>
                        @if (flow.IsEstimate) { <span class="fg-badge fg-badge-muted">estimate</span> }
                    </div>
                    @if (!string.IsNullOrEmpty(flow.InputElementSymbol) || !string.IsNullOrEmpty(flow.OutputElementSymbol))
                    {
                        <p class="fg-seaport-element">
                            @if (!string.IsNullOrEmpty(flow.InputElementSymbol))
                            {
                                <span class="fg-element-badge">@flow.InputElementSymbol</span>
                                @if (!string.IsNullOrEmpty(flow.InputPhase))
                                {
                                    <span class="fg-phase-badge fg-phase-@flow.InputPhase.ToLowerInvariant()">@FormatPhaseLabel(flow.InputPhase)</span>
                                }
                            }
                            @if (!string.IsNullOrEmpty(flow.InputElementSymbol) && !string.IsNullOrEmpty(flow.OutputElementSymbol))
                            {
                                <span>→</span>
                            }
                            @if (!string.IsNullOrEmpty(flow.OutputElementSymbol))
                            {
                                <span class="fg-element-badge fg-element-badge-out">@flow.OutputElementSymbol</span>
                                @if (!string.IsNullOrEmpty(flow.OutputPhase))
                                {
                                    <span class="fg-phase-badge fg-phase-@flow.OutputPhase.ToLowerInvariant()">@FormatPhaseLabel(flow.OutputPhase)</span>
                                }
                            }
                            @if (!string.IsNullOrEmpty(flow.TransformNote))
                            {
                                <span class="muted">(@flow.TransformNote)</span>
                            }
                        </p>
                    }
                    @if (!string.IsNullOrEmpty(flow.ProcessStatus))
                    {
                        <p class="fg-process-status fg-process-@flow.ProcessStatus.ToLowerInvariant()">
                            @FormatProcessStatus(flow.ProcessStatus)
                            @if (flow.DnaChanged) { <span class="muted"> · DNA changed</span> }
                        </p>
                    }
                    <p class="fg-seaport-port-summary">@flow.Summary</p>
                </li>
            }
        </ul>
    }

    <h5>Reports</h5>
    @if (VisibleIssues.Count == 0 && MutedWarningCount == 0)
    {
        <p class="muted">No errors or warnings.</p>
    }
    else
    {
        @if (MutedWarningCount > 0)
        {
            <p class="muted">@MutedWarningCount warning(s) muted — does not affect factory status.</p>
            <ul class="fg-issues fg-issues-muted">
                @foreach (var issue in Info.Issues.Where(i => i.Severity == "warning"
                    && MutedIssueKeys.Contains(BoardIssueMuteStore.IssueKey(i.Code, i.MachineId))))
                {
                    <li class="fg-issue fg-issue-warning fg-issue-muted">
                        <span class="muted">@issue.Message</span>
                        @if (OnToggleIssueMute.HasDelegate)
                        {
                            <button type="button" class="fg-issue-mute-btn secondary" @onclick="() => OnToggleIssueMute.InvokeAsync(issue)">Show</button>
                        }
                    </li>
                }
            </ul>
        }
        @if (VisibleIssues.Count > 0)
        {
            <ul class="fg-issues">
                @foreach (var issue in VisibleIssues.OrderBy(i => i.Severity))
                {
                    <li class="fg-issue fg-issue-@issue.Severity">
                        <span>@issue.Message</span>
                        @if (issue.Severity == "warning" && OnToggleIssueMute.HasDelegate)
                        {
                            <button type="button"
                                    class="fg-issue-mute-btn secondary"
                                    title="Mute this warning"
                                    @onclick="() => OnToggleIssueMute.InvokeAsync(issue)">
                                Mute
                            </button>
                        }
                    </li>
                }
            </ul>
        }
    }
</div>

@code {
    [Parameter, EditorRequired]
    public BoardInfoDto Info { get; set; } = null!;

    [Parameter]
    public IReadOnlyList<BoardIssueDto> VisibleIssues { get; set; } = Array.Empty<BoardIssueDto>();

    [Parameter]
    public IReadOnlySet<string> MutedIssueKeys { get; set; } = new HashSet<string>(StringComparer.Ordinal);

    [Parameter]
    public EventCallback<BoardIssueDto> OnToggleIssueMute { get; set; }

    private int MutedWarningCount =>
        Info.Issues.Count(i => i.Severity == "warning"
            && MutedIssueKeys.Contains(BoardIssueMuteStore.IssueKey(i.Code, i.MachineId)));

    private static string FormatPhaseLabel(string phaseKey) => phaseKey.ToLowerInvariant() switch
    {
        "gas" => "gas",
        "liquid" => "liquid",
        "solid" => "solid",
        _ => phaseKey
    };

    private static string FormatProcessStatus(string status) => status switch
    {
        "Transformed" => "Transformed",
        "Blocked" => "Blocked",
        "WaitingMaterial" => "Waiting for material",
        "Idle" => "Idle",
        _ => status
    };
}
