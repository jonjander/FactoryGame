@using FactoryGame.Contracts.Boards
@using FactoryGame.Contracts.Machines
@using FactoryGame.Web.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="fg-factory-canvas-wrap @(FillViewport ? "fg-factory-canvas-fill" : "")">
    <ConfirmDialog Visible="_confirmRemoveVisible"
                   Message="@_confirmRemoveMessage"
                   ConfirmLabel="Ta bort"
                   OnConfirm="ConfirmRemoveMachineAsync"
                   OnCancel="CancelRemoveMachine" />
    @if (!ReadOnly)
    {
        @if (!HideHelpText)
        {
            <p class="muted">Dra maskiner. Koppla rör: dra från utgång → ingång, eller klicka utgång → ingång. Klicka rör → «Ta bort rör». Papperskorg på maskin → ta bort.</p>
        }
        @if (_selectedConnectionIndex is int sel && sel >= 0 && sel < Plan.Connections.Count)
        {
            var sc = Plan.Connections[sel];
            <div class="fg-pipe-toolbar">
                <span class="muted">Valt: @sc.FromId.@sc.FromPort → @sc.ToId.@sc.ToPort</span>
                <button type="button" class="secondary" @onclick="RemoveSelectedPipeAsync">Ta bort rör</button>
                <button type="button" class="secondary" @onclick="ClearPipeSelection">Avmarkera</button>
            </div>
        }
    }
    else if (!HideHelpText)
    {
        <p class="muted fg-factory-running-banner">Planen körs — endast visning. Stoppa fabriken för att redigera.</p>
    }
    <svg @ref="_svgRef"
         xmlns="http://www.w3.org/2000/svg"
         class="fg-factory-canvas @(FillViewport ? "fg-factory-canvas-fill" : "")"
         viewBox="@_viewBox"
         @onclick="OnCanvasBackgroundClick">
        <defs>
            <marker id="fg-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                <path d="M0,0 L6,3 L0,6 Z" fill="var(--fg-pipe, #5b9bd5)" />
            </marker>
        </defs>

        @foreach (var entry in BuildPipeEntries())
        {
            var selected = _selectedConnectionIndex == entry.Index;
            var pipeTitle = GetPipeTooltip(entry.Index);
            <path class="fg-pipe-hit @(selected ? "fg-pipe-hit-selected" : "")"
                  d="@entry.Draw.Path"
                  @onclick="() => OnPipeClick(entry.Index)"
                  @onclick:stopPropagation="true">
                <title>@pipeTitle</title>
            </path>
            <path class="@entry.Draw.CssClass @(selected ? "fg-pipe-selected" : "") @GetPipeFlowClass(entry.Index) @GetPipePhaseClass(entry.Index)"
                  d="@entry.Draw.Path"
                  marker-end="url(#fg-arrow)"
                  pointer-events="none" />
        }

        @if (_dragPipeFrom is { } dragFrom && _dragCursor is { } cursor)
        {
            var p1 = GetPortPointOrDefault(dragFrom.Id, dragFrom.Port, true);
            <path class="fg-pipe fg-pipe-drag-preview"
                  d="@PipeRouting.BuildPath(p1, cursor, 0, 1)"
                  pointer-events="none" />
        }

        @for (var i = 0; i < Plan.Machines.Count; i++)
        {
            var m = Plan.Machines[i];
            var (mx, my) = PlanLayout.GetPosition(m, i);
            var w = MachineWidth;
            var h = MachineHeight;
            if (!_machineMeta.TryGetValue(m.Type, out var meta))
                meta = null;

            var running = IsMachineRunning(m.Id);
            var blocked = IsMachineBlocked(m.Id);
            var condenserActive = IsCondenserTransforming(m.Id);
            var machineTitle = GetMachineTooltip(m);

            <g class="fg-machine @(ReadOnly ? "fg-machine-readonly" : "") @(IsSelected(m.Id) ? "fg-machine-selected" : "") @(running ? "fg-machine-running" : "") @(blocked ? "fg-machine-blocked" : "") @(condenserActive ? "fg-machine-condenser-active" : "")"
               transform="translate(@Fmt(mx), @Fmt(my))">
                <title>@machineTitle</title>
                <rect class="fg-machine-body" width="@w" height="@h" rx="6" pointer-events="none" />
                @if (running)
                {
                    <rect class="fg-machine-flow-pulse" width="@w" height="@h" rx="6" pointer-events="none" />
                }
                @if (condenserActive)
                {
                    <circle class="fg-condenser-bubble fg-condenser-bubble-a" cx="@Fmt(w * 0.35)" cy="@Fmt(h * 0.55)" r="3" pointer-events="none" />
                    <circle class="fg-condenser-bubble fg-condenser-bubble-b" cx="@Fmt(w * 0.55)" cy="@Fmt(h * 0.65)" r="2.5" pointer-events="none" />
                    <circle class="fg-condenser-bubble fg-condenser-bubble-c" cx="@Fmt(w * 0.72)" cy="@Fmt(h * 0.5)" r="2" pointer-events="none" />
                }
                @if (!ReadOnly)
                {
                    <rect class="fg-machine-drag-handle"
                          width="@w"
                          height="@h"
                          rx="6"
                          @onclick="() => OnMachineClick(m.Id)"
                          @onclick:stopPropagation="true"
                          @onmousedown="e => OnMachineMouseDown(e, m.Id)"
                          @onmousedown:stopPropagation="true" />
                }
                <foreignObject x="4" y="6" width="@(w - 8)" height="20" pointer-events="none">
                    <div xmlns="http://www.w3.org/1999/xhtml" class="fg-machine-label-html">
                        @m.Id
                        @if (running) { <span class="fg-machine-status-dot" title="Kör">●</span> }
                        else if (blocked) { <span class="fg-machine-status-dot fg-machine-status-blocked" title="Blockerad">●</span> }
                    </div>
                </foreignObject>
                <foreignObject x="4" y="26" width="@(w - 8)" height="16" pointer-events="none">
                    <div xmlns="http://www.w3.org/1999/xhtml" class="fg-machine-type-html">@m.Type</div>
                </foreignObject>
                @if (!ReadOnly)
                {
                    <foreignObject x="@Fmt(w - 22)" y="2" width="20" height="20">
                        <button xmlns="http://www.w3.org/1999/xhtml"
                                type="button"
                                class="fg-machine-delete-btn"
                                title="Ta bort maskin"
                                aria-label="Ta bort @m.Id"
                                @onclick="() => RequestRemoveMachine(m)"
                                @onclick:stopPropagation="true"
                                @onmousedown:stopPropagation="true">
                            <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                                <path fill="currentColor" d="M5.5 1.5A1 1 0 0 1 6.5 1h3a1 1 0 0 1 1 1V2h2.5a.5.5 0 0 1 0 1H13v9.5a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 3 12.5V3h-.5a.5.5 0 0 1 0-1H5v-.5zm1 0v.5h3V1.5h-3zM4 3v9.5c0 .276.224.5.5.5h7a.5.5 0 0 0 .5-.5V3H4zm2 2h1v6H6V5zm3 0h1v6H9V5z"/>
                            </svg>
                        </button>
                    </foreignObject>
                }

                @if (meta != null)
                {
                    var inPorts = meta.Ports.Where(p => p.Direction == "in").ToList();
                    var outPorts = meta.Ports.Where(p => p.Direction == "out").ToList();
                    @for (var pi = 0; pi < inPorts.Count; pi++)
                    {
                        var port = inPorts[pi];
                        var py = PortY(pi, inPorts.Count, h);
                        var inHint = GetPortFlowHint(m.Id, port.Name, isOutput: false);
                        <circle class="fg-port fg-port-in @PortClass(m.Id, port.Name, false) @(HasPortFlow(m.Id, port.Name, false) ? "fg-port-flowing" : "")"
                                cx="0" cy="@Fmt(py)" r="8"
                                data-fg-machine="@m.Id" data-fg-port="@port.Name" data-fg-dir="in"
                                @onclick="() => OnPortClick(m.Id, port.Name, false)"
                                @onclick:stopPropagation="true"
                                @onmouseup="e => OnPortMouseUp(e, m.Id, port.Name, false)"
                                @onmouseup:stopPropagation="true">
                            <title>@GetPortTitle(port.Name, inHint)</title>
                        </circle>
                        @if (!string.IsNullOrEmpty(inHint))
                        {
                            <foreignObject x="-58" y="@Fmt(py - 9)" width="54" height="18" pointer-events="none">
                                <div xmlns="http://www.w3.org/1999/xhtml" class="fg-port-flow-hint">@inHint</div>
                            </foreignObject>
                        }
                    }
                    @for (var pi = 0; pi < outPorts.Count; pi++)
                    {
                        var port = outPorts[pi];
                        var py = PortY(pi, outPorts.Count, h);
                        var outHint = GetPortFlowHint(m.Id, port.Name, isOutput: true);
                        <circle class="fg-port fg-port-out @PortClass(m.Id, port.Name, true) @(HasPortFlow(m.Id, port.Name, true) ? "fg-port-flowing" : "")"
                                cx="@w" cy="@Fmt(py)" r="8"
                                data-fg-machine="@m.Id" data-fg-port="@port.Name" data-fg-dir="out"
                                @onclick="() => OnPortClick(m.Id, port.Name, true)"
                                @onclick:stopPropagation="true"
                                @onmousedown="e => OnPortMouseDown(e, m.Id, port.Name, true)"
                                @onmousedown:stopPropagation="true"
                                @onmouseup="e => OnPortMouseUp(e, m.Id, port.Name, true)">
                            <title>@GetPortTitle(port.Name, outHint)</title>
                        </circle>
                        @if (!string.IsNullOrEmpty(outHint))
                        {
                            <foreignObject x="@Fmt(w + 4)" y="@Fmt(py - 9)" width="54" height="18" pointer-events="none">
                                <div xmlns="http://www.w3.org/1999/xhtml" class="fg-port-flow-hint">@outHint</div>
                            </foreignObject>
                        }
                    }
                }
            </g>
        }
    </svg>
</div>

@code {
    private const double MachineWidth = 120;
    private const double MachineHeight = 64;
    private const double CanvasPad = 24;
    private const double MachineDragThresholdPx = 4;

    [Parameter, EditorRequired]
    public BoardPlanDto Plan { get; set; } = null!;

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public bool IsFactoryRunning { get; set; }

    [Parameter]
    public double UnitsPerSecond { get; set; } = 1;

    [Parameter]
    public IReadOnlyDictionary<string, MachineStoreItemDto> MachineMeta { get; set; } =
        new Dictionary<string, MachineStoreItemDto>(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public BoardKeyframeDto? LatestKeyframe { get; set; }

    [Parameter]
    public EventCallback<BoardPlanDto> PlanChanged { get; set; }

    [Parameter]
    public EventCallback<(string FromId, string FromPort, string ToId, string ToPort)> ConnectionAdded { get; set; }

    [Parameter]
    public EventCallback<int> ConnectionRemoved { get; set; }

    [Parameter]
    public EventCallback<string> MachineRemoved { get; set; }

    [Parameter]
    public IReadOnlyList<SeaportPortFlowDto> SeaportPortFlows { get; set; } = Array.Empty<SeaportPortFlowDto>();

    [Parameter]
    public IReadOnlyList<MachinePortFlowDto> MachinePortFlows { get; set; } = Array.Empty<MachinePortFlowDto>();

    [Parameter]
    public IReadOnlyList<BoardIssueDto> BoardIssues { get; set; } = Array.Empty<BoardIssueDto>();

    [Parameter]
    public string? SelectedMachineId { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedMachineIdChanged { get; set; }

    [Parameter]
    public EventCallback LayoutCommitted { get; set; }

    [Parameter]
    public IReadOnlyList<ElementContentItem> ElementCatalog { get; set; } = Array.Empty<ElementContentItem>();

    [Parameter]
    public bool FillViewport { get; set; }

    [Parameter]
    public bool HideHelpText { get; set; }

    private Dictionary<string, MachineStoreItemDto> _machineMeta = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<int, ElementContentItem> _elementById = new();
    private Dictionary<string, SeaportPortFlowDto> _seaportPortByKey = new(StringComparer.Ordinal);
    private Dictionary<string, MachinePortFlowDto> _machinePortByKey = new(StringComparer.Ordinal);
    private Dictionary<string, string> _blockedByMachineId = new(StringComparer.Ordinal);
    private HashSet<string> _machinesWithFlow = new(StringComparer.Ordinal);
    private string _viewBox = "0 0 800 480";
    private string? _dragMachineId;
    private string? _pendingMachineDragId;
    private bool _machineDragMoved;
    private double _machineDragStartClientX;
    private double _machineDragStartClientY;
    private double _dragOffsetX;
    private double _dragOffsetY;
    private (string Id, string Port)? _pendingOut;
    private (string Id, string Port)? _dragPipeFrom;
    private (double X, double Y)? _dragCursor;
    private int? _selectedConnectionIndex;
    private bool _confirmRemoveVisible;
    private string? _pendingRemoveMachineId;
    private string _confirmRemoveMessage = "";
    private ElementReference _svgRef;
    private IJSObjectReference? _canvasModule;
    private DotNetObjectReference<FactoryCanvas>? _dotNetRef;
    private bool _pointerDragActive;
    private DateTime _suppressBackgroundClearUntilUtc;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _canvasModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/factory-canvas.js");
    }

    public async ValueTask DisposeAsync()
    {
        await StopPointerDragAsync();
        _dotNetRef?.Dispose();
        if (_canvasModule != null)
            await _canvasModule.DisposeAsync();
    }

    private sealed class SvgPoint
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    private sealed class PortHit
    {
        public string MachineId { get; set; } = "";
        public string Port { get; set; } = "";
        public bool IsOutput { get; set; }
    }

    private async Task<(double X, double Y)?> ClientToSvgAsync(double clientX, double clientY)
    {
        if (_canvasModule == null)
            return null;
        var pt = await _canvasModule.InvokeAsync<SvgPoint>("toSvgPoint", _svgRef, clientX, clientY);
        return (pt.X, pt.Y);
    }

    private async Task StartPointerDragAsync()
    {
        if (_canvasModule == null)
            return;
        _dotNetRef ??= DotNetObjectReference.Create(this);
        await _canvasModule.InvokeVoidAsync("startPointerDrag", _dotNetRef);
        _pointerDragActive = true;
    }

    private async Task StopPointerDragAsync()
    {
        if (_canvasModule == null || !_pointerDragActive)
            return;
        await _canvasModule.InvokeVoidAsync("stopPointerDrag");
        _pointerDragActive = false;
    }

    [JSInvokable]
    public async Task OnDocumentPointerMove(double clientX, double clientY)
    {
        if (ReadOnly)
            return;

        var pt = await ClientToSvgAsync(clientX, clientY);
        if (pt == null)
            return;

        if (_dragPipeFrom != null)
        {
            _dragCursor = pt;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_pendingMachineDragId != null && !_machineDragMoved)
        {
            var dx = clientX - _machineDragStartClientX;
            var dy = clientY - _machineDragStartClientY;
            if (dx * dx + dy * dy < MachineDragThresholdPx * MachineDragThresholdPx)
                return;

            _machineDragMoved = true;
            _dragMachineId = _pendingMachineDragId;
        }

        if (_dragMachineId == null)
            return;

        var machines = Plan.Machines.ToList();
        var idx = machines.FindIndex(m => m.Id == _dragMachineId);
        if (idx < 0)
            return;

        var nx = Math.Max(0, pt.Value.X - _dragOffsetX);
        var ny = Math.Max(0, pt.Value.Y - _dragOffsetY);
        machines[idx] = PlanLayout.WithPosition(machines[idx], nx, ny);
        var updated = new BoardPlanDto(machines, Plan.Connections);
        Plan = updated;
        UpdateViewBox();
        await PlanChanged.InvokeAsync(updated);
    }

    [JSInvokable]
    public async Task OnDocumentPointerUp(double clientX, double clientY)
    {
        var commitLayout = _machineDragMoved && _dragMachineId != null;
        var pipeFrom = _dragPipeFrom;
        _pendingMachineDragId = null;
        _machineDragMoved = false;
        _dragMachineId = null;
        _dragPipeFrom = null;
        _dragCursor = null;
        await StopPointerDragAsync();
        if (pipeFrom is { } from)
            await TryCompletePipeDragAsync(from, clientX, clientY);
        if (commitLayout)
            await LayoutCommitted.InvokeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task TryCompletePipeDragAsync((string Id, string Port) from, double clientX, double clientY)
    {
        if (_canvasModule == null || ReadOnly)
            return;

        var hit = await _canvasModule.InvokeAsync<PortHit?>("findPortAtPoint", _svgRef, clientX, clientY);
        if (hit == null || hit.IsOutput || hit.MachineId == from.Id)
            return;

        await ConnectionAdded.InvokeAsync((from.Id, from.Port, hit.MachineId, hit.Port));
    }

    protected override void OnParametersSet()
    {
        _machineMeta = MachineMeta.ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);
        _elementById = ElementCatalog.ToDictionary(e => e.Id);
        _seaportPortByKey = SeaportPortFlows.ToDictionary(
            p => PortFlowKey(p.MachineId, p.Port),
            StringComparer.Ordinal);
        _machinePortByKey = MachinePortFlows.ToDictionary(
            p => PortFlowKey(p.MachineId, p.Port),
            StringComparer.Ordinal);
        _blockedByMachineId = BoardIssues
            .Where(i => i.Severity == "error" && i.MachineId != null
                        && (i.Code == "machine_blocked" || i.Code == "dna_incompatible"))
            .GroupBy(i => i.MachineId!, StringComparer.Ordinal)
            .ToDictionary(g => g.Key, g => g.First().Message, StringComparer.Ordinal);
        _machinesWithFlow = BuildMachinesWithFlow();
        UpdateViewBox();
    }

    private HashSet<string> BuildMachinesWithFlow()
    {
        var set = new HashSet<string>(StringComparer.Ordinal);
        if (!IsFactoryRunning)
            return set;

        foreach (var flow in MachinePortFlows)
        {
            if (flow.IsEstimate)
                continue;
            if (flow.ProcessStatus is "Transformed" or "Processing")
                set.Add(flow.MachineId);
        }

        foreach (var sea in SeaportPortFlows)
        {
            if (!sea.IsEstimate && !string.IsNullOrEmpty(sea.ElementSymbol))
                set.Add(sea.MachineId);
        }

        return set;
    }

    private void UpdateViewBox()
    {
        if (Plan.Machines.Count == 0)
        {
            _viewBox = "0 0 800 480";
            return;
        }

        const double pipeMargin = 56;
        double maxX = 400, maxY = 300;
        for (var i = 0; i < Plan.Machines.Count; i++)
        {
            var (x, y) = PlanLayout.GetPosition(Plan.Machines[i], i);
            maxX = Math.Max(maxX, x + MachineWidth + CanvasPad + pipeMargin);
            maxY = Math.Max(maxY, y + MachineHeight + CanvasPad + pipeMargin);
        }
        _viewBox = $"0 0 {Fmt(maxX)} {Fmt(maxY)}";
    }

    private readonly record struct PipeEntry(int Index, PipeRouting.PipeDraw Draw);

    private IReadOnlyList<PipeEntry> BuildPipeEntries()
    {
        var indexed = Plan.Connections.Select((c, i) => (Conn: c, Index: i)).ToList();
        var pairTotals = indexed
            .GroupBy(x => PipeRouting.PairKey(x.Conn.FromId, x.Conn.ToId))
            .ToDictionary(g => g.Key, g => g.Count(), StringComparer.Ordinal);
        var pairLane = new Dictionary<string, int>(StringComparer.Ordinal);

        var entries = new List<PipeEntry>();
        foreach (var item in indexed.OrderBy(x => x.Conn.FromId, StringComparer.Ordinal)
                     .ThenBy(x => x.Conn.FromPort, StringComparer.Ordinal))
        {
            if (!TryGetPortPoint(item.Conn.FromId, item.Conn.FromPort, true, out var p1) ||
                !TryGetPortPoint(item.Conn.ToId, item.Conn.ToPort, false, out var p2))
                continue;

            var key = PipeRouting.PairKey(item.Conn.FromId, item.Conn.ToId);
            var lane = pairLane.GetValueOrDefault(key);
            pairLane[key] = lane + 1;
            var laneCount = pairTotals[key];
            var css = laneCount > 1
                ? $"fg-pipe fg-pipe-loop fg-pipe-loop-{(lane % 2 == 0 ? "a" : "b")}"
                : "fg-pipe";
            var path = PipeRouting.BuildPath(p1, p2, lane, laneCount);
            entries.Add(new PipeEntry(item.Index, new PipeRouting.PipeDraw(path, css)));
        }

        return entries;
    }

    private static double PortY(int index, int count, double height)
    {
        if (count <= 1)
            return height / 2;
        var margin = 14;
        var span = height - margin * 2;
        return margin + span * index / (count - 1);
    }

    private bool TryGetPortPoint(string machineId, string portName, bool isOutput, out (double X, double Y) point)
    {
        point = default;
        var idx = Plan.Machines.ToList().FindIndex(m => m.Id == machineId);
        if (idx < 0)
            return false;
        var m = Plan.Machines[idx];
        if (!_machineMeta.TryGetValue(m.Type, out var meta))
            return false;

        var ports = isOutput
            ? meta.Ports.Where(p => p.Direction == "out").ToList()
            : meta.Ports.Where(p => p.Direction == "in").ToList();
        var pi = ports.FindIndex(p => p.Name.Equals(portName, StringComparison.OrdinalIgnoreCase));
        if (pi < 0)
            return false;

        var (mx, my) = PlanLayout.GetPosition(m, idx);
        var py = PortY(pi, ports.Count, MachineHeight);
        point = isOutput
            ? (mx + MachineWidth, my + py)
            : (mx, my + py);
        return true;
    }

    private (double X, double Y) GetPortPointOrDefault(string machineId, string portName, bool isOutput) =>
        TryGetPortPoint(machineId, portName, isOutput, out var p) ? p : (0, 0);

    private static string PortFlowKey(string machineId, string port) => $"{machineId}\0{port}";

    private string? GetPortFlowHint(string machineId, string portName, bool isOutput)
    {
        if (isOutput && _machinePortByKey.TryGetValue(PortFlowKey(machineId, portName), out var outFlow))
        {
            if (outFlow.IsPoolSource && !string.IsNullOrEmpty(outFlow.OutputElementSymbol))
                return $"{outFlow.OutputElementSymbol} →";

            if (!string.IsNullOrEmpty(outFlow.InputElementSymbol)
                && !string.IsNullOrEmpty(outFlow.OutputElementSymbol)
                && outFlow.InputElementSymbol != outFlow.OutputElementSymbol)
                return $"{outFlow.InputElementSymbol}→{outFlow.OutputElementSymbol}";

            if (!string.IsNullOrEmpty(outFlow.OutputElementSymbol))
                return $"{outFlow.OutputElementSymbol} →";
        }

        if (!isOutput)
        {
            var conn = Plan.Connections.FirstOrDefault(c =>
                c.ToId == machineId && c.ToPort == portName);
            if (conn != null
                && _machinePortByKey.TryGetValue(PortFlowKey(conn.FromId, conn.FromPort), out var src)
                && !string.IsNullOrEmpty(src.OutputElementSymbol))
                return $"← {src.OutputElementSymbol}";
        }

        if (_seaportPortByKey.TryGetValue(PortFlowKey(machineId, portName), out var sea)
            && !string.IsNullOrEmpty(sea.ElementSymbol))
            return sea.Direction == "in" ? $"← {sea.ElementSymbol}" : $"{sea.ElementSymbol} →";

        return Plan.Connections.Any(c =>
            (c.FromId == machineId && c.FromPort == portName) || (c.ToId == machineId && c.ToPort == portName))
            ? "kopplad"
            : null;
    }

    private static string GetPortTitle(string portName, string? hint) =>
        string.IsNullOrEmpty(hint) ? portName : $"{portName}: {hint}";

    private string GetPipeTooltip(int connectionIndex)
    {
        if (connectionIndex < 0 || connectionIndex >= Plan.Connections.Count)
            return "Rör";

        var c = Plan.Connections[connectionIndex];
        var rate = FormatRate();
        var material = GetConnectionMaterialHint(c);
        return string.IsNullOrEmpty(material)
            ? $"{c.FromId}.{c.FromPort} → {c.ToId}.{c.ToPort} · {rate}"
            : $"{material} · {rate}\n{c.FromId}.{c.FromPort} → {c.ToId}.{c.ToPort}";
    }

    private string? GetConnectionMaterialHint(ConnectionDto c)
    {
        if (_machinePortByKey.TryGetValue(PortFlowKey(c.FromId, c.FromPort), out var flow))
        {
            if (!string.IsNullOrEmpty(flow.OutputElementSymbol))
                return FormatMaterialWithPhase(flow.OutputElementSymbol, flow.OutputPhase);
            if (!string.IsNullOrEmpty(flow.InputElementSymbol))
                return FormatMaterialWithPhase(flow.InputElementSymbol, flow.InputPhase ?? flow.OutputPhase);
        }
        return null;
    }

    private static string FormatMaterialWithPhase(string symbol, string? phase) =>
        string.IsNullOrEmpty(phase) ? symbol : $"{symbol} {PhaseShort(phase)}";

    private string GetMachineTooltip(MachineDto m)
    {
        var lines = new List<string> { $"{m.Id} ({m.Type})" };

        if (_blockedByMachineId.TryGetValue(m.Id, out var block))
            lines.Add(block);
        else if (IsFactoryRunning && _machinesWithFlow.Contains(m.Id))
            lines.Add($"Kör — ~{FormatRate()}");
        else if (IsFactoryRunning)
            lines.Add("Kör — väntar på material");
        else
            lines.Add(GetStoppedSettingsSummary(m, _elementById));

        foreach (var flow in MachinePortFlows.Where(f => f.MachineId == m.Id))
        {
            if (!string.IsNullOrEmpty(flow.Summary))
            {
                var phaseHint = BuildPhaseHint(flow);
                lines.Add(string.IsNullOrEmpty(phaseHint)
                    ? $"{flow.Port}: {flow.Summary}"
                    : $"{flow.Port}: {phaseHint} — {flow.Summary}");
            }
        }

        return string.Join("\n", lines.Distinct());
    }

    private static string GetStoppedSettingsSummary(
        MachineDto m,
        IReadOnlyDictionary<int, ElementContentItem> elementById)
    {
        var fields = MachineSettingsUi.GetFields(m.Type);
        if (fields.Count == 0)
            return "Inga inställningar — koppla rör och spara.";

        var parts = new List<string>();
        foreach (var field in fields)
        {
            if (MachineSettingsUi.UsesElementPicker(field))
            {
                var id = field.JsonKey switch
                {
                    "outElementId" => PlanMachineSettings.GetOutElementId(m),
                    "port1" or "port2" or "port3" => PlanMachineSettings.GetSorterPortElement(m, field.JsonKey),
                    _ => 0
                };
                parts.Add(id > 0
                    ? $"{field.Label}: {FormatElementLabel(id, elementById)}"
                    : $"{field.Label}: (ingenting)");
            }
            else
            {
                var v = PlanMachineSettings.GetInt(m, field.JsonKey, -1);
                if (v >= 0)
                {
                    var opt = field.Options.FirstOrDefault(o => o.Value == v);
                    parts.Add($"{field.Label}: {opt?.Label ?? v.ToString()}");
                }
            }
        }
        return string.Join(" · ", parts);
    }

    private static string FormatElementLabel(int elementId, IReadOnlyDictionary<int, ElementContentItem> elementById)
    {
        if (elementById.TryGetValue(elementId, out var el))
            return $"{el.Symbol} — {el.Name}";
        return $"id {elementId}";
    }

    private static string BuildPhaseHint(MachinePortFlowDto flow)
    {
        if (flow.DnaChanged
            && !string.IsNullOrEmpty(flow.InputElementSymbol)
            && !string.IsNullOrEmpty(flow.OutputElementSymbol)
            && !string.IsNullOrEmpty(flow.InputPhase)
            && !string.IsNullOrEmpty(flow.OutputPhase))
        {
            return $"{flow.InputElementSymbol} {PhaseShort(flow.InputPhase)}→{PhaseShort(flow.OutputPhase)}";
        }

        if (!string.IsNullOrEmpty(flow.OutputPhase) && !string.IsNullOrEmpty(flow.OutputElementSymbol))
            return $"{flow.OutputElementSymbol} {PhaseShort(flow.OutputPhase)}";

        return "";
    }

    private static string PhaseShort(string phaseKey) => phaseKey.ToLowerInvariant() switch
    {
        "gas" => "gas",
        "liquid" => "vätska",
        "solid" => "fast",
        _ => phaseKey
    };

    private string FormatRate() =>
        UnitsPerSecond >= 0.01
            ? $"{UnitsPerSecond:0.##} enheter/s"
            : "1 enhet/tick";

    private string GetPipeFlowClass(int connectionIndex)
    {
        if (!IsFactoryRunning || connectionIndex < 0 || connectionIndex >= Plan.Connections.Count)
            return "";
        var c = Plan.Connections[connectionIndex];
        return _machinesWithFlow.Contains(c.FromId) ? "fg-pipe-flowing" : "";
    }

    private string GetPipePhaseClass(int connectionIndex)
    {
        if (connectionIndex < 0 || connectionIndex >= Plan.Connections.Count)
            return "";

        var c = Plan.Connections[connectionIndex];
        if (!_machinePortByKey.TryGetValue(PortFlowKey(c.FromId, c.FromPort), out var flow)
            || string.IsNullOrEmpty(flow.OutputPhase))
            return "";

        return flow.OutputPhase.ToLowerInvariant() switch
        {
            "gas" => "fg-pipe-phase-gas",
            "liquid" => "fg-pipe-phase-liquid",
            "solid" => "fg-pipe-phase-solid",
            _ => ""
        };
    }

    private bool IsCondenserTransforming(string machineId)
    {
        if (!IsFactoryRunning)
            return false;

        var machine = Plan.Machines.FirstOrDefault(m => m.Id == machineId);
        if (machine == null || !machine.Type.Equals("Condenser", StringComparison.OrdinalIgnoreCase))
            return false;

        return MachinePortFlows.Any(f =>
            f.MachineId == machineId
            && f.ProcessStatus == "Transformed"
            && f.DnaChanged);
    }

    private bool HasPortFlow(string machineId, string portName, bool isOutput)
    {
        if (!IsFactoryRunning)
            return false;
        if (isOutput && _machinePortByKey.ContainsKey(PortFlowKey(machineId, portName)))
            return !string.IsNullOrEmpty(_machinePortByKey[PortFlowKey(machineId, portName)].OutputElementSymbol);
        if (!isOutput)
        {
            var conn = Plan.Connections.FirstOrDefault(c => c.ToId == machineId && c.ToPort == portName);
            if (conn != null)
                return _machinesWithFlow.Contains(conn.FromId);
        }
        return false;
    }

    private bool IsMachineBlocked(string machineId) => _blockedByMachineId.ContainsKey(machineId);

    private bool IsMachineRunning(string machineId) =>
        IsFactoryRunning && !IsMachineBlocked(machineId) && _machinesWithFlow.Contains(machineId);

    private string PortClass(string machineId, string portName, bool isOutput)
    {
        var classes = new List<string>();
        if (_pendingOut is { } p && isOutput && p.Id == machineId && p.Port == portName)
            classes.Add("fg-port-pending");
        if (_dragPipeFrom is { } d && isOutput && d.Id == machineId && d.Port == portName)
            classes.Add("fg-port-pending");

        var occupied = isOutput
            ? Plan.Connections.Any(c => c.FromId == machineId && c.FromPort == portName)
            : Plan.Connections.Any(c => c.ToId == machineId && c.ToPort == portName);
        if (occupied)
            classes.Add("fg-port-occupied");

        return string.Join(' ', classes);
    }

    private bool IsSelected(string machineId) =>
        !string.IsNullOrEmpty(SelectedMachineId)
        && SelectedMachineId.Equals(machineId, StringComparison.Ordinal);

    private Task OnMachineClick(string machineId)
    {
        if (ReadOnly)
            return Task.CompletedTask;
        return SelectedMachineIdChanged.InvokeAsync(machineId);
    }

    private async Task OnMachineMouseDown(MouseEventArgs e, string machineId)
    {
        if (ReadOnly || e.Button != 0)
            return;

        _dragPipeFrom = null;
        _dragCursor = null;
        _pendingOut = null;
        _dragMachineId = null;
        _machineDragMoved = false;
        _suppressBackgroundClearUntilUtc = DateTime.UtcNow.AddMilliseconds(400);
        await SelectedMachineIdChanged.InvokeAsync(machineId);
        _pendingMachineDragId = machineId;
        _machineDragStartClientX = e.ClientX;
        _machineDragStartClientY = e.ClientY;

        var pt = await ClientToSvgAsync(e.ClientX, e.ClientY);
        if (pt == null)
            return;

        var idx = Plan.Machines.ToList().FindIndex(m => m.Id == machineId);
        if (idx < 0)
            return;

        var (mx, my) = PlanLayout.GetPosition(Plan.Machines[idx], idx);
        _dragOffsetX = pt.Value.X - mx;
        _dragOffsetY = pt.Value.Y - my;
        await StartPointerDragAsync();
    }

    private async Task OnCanvasBackgroundClick()
    {
        if (DateTime.UtcNow < _suppressBackgroundClearUntilUtc)
            return;

        _pendingOut = null;
        _dragPipeFrom = null;
        _dragCursor = null;
        _selectedConnectionIndex = null;
        await SelectedMachineIdChanged.InvokeAsync(null);
    }

    private void OnPipeClick(int connectionIndex)
    {
        if (ReadOnly)
            return;
        _pendingOut = null;
        _dragPipeFrom = null;
        _selectedConnectionIndex = _selectedConnectionIndex == connectionIndex ? null : connectionIndex;
        StateHasChanged();
    }

    private void ClearPipeSelection()
    {
        _selectedConnectionIndex = null;
        StateHasChanged();
    }

    private async Task RemoveSelectedPipeAsync()
    {
        if (ReadOnly || _selectedConnectionIndex is not int idx)
            return;
        if (idx < 0 || idx >= Plan.Connections.Count)
            return;

        await ConnectionRemoved.InvokeAsync(idx);
        _selectedConnectionIndex = null;
        await InvokeAsync(StateHasChanged);
    }

    private void RequestRemoveMachine(MachineDto m)
    {
        if (ReadOnly)
            return;
        _pendingRemoveMachineId = m.Id;
        _confirmRemoveMessage =
            $"Ta bort maskin {m.Id} ({m.Type})? Alla kopplade rör tas också bort.";
        _confirmRemoveVisible = true;
    }

    private async Task ConfirmRemoveMachineAsync()
    {
        if (ReadOnly || string.IsNullOrEmpty(_pendingRemoveMachineId))
        {
            CancelRemoveMachine();
            return;
        }

        var machineId = _pendingRemoveMachineId;
        CancelRemoveMachine();
        await MachineRemoved.InvokeAsync(machineId);
        if (!string.IsNullOrEmpty(SelectedMachineId)
            && SelectedMachineId.Equals(machineId, StringComparison.Ordinal))
            await SelectedMachineIdChanged.InvokeAsync(null);
    }

    private void CancelRemoveMachine()
    {
        _confirmRemoveVisible = false;
        _pendingRemoveMachineId = null;
        _confirmRemoveMessage = "";
    }

    private async Task OnPortMouseDown(MouseEventArgs e, string machineId, string portName, bool isOutput)
    {
        if (ReadOnly || !isOutput || e.Button != 0)
            return;

        _dragMachineId = null;
        _pendingMachineDragId = null;
        _machineDragMoved = false;
        _dragPipeFrom = (machineId, portName);
        var pt = await ClientToSvgAsync(e.ClientX, e.ClientY);
        _dragCursor = pt;
        _pendingOut = null;
        _selectedConnectionIndex = null;
        await StartPointerDragAsync();
    }

    private async Task OnPortMouseUp(MouseEventArgs e, string machineId, string portName, bool isOutput)
    {
        if (ReadOnly)
            return;

        if (isOutput)
        {
            if (_dragPipeFrom != null)
            {
                _dragPipeFrom = null;
                _dragCursor = null;
                await StopPointerDragAsync();
            }
            return;
        }

        if (_dragPipeFrom is { } from)
        {
            _dragPipeFrom = null;
            _dragCursor = null;
            await StopPointerDragAsync();
            if (from.Id != machineId)
                await ConnectionAdded.InvokeAsync((from.Id, from.Port, machineId, portName));
            return;
        }

        await OnPortClick(machineId, portName, false);
    }

    private async Task OnPortClick(string machineId, string portName, bool isOutput)
    {
        if (ReadOnly)
            return;

        _selectedConnectionIndex = null;

        if (isOutput)
        {
            _pendingOut = (machineId, portName);
            _dragPipeFrom = null;
            return;
        }

        if (_pendingOut is not { } from)
            return;

        _pendingOut = null;
        if (from.Id == machineId)
            return;

        await ConnectionAdded.InvokeAsync((from.Id, from.Port, machineId, portName));
    }

    private static string Fmt(double v) => v.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
}
