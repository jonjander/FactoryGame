@using System.Globalization
@using FactoryGame.Contracts.Pool
@using FactoryGame.Web.Models
@using FactoryGame.Web.Services
@inject BoardCanvasSession Session
@inject ViewportLayoutService Viewport
@inject GameShellNavigation ShellNav
@inject GameWindowService Windows
@inject NavigationManager Nav

@if (Visible && Element is not null)
{
    <div class="fg-modal-backdrop" @onclick="CloseAsync">
        <div class="fg-modal fg-modal-wide pool-analysis-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pool-analysis-title">
            <div class="pool-analysis-header">
                <div>
                    <h3 id="pool-analysis-title" class="fg-modal-title">@DisplayTitle</h3>
                    <p class="muted pool-analysis-subtitle">
                        <span class="fg-element-badge" title="@VariantLabel">@DisplayBadge</span>
                        Element @Element.Id
                    </p>
                </div>
                <button type="button" class="secondary pool-analysis-close" @onclick="CloseAsync" aria-label="Close">X</button>
            </div>

            <p class="pool-analysis-narrative">@ElementPropertyNarrator.Describe(Element)</p>

            @if (FactoryFlow is { } flow && (flow.ConsumedByFactory || flow.ProducedByFactory))
            {
                <h4 class="pool-analysis-section-title">Seaport</h4>
                <ul class="pool-factory-flow-list">
                    @if (flow.ConsumedByFactory)
                    {
                        <li>
                            <span class="pool-factory-flow-icon pool-factory-flow-consume" aria-hidden="true">↓</span>
                            Withdraw to factory: <strong>@FormatRate(flow.ConsumeUnitsPerSecond)</strong> units/s
                        </li>
                    }
                    @if (flow.ProducedByFactory)
                    {
                        <li>
                            <span class="pool-factory-flow-icon pool-factory-flow-produce" aria-hidden="true">↑</span>
                            Deposit from factory: <strong>@FormatRate(flow.ProduceUnitsPerSecond)</strong> units/s
                        </li>
                    }
                    @if (flow.ConsumedByFactory && flow.ProducedByFactory)
                    {
                        <li class="muted">Combined turnover: @FormatRate(TotalTurnover(flow)) units/s</li>
                    }
                </ul>
                @if (flow.FlowIsEstimate)
                {
                    <p class="muted pool-factory-flow-hint">Planned capacity from factory layout (factory stopped or material not yet determined).</p>
                }
                else
                {
                    <p class="muted pool-factory-flow-hint">Planned seaport capacity from running factory layout.</p>
                }

                @if (flow.Boards.Count > 0)
                {
                    <div class="pool-factory-board-list">
                        @foreach (var board in flow.Boards)
                        {
                            <section class="pool-factory-board-card">
                                <div class="pool-factory-board-header">
                                    <div>
                                        <strong>@board.BoardName</strong>
                                        <span class="muted pool-factory-board-mode">
                                            @(board.IsRunning ? "Running" : "Stopped")
                                        </span>
                                    </div>
                                    <button type="button" class="secondary pool-factory-open-btn" @onclick="() => OpenFactoryAsync(board.BoardId, null)">
                                        Open factory
                                    </button>
                                </div>
                                @if (board.Machines.Count > 0)
                                {
                                    <ul class="pool-factory-machine-list">
                                        @foreach (var machine in board.Machines)
                                        {
                                            <li class="pool-factory-machine-row">
                                                <span class="pool-factory-flow-icon @(machine.Role == "produce" ? "pool-factory-flow-produce" : "pool-factory-flow-consume")" aria-hidden="true">
                                                    @(machine.Role == "produce" ? "↑" : "↓")
                                                </span>
                                                <div class="pool-factory-machine-main">
                                                    <button type="button" class="pool-factory-machine-link" @onclick="() => OpenFactoryAsync(board.BoardId, machine.MachineId)">
                                                        <strong>@machine.MachineId</strong>
                                                        <span class="muted">@machine.MachineType</span>
                                                    </button>
                                                    <span class="muted pool-factory-machine-role">
                                                        @(machine.Role == "produce" ? "Deposits to pool" : "Withdraws from pool")
                                                        @if (machine.UnitsPerSecond is { } rate and > 0)
                                                        {
                                                            <span> · @FormatRate(rate) u/s</span>
                                                        }
                                                        @if (machine.IsEstimate)
                                                        {
                                                            <span> · estimate</span>
                                                        }
                                                    </span>
                                                    @if (!string.IsNullOrWhiteSpace(machine.Summary))
                                                    {
                                                        <span class="muted pool-factory-machine-summary">@machine.Summary</span>
                                                    }
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                            </section>
                        }
                    </div>
                }
            }

            <h4 class="pool-analysis-section-title">DNA breakdown</h4>
            <WikiDnaChart Element="Element" />
            <p class="muted pool-dna-hex">DNA: @FormatDnaHex(EffectiveDna)</p>

            <h4 class="pool-analysis-section-title">Properties</h4>
            <dl class="pool-props-grid">
                <dt>Phase</dt><dd>@Element.Decoded.Phase</dd>
                <dt>Explosivity</dt><dd>@Element.Decoded.Explosivity %</dd>
                <dt>Flammability</dt><dd>@Element.Decoded.Flammability %</dd>
                <dt>Toxicity</dt><dd>@Element.Decoded.Toxicity %</dd>
                <dt>Boiling point</dt><dd>@Element.Decoded.BoilingPoint</dd>
                <dt>Freeze point</dt><dd>@Element.Decoded.FreezePoint</dd>
                <dt>Family</dt><dd>@Element.Decoded.FamilyId</dd>
            </dl>

            <div class="fg-modal-actions pool-analysis-footer">
                <a class="button-link" href="@ExchangeHref">Show in Exchange</a>
                <a class="button-link secondary" href="@WikiHref">Open in wiki</a>
                <button type="button" class="secondary" @onclick="CloseAsync">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public ElementContentItem? Element { get; set; }

    [Parameter]
    public long? VariantDna { get; set; }

    [Parameter]
    public string? VariantLabel { get; set; }

    [Parameter]
    public PoolElementFactoryFlowDto? FactoryFlow { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private long EffectiveDna => VariantDna ?? Element?.Dna ?? 0;

    private string DisplayTitle => VariantLabel ?? Element?.Name ?? "";

    private string DisplayBadge =>
        MaterialLabelUi.Compact(VariantLabel) ?? Element?.Symbol ?? "";

    private string ExchangeHref =>
        Element is null || EffectiveDna == 0
            ? "/exchange"
            : $"/exchange?elementId={Element.Id}&dna={EffectiveDna.ToString(CultureInfo.InvariantCulture)}&side=sell";

    private string WikiHref =>
        Element is null
            ? "/wiki"
            : EffectiveDna == 0
                ? $"/wiki?elementId={Element.Id}&tab=elements"
                : $"/wiki?elementId={Element.Id}&dna={EffectiveDna.ToString(CultureInfo.InvariantCulture)}&tab=elements";

    private static string FormatDnaHex(long dna) => $"0x{dna.ToString("X16", CultureInfo.InvariantCulture)}";

    private static string FormatRate(double? rate) =>
        rate.HasValue ? rate.Value.ToString("0.##", CultureInfo.InvariantCulture) : "0";

    private static double? TotalTurnover(PoolElementFactoryFlowDto flow) =>
        (flow.ConsumeUnitsPerSecond ?? 0) + (flow.ProduceUnitsPerSecond ?? 0);

    private async Task OpenFactoryAsync(Guid boardId, string? machineId)
    {
        await Session.OpenFactoryAsync(boardId, machineId);
        await CloseAsync();

        if (Viewport.UseGameShell)
        {
            ShellNav.NavigateAndOpen("/boards", "boards-picker");
            Windows.Close("pool");
        }
        else
        {
            Nav.NavigateTo("/boards");
        }
    }

    private Task CloseAsync() => OnClose.InvokeAsync();
}
