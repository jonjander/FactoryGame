@using System.Globalization
@using FactoryGame.Web.Models
@using FactoryGame.Web.Services

@if (Visible && Element is not null)
{
    <div class="fg-modal-backdrop" @onclick="CloseAsync">
        <div class="fg-modal fg-modal-wide pool-analysis-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pool-analysis-title">
            <div class="pool-analysis-header">
                <div>
                    <h3 id="pool-analysis-title" class="fg-modal-title">@DisplayTitle</h3>
                    <p class="muted pool-analysis-subtitle">
                        <span class="fg-element-badge" title="@VariantLabel">@DisplayBadge</span>
                        Element @Element.Id
                    </p>
                </div>
                <button type="button" class="secondary pool-analysis-close" @onclick="CloseAsync" aria-label="Close">X</button>
            </div>

            <p class="pool-analysis-narrative">@ElementPropertyNarrator.Describe(Element)</p>

            <h4 class="pool-analysis-section-title">DNA breakdown</h4>
            <WikiDnaChart Element="Element" />
            <p class="muted pool-dna-hex">DNA: @FormatDnaHex(EffectiveDna)</p>

            <h4 class="pool-analysis-section-title">Properties</h4>
            <dl class="pool-props-grid">
                <dt>Phase</dt><dd>@Element.Decoded.Phase</dd>
                <dt>Explosivity</dt><dd>@Element.Decoded.Explosivity %</dd>
                <dt>Flammability</dt><dd>@Element.Decoded.Flammability %</dd>
                <dt>Toxicity</dt><dd>@Element.Decoded.Toxicity %</dd>
                <dt>Boiling point</dt><dd>@Element.Decoded.BoilingPoint</dd>
                <dt>Freeze point</dt><dd>@Element.Decoded.FreezePoint</dd>
                <dt>Family</dt><dd>@Element.Decoded.FamilyId</dd>
            </dl>

            <div class="fg-modal-actions pool-analysis-footer">
                <a class="button-link" href="@ExchangeHref">Show in Exchange</a>
                <a class="button-link secondary" href="/wiki?elementId=@Element.Id">Open in wiki</a>
                <button type="button" class="secondary" @onclick="CloseAsync">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public ElementContentItem? Element { get; set; }

    [Parameter]
    public long? VariantDna { get; set; }

    [Parameter]
    public string? VariantLabel { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private long EffectiveDna => VariantDna ?? Element?.Dna ?? 0;

    private string DisplayTitle => VariantLabel ?? Element?.Name ?? "";

    private string DisplayBadge =>
        MaterialLabelUi.Compact(VariantLabel) ?? Element?.Symbol ?? "";

    private string ExchangeHref =>
        Element is null || EffectiveDna == 0
            ? "/exchange"
            : $"/exchange?elementId={Element.Id}&dna={EffectiveDna.ToString(CultureInfo.InvariantCulture)}&side=sell";

    private static string FormatDnaHex(long dna) => $"0x{dna.ToString("X16", CultureInfo.InvariantCulture)}";

    private Task CloseAsync() => OnClose.InvokeAsync();
}
