@using FactoryGame.Web.Services

<div class="wiki-machine-icon-wrap wiki-machine-icon-@Category" aria-hidden="true">
    @((MarkupString)BuildIconSvg(Type))
    <span class="wiki-machine-icon-emoji">@WikiPresentation.MachineEmoji(Type)</span>
</div>

@code {
    [Parameter, EditorRequired]
    public string Type { get; set; } = "";

    private string Category => WikiPresentation.MachineCategory(Type);

    private static string BuildIconSvg(string type)
    {
        var (body, accent) = type switch
        {
            "Boiler" or "Heater" => ("#5c2a1a", "#f0883e"),
            "Cooler" or "Condenser" or "Crystallizer" => ("#1a3d5c", "#58a6ff"),
            "Mixer" => ("#3d2a5c", "#bc8cff"),
            "Destilator" or "LiquidSeparator" => ("#2a4a22", "#79c27a"),
            "Sorter" => ("#4a4222", "#d29922"),
            "Tank" or "Junction" or "RateLimiter" => ("#2a3544", "#79b8ff"),
            "SeaportConnector" or "SeaportIn" or "SeaportOut" => ("#1a3d3d", "#39d353"),
            "Melter" => ("#5c3a1a", "#e3b341"),
            _ => ("#21262d", "#8b949e")
        };

        var label = type.Length > 9 ? type[..9] : type;
        return $"""
            <svg viewBox="0 0 120 72" xmlns="http://www.w3.org/2000/svg" class="wiki-machine-icon-svg">
              <rect class="wiki-machine-body-rect" x="8" y="12" width="104" height="48" rx="8" fill="{body}" stroke="{accent}" stroke-width="2"/>
              <circle cx="8" cy="36" r="5" fill="#238636"/>
              <circle cx="112" cy="28" r="5" fill="#1f6feb"/>
              <circle cx="112" cy="44" r="5" fill="#1f6feb"/>
              <text x="60" y="42" text-anchor="middle" fill="#e6edf3" font-size="10" font-family="system-ui,sans-serif">{Escape(label)}</text>
            </svg>
            """;
    }

    private static string Escape(string s) =>
        s.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
}
