@using FactoryGame.Contracts.Machines
@inject BoardCanvasSession Session
@inject ViewportLayoutService Viewport
@inject GameWindowService Windows
@inject GameShellNavigation ShellNav

<div class="fg-place-machine-panel">
    <h4>Place from inventory</h4>
    @if (Session.Inventory.Count == 0)
    {
        <p class="muted">No machines in inventory. Buy machines in the store first.</p>
        @if (Viewport.UseGameShell)
        {
            <button type="button" class="secondary" @onclick="OpenStore">Open machine store</button>
        }
        else
        {
            <a class="secondary secondary-link" href="#fg-machine-store">Go to machine store</a>
        }
    }    else
    {
        <div class="fg-place-machine-grid">
            @foreach (var row in Session.Inventory)
            {
                var selected = !string.IsNullOrEmpty(Session.PlaceStockId) && Session.PlaceStockId == row.Id.ToString();
                Session.MachineMeta.TryGetValue(row.MachineType, out var meta);
                <button type="button"
                        class="fg-place-machine-card @(selected ? "fg-place-machine-card-selected" : "")"
                        disabled="@Session.Busy"
                        @onclick="() => SelectStock(row)">
                    <WikiMachineIcon Type="@row.MachineType" Ports="@FormatPorts(meta)" />
                    <span class="fg-place-machine-type">@row.MachineType</span>
                    <span class="muted fg-place-machine-id">@DisplayIds.ShortGuid(row.Id)</span>
                </button>
            }
        </div>
        <div class="fg-row fg-place-machine-actions">
            <div>
                <label>New machine id on board</label>
                <input @bind="Session.PlaceMachineId" placeholder="e.g. boiler1" />
            </div>
            <button type="button" @onclick="Session.PlaceFromStockAsync" disabled="@Session.Busy || string.IsNullOrEmpty(Session.PlaceStockId)">
                Place
            </button>
        </div>
    }
</div>

@code {
    private void SelectStock(PlayerMachineStockDto row)
    {
        Session.PlaceStockId = row.Id.ToString();
        Session.OnPlaceStockChanged();
    }

    private void OpenStore()
    {
        ShellNav.EnsureRegistered();
        Windows.Toggle("store");
    }
    private static string? FormatPorts(MachineStoreItemDto? meta)
    {
        if (meta?.Ports is not { Count: > 0 } ports)
            return null;
        var ins = string.Join(",", ports.Where(p => p.Direction == "in").Select(p => p.Name));
        var outs = string.Join(",", ports.Where(p => p.Direction == "out").Select(p => p.Name));
        return $"{ins}:{outs}";
    }
}
